<%- include('../layouts/header', {
  title: 'Desco AI — DESCO CRM',
  activePage: 'ai',
  user: user}) %>

<style>
/* ═══════════════════════════════════════════
   AI CHAT PAGE — Minimalist Design
═══════════════════════════════════════════ */
.ai-page {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 40px); /* Fill available space minus padding */
  max-width: 900px;
  margin: 0 auto;
  background: var(--bg-primary);
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  overflow: hidden;
  border: 1px solid var(--border-color);
}

body.dark-mode .ai-page {
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}

.ai-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--bg-secondary);
}

.ai-header-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: var(--accent);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.ai-header-text h2 {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 2px;
}

.ai-header-text p {
  font-size: 12px;
  color: var(--text-tertiary);
}

.chat-box {
  flex: 1;
  padding: 24px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.msg {
  display: flex;
  flex-direction: column;
  max-width: 80%;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.msg.user {
  align-self: flex-end;
}

.msg.assistant {
  align-self: flex-start;
}

.msg-bubble {
  padding: 12px 16px;
  border-radius: 16px;
  font-size: 14px;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
}

.msg.user .msg-bubble {
  background: var(--accent);
  color: #fff;
  border-bottom-right-radius: 4px;
}

.msg.assistant .msg-bubble {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  border-bottom-left-radius: 4px;
}

.msg-time {
  font-size: 11px;
  color: var(--text-tertiary);
  margin-top: 4px;
  margin-bottom: -4px;
}
.msg.user .msg-time { text-align: right; }
.msg.assistant .msg-time { text-align: left; }

.chat-input-area {
  padding: 20px 24px;
  background: var(--bg-primary);
  border-top: 1px solid var(--border-color);
}

.chat-input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 24px;
  padding: 6px 6px 6px 20px;
  transition: border-color 0.2s;
}

.chat-input-wrapper:focus-within {
  border-color: var(--accent);
}

.chat-input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-size: 14px;
  padding: 10px 0;
  max-height: 120px;
  resize: none;
  font-family: inherit;
  outline: none;
  line-height: 1.4;
}

.chat-input::placeholder {
  color: var(--text-tertiary);
}

.chat-send-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--accent);
  color: white;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.chat-send-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
}

.chat-send-btn:disabled {
  background: var(--text-tertiary);
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

/* Typing Indicator */
.typing-indicator {
  display: none;
  align-self: flex-start;
  background: var(--bg-secondary);
  padding: 12px 16px;
  border-radius: 16px;
  border-bottom-left-radius: 4px;
  border: 1px solid var(--border-color);
  gap: 4px;
  align-items: center;
}

.typing-dot {
  width: 6px;
  height: 6px;
  background: var(--text-tertiary);
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* Scrollbar styling for chat */
.chat-box::-webkit-scrollbar { width: 6px; }
.chat-box::-webkit-scrollbar-track { background: transparent; }
.chat-box::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
.chat-box::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }

</style>

<div class="ai-page">
  <div class="ai-header">
    <div class="ai-header-icon"><i class="fas fa-robot"></i></div>
    <div class="ai-header-text">
      <h2>Desco AI (DeepSeek)</h2>
      <p>Sdelkalar, mijozlar va sotuv bo'yicha aqlli yordamchi</p>
    </div>
  </div>

  <div class="chat-box" id="chatBox">
    <div class="msg assistant">
      <div class="msg-bubble">Assalomu alaykum, <b><%= user ? user.fullName : '' %></b>! Men Desco AI yordamchisiman. 
Sizning CRM tizimingizdagi joriy faol sdelkalar va mijozlar ma'lumotlarini tahlil qilib, savollaringizga javob bera olaman.<br><br>
<b>Menga berishingiz mumkin bo'lgan ba'zi savollar / imkoniyatlar:</b>
<ul style="margin: 8px 0; padding-left: 20px; line-height: 1.6; font-size: 13px;">
  <li><code>#385 haqida ma'lumot ber</code> — Sdelka ID raqami orqali mijoz, telefon, viloyat, bosqich, menejer va izohlarni ko'rsataman.</li>
  <li><code>Samarqandga Damas shopir topib ber</code> — Telegram guruh/kanallaridan viloyatlar aro yuk tashuvchi haydovchilarni (tel, ismi, guruhi bilan) qidirib beraman.</li>
  <li><code>Alisher Umarovni sdelka #305 ga shopir qilib belgilab qo'y</code> — Topilgan haydovchini buyurtmaga (DeliveryLog) biriktiraman.</li>
  <li><code>Ertaga soat 10:00 ga mijoz bilan bog'lanish bo'yicha vazifa yaratib ber</code> — Avtomatik ravishda tizimda yangi vazifa (Task) yarataman.</li>
  <li><code>Hisobot chiqarib ber</code> — Sotuvlar, tushumlar bo'yicha Excel (CSV) fayl qilib yuklab olish tugmasi bilan tartibli jadval taqdim etaman.</li>
</ul></div>
      <div class="msg-time">Tizim xabari</div>
    </div>
    
    <!-- Typing indicator placeholder -->
    <div class="typing-indicator" id="typingIndicator">
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
    </div>
  </div>

  <div class="chat-input-area">
    <div class="chat-input-wrapper">
      <textarea id="chatInput" class="chat-input" placeholder="Xabar yozing (masalan, 'Mening faol sdelkalarim haqida qisqacha ma\'lumot ber')" rows="1" oninput="autoResize(this)" onkeydown="handleEnter(event)"></textarea>
      <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()">
        <i class="fas fa-paper-plane" style="margin-left:-2px; margin-top: 2px;"></i>
      </button>
    </div>
  </div>
</div>

<script>
// Chat history array for DeepSeek context
let chatHistory = [];

const chatBox = document.getElementById('chatBox');
const chatInput = document.getElementById('chatInput');
const sendBtn = document.getElementById('sendBtn');
const typingIndicator = document.getElementById('typingIndicator');

function autoResize(textarea) {
  textarea.style.height = 'auto';
  textarea.style.height = (textarea.scrollHeight < 120 ? textarea.scrollHeight : 120) + 'px';
}

function handleEnter(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function getTimeString() {
  const now = new Date();
  return now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
}

function parseMarkdown(text) {
  if (!text) return '';
  
  // 1. Normalize line breaks
  let html = text.replace(/\\n/g, '\n');
  
  // 2. Parse Markdown tables (e.g. | col1 | col2 |)
  const tableRegex = /((?:\|[^\n]*\|(?:\n|$))+)/g;
  html = html.replace(tableRegex, (match) => {
    const lines = match.trim().split('\n');
    if (lines.length < 2) return match;
    
    let tableHtml = '<div class="table-container" style="overflow-x:auto; margin:16px 0; border:1px solid var(--border); border-radius:10px; background:var(--bg-secondary); box-shadow:var(--shadow-sm);"><table class="ai-report-table" style="width:100%; border-collapse:collapse; font-size:12.5px; text-align:left;">';
    let hasHeader = false;
    
    lines.forEach((line, index) => {
      if (line.trim().startsWith('|') && line.includes('---')) return; // skip separator row
      
      const cells = line.split('|').map(c => c.trim()).filter((c, i, arr) => i > 0 && i < arr.length - 1);
      if (cells.length === 0) return;
      
      if (index === 0 || !hasHeader) {
        tableHtml += '<thead style="background:var(--bg-tertiary); border-bottom:1px solid var(--border);"><tr>';
        cells.forEach(cell => {
          tableHtml += `<th style="padding:12px 14px; font-weight:700; color:var(--text-secondary);">${cell}</th>`;
        });
        tableHtml += '</tr></thead><tbody>';
        hasHeader = true;
      } else {
        tableHtml += '<tr style="border-bottom:1px solid var(--border); transition:background 0.15s;" onmouseover="this.style.background=\'var(--bg-primary)\'" onmouseout="this.style.background=\'transparent\'">';
        cells.forEach(cell => {
          tableHtml += `<td style="padding:10px 14px; color:var(--text-primary);">${cell}</td>`;
        });
        tableHtml += '</tr>';
      }
    });
    
    if (hasHeader) tableHtml += '</tbody>';
    tableHtml += '</table>';
    
    // Download CSV button
    tableHtml += `
      <div style="padding:10px 14px; background:var(--bg-tertiary); border-top:1px solid var(--border); display:flex; justify-content:flex-end;">
        <button class="btn btn-primary btn-sm" onclick="downloadTableAsCSV(this)" style="font-size:11.5px; padding:6px 12px; border-radius:6px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
          <i class="fas fa-file-excel"></i> Excel (CSV) yuklab olish
        </button>
      </div>
    `;
    tableHtml += '</div>';
    return tableHtml;
  });
  
  // 3. Bold styling
  html = html.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
  
  // 4. Linebreaks outside of parsed tables
  html = html.replace(/\n/g, '<br>');
  
  return html;
}

function downloadTableAsCSV(button) {
  const container = button.closest('.table-container');
  const table = container.querySelector('table');
  if (!table) return;
  
  let csvContent = "\uFEFF"; // UTF-8 BOM for Excel compatibility with Uzbek/Cyrillic characters
  const rows = table.querySelectorAll('tr');
  
  rows.forEach(row => {
    const cols = row.querySelectorAll('th, td');
    const rowData = [];
    cols.forEach(col => {
      let text = col.innerText.replace(/"/g, '""').trim();
      rowData.push(`"${text}"`);
    });
    csvContent += rowData.join(',') + "\r\n";
  });
  
  const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
  const link = document.createElement("a");
  const url = URL.createObjectURL(blob);
  link.setAttribute("href", url);
  link.setAttribute("download", `desco_ai_hisobot_${new Date().toISOString().slice(0,10)}.csv`);
  link.style.visibility = 'hidden';
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}

function appendMessage(role, content) {
  const msgDiv = document.createElement('div');
  msgDiv.className = 'msg ' + role;
  
  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.innerHTML = parseMarkdown(content);
  
  const time = document.createElement('div');
  time.className = 'msg-time';
  time.textContent = getTimeString();

  msgDiv.appendChild(bubble);
  msgDiv.appendChild(time);
  
  // Insert before typing indicator
  chatBox.insertBefore(msgDiv, typingIndicator);
  chatBox.scrollTop = chatBox.scrollHeight;
}

async function sendMessage() {
  const text = chatInput.value.trim();
  if (!text) return;

  // Add user message to UI
  appendMessage('user', text);
  
  // Add to history
  chatHistory.push({ role: 'user', content: text });
  
  // Clear input
  chatInput.value = '';
  chatInput.style.height = 'auto';
  
  // Show loading state
  sendBtn.disabled = true;
  chatInput.disabled = true;
  typingIndicator.style.display = 'flex';
  chatBox.scrollTop = chatBox.scrollHeight;

  try {
    const res = await fetch('/api/ai/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: chatHistory })
    });

    const data = await res.json();

    if (!res.ok) {
      throw new Error(data.error || 'Serverda xatolik yuz berdi');
    }

    // Add AI response to UI
    appendMessage('assistant', data.reply);
    
    // Add to history
    chatHistory.push({ role: 'assistant', content: data.reply });

  } catch (err) {
    appendMessage('assistant', '<span style="color:var(--danger)">Xatolik yuz berdi: ' + err.message + '</span>');
  } finally {
    // Hide loading state
    sendBtn.disabled = false;
    chatInput.disabled = false;
    typingIndicator.style.display = 'none';
    chatInput.focus();
  }
}
</script>
<%- include('../layouts/footer') %>
