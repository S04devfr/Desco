<%- include('../layouts/header', {
  title: 'Xarajatlar — DESCO CRM',
  activePage: 'expenses',
  user: user}) %>

<div class="page-header">
  <div>
    <h1>Xarajatlar</h1>
    <p>Moliyaviy xarajatlar hisobi</p>
  </div>
  <div class="page-header-actions">
    <button class="btn btn-primary" onclick="openExpenseModal()">
      <i class="fas fa-plus"></i> Xarajat qo'shish
    </button>
  </div>
</div>

<style>
#expensesTable {
  border-collapse: collapse !important;
  width: 100%;
}
#expensesTable th {
  border: 1px solid var(--border-strong) !important;
  padding: 10px 12px !important;
  font-size: 11.5px !important;
  font-weight: 700 !important;
  text-transform: uppercase;
  background: var(--bg-tertiary) !important;
  color: var(--text-primary) !important;
}
#expensesTable td {
  border: 1px solid var(--border) !important;
  padding: 8px 12px !important;
  font-size: 13.5px !important;
  color: var(--text-800) !important;
  vertical-align: middle;
}
#expensesTable tbody tr:hover {
  background: var(--brand-soft) !important;
}
</style>

<!-- STATS -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:16px">
  <div class="stat-card">
    <div class="stat-icon red"><i class="fas fa-receipt"></i></div>
    <div class="stat-info">
      <div class="stat-label">Jami xarajat</div>
      <div class="stat-value" id="statTotal">—</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-calendar-alt"></i></div>
    <div class="stat-info">
      <div class="stat-label">Bu oyda</div>
      <div class="stat-value" id="statMonth">—</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue"><i class="fas fa-list"></i></div>
    <div class="stat-info">
      <div class="stat-label">Jami yozuvlar</div>
      <div class="stat-value" id="statCount">—</div>
    </div>
  </div>
</div>

<!-- FILTER -->
<div class="filter-bar">
  <div style="display:flex; align-items:center; gap:8px; font-size:13px; font-weight:600; color:var(--text-secondary); margin-right:8px;">
    <i class="fas fa-filter"></i> Filtrlash:
  </div>
  <select id="filterCategory" class="form-control" style="width:180px; font-size:13px;">
    <option value="">Barcha kategoriya</option>
    <option value="salary">Maosh</option>
    <option value="transport">Transport</option>
    <option value="office">Ofis</option>
    <option value="marketing">Marketing</option>
    <option value="other">Boshqa</option>
  </select>
  <div style="display:flex; align-items:center; gap:8px;">
    <input type="date" id="filterFrom" class="form-control" style="width:140px; font-size:13px;" title="Dan">
    <span style="color:var(--text-tertiary); font-size:12px;">—</span>
    <input type="date" id="filterTo" class="form-control" style="width:140px; font-size:13px;" title="Gacha">
  </div>
  <button class="btn btn-primary btn-sm" onclick="loadExpenses()" style="margin-left:auto;"><i class="fas fa-search"></i> Izlash</button>
  <button class="btn btn-secondary btn-sm" onclick="clearFilters()" title="Tozalash"><i class="fas fa-times"></i></button>
</div>

<!-- TABLE -->
<div class="table-responsive" style="overflow-x:auto;">
  <table class="table" id="expensesTable" style="width:100%;">
      <thead>
        <tr>
          <th style="width: 4%; text-align: center;">#</th>
          <th style="width: 40%;">Tavsif</th>
          <th style="width: 12%;">Kategoriya</th>
          <th style="width: 15%;">Summa</th>
          <th style="width: 12%;">Sana</th>
          <th style="width: 12%;">Qo'shgan</th>
          <th style="width: 5%; text-align: center;">Amallar</th>
        </tr>
      </thead>
      <tbody id="expensesBody">
        <tr><td colspan="7"><div style="padding:40px;text-align:center"><div class="spinner"></div></div></td></tr>
      </tbody>
  </table>
</div>

<!-- MODAL -->
<div class="modal-overlay hidden" id="expenseModal">
  <div class="modal-box">
    <div class="modal-header">
      <h2 id="expModalTitle">Yangi xarajat</h2>
      <button class="modal-close" onclick="closeExpenseModal()">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="expenseId">
      <div class="form-group">
        <label class="form-label">Tavsif *</label>
        <input type="text" id="e-description" class="form-control" placeholder="Xarajat tavsifi">
      </div>
      <div class="form-grid form-grid-2">
        <div class="form-group">
          <label class="form-label">Summa *</label>
          <input type="number" id="e-amount" class="form-control" placeholder="0" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">Kategoriya</label>
          <select id="e-category" class="form-control">
            <option value="other">Boshqa</option>
            <option value="salary">Maosh</option>
            <option value="transport">Transport</option>
            <option value="office">Ofis</option>
            <option value="marketing">Marketing</option>
          </select>
        </div>
        <div class="form-group" style="grid-column:1/-1">
          <label class="form-label">Sana</label>
          <input type="date" id="e-date" class="form-control">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeExpenseModal()">Bekor qilish</button>
      <button class="btn btn-primary" id="expSaveBtn" onclick="saveExpense()">
        <i class="fas fa-save"></i> Saqlash
      </button>
    </div>
  </div>
</div>

<script>
let allExpenses = [];
const catLabels = { salary:'Maosh', transport:'Transport', office:'Ofis', marketing:'Marketing', other:'Boshqa' };
const catColors = { salary:'badge-blue', transport:'badge-orange', office:'badge-purple', marketing:'badge-green', other:'badge-gray' };

window.allDealsData = [];

async function loadExpenses() {
  const cat = document.getElementById('filterCategory').value;
  const from = document.getElementById('filterFrom').value;
  const to = document.getElementById('filterTo').value;
  const params = new URLSearchParams();
  if (cat) params.set('category', cat);
  if (from) params.set('from', from);
  if (to) params.set('to', to);
  try {
    const fetchFn = (typeof fetchWithTimeout === 'function') ? fetchWithTimeout : fetch;
    const [expRes, dealsRes] = await Promise.all([
      fetchFn('/api/expenses?' + params),
      fetchFn('/api/deals')
    ]);

    const [expData, dealsData] = await Promise.all([
      expRes.json().catch(() => ({})),
      dealsRes.json().catch(() => ([]))
    ]);

    if (!expRes.ok) throw new Error(expData.message || 'Server xatosi: ' + expRes.status);
    
    allExpenses = Array.isArray(expData) ? expData : [];
    window.allDealsData = Array.isArray(dealsData) ? dealsData : [];

    renderExpenses();
    updateStats();
  } catch(e) {
    allExpenses = [];
    showToast("Ma'lumotlarni yuklashda xatolik" + (e && e.message && !e.isTimeout ? ': ' + e.message : ''), 'error');
    renderExpenses();
    updateStats();
  }
}

function updateStats() {
  const total = allExpenses.reduce((s, e) => s + e.amount, 0);
  document.getElementById('statTotal').textContent = fmtMoney(total);
  document.getElementById('statCount').textContent = allExpenses.length;
  const now = new Date();
  const monthTotal = allExpenses.filter(e => {
    const d = new Date(e.date||e.createdAt);
    return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
  }).reduce((s, e) => s + e.amount, 0);
  document.getElementById('statMonth').textContent = fmtMoney(monthTotal);
}

function renderExpenses() {
  const tbody = document.getElementById('expensesBody');
  if (!allExpenses.length) {
    tbody.innerHTML = `<tr><td colspan="7"><div style="padding:60px 20px;text-align:center;color:var(--text-tertiary);"><div style="font-size:40px;margin-bottom:12px;color:var(--border);"><i class="fas fa-receipt"></i></div><h3 style="font-size:16px;color:var(--text-secondary);margin:0;">Xarajatlar yo'q</h3><p style="font-size:13px;margin-top:6px;">Ushbu oraliqda hech qanday xarajat topilmadi.</p></div></td></tr>`;
    return;
  }
  tbody.innerHTML = allExpenses.map((e, i) => {
    let dealInfoHtml = '';
    const match = e.description.match(/#(\d+)/);
    if (match && window.allDealsData) {
      const dealId = Number(match[1]);
      const deal = window.allDealsData.find(d => d.id === dealId);
      if (deal) {
        dealInfoHtml = `
          <div style="font-size: 11px; margin-top: 5px; color: var(--accent); font-weight: 600; background: var(--accent)1A; padding: 2px 6px; border-radius: 4px; display: inline-flex; align-items: center; gap: 4px; flex-wrap: wrap;">
            <i class="fas fa-handshake"></i> Sdelka #${deal.id} &bull; ${escHtml(deal.productName)}
            ${deal.client ? ` &bull; 👤 ${escHtml(deal.client.name)}` : ''}
            ${deal.client?.phone ? ` &bull; 📞 <a href="tel:${escHtml(deal.client.phone)}" style="color:inherit; font-weight:700">${escHtml(deal.client.phone)}</a>` : ''}
            ${deal.client?.city ? ` &bull; 📍 ${escHtml(deal.client.city)}` : ''}
          </div>
        `;
      } else {
        dealInfoHtml = `
          <div style="font-size: 11px; margin-top: 5px; color: var(--text-tertiary); font-weight: 500;">
            <i class="fas fa-exclamation-circle"></i> Sdelka #${dealId} (Tizimda topilmadi)
          </div>
        `;
      }
    }

    return `
      <tr>
        <td style="text-align: center;">${i+1}</td>
        <td>
          <div style="font-weight:600; font-size: 13.5px; color: var(--text-primary);">${escHtml(e.description)}</div>
          ${dealInfoHtml}
        </td>
        <td><span class="badge ${catColors[e.category]||'badge-gray'}" style="font-size:11.5px; font-weight:700; padding:2px 6px; border-radius:4px;">${catLabels[e.category]||e.category}</span></td>
        <td style="font-weight:700; color:var(--danger)">${fmtMoney(e.amount)}</td>
        <td style="font-weight: 500;">${fmtDateShort(e.date||e.createdAt)}</td>
        <td>${e.createdBy ? escHtml(e.createdBy.fullName||e.createdBy.email) : '—'}</td>
        <td style="text-align:center;">
          <div style="display:flex; justify-content:center; gap:4px">
            <button class="btn btn-ghost btn-icon btn-sm" onclick="openExpenseModal(${e.id})" title="Tahrirlash" style="padding: 4px 6px; font-size: 12px;"><i class="fas fa-edit"></i></button>
            <button class="btn btn-ghost btn-icon btn-sm text-danger" onclick="deleteExpense(${e.id})" title="O'chirish" style="padding: 4px 6px; font-size: 12px;"><i class="fas fa-trash"></i></button>
          </div>
        </td>
      </tr>
    `;
  }).join('');
}

async function openExpenseModal(id) {
  document.getElementById('expenseId').value = id || '';
  document.getElementById('e-description').value = '';
  document.getElementById('e-amount').value = '';
  document.getElementById('e-category').value = 'other';
  document.getElementById('e-date').value = new Date().toISOString().slice(0,10);
  document.getElementById('expModalTitle').textContent = id ? 'Xarajatni tahrirlash' : 'Yangi xarajat';

  if (id) {
    try {
      const exp = allExpenses.find(e => e.id === id);
      if (exp) {
        document.getElementById('e-description').value = exp.description || '';
        document.getElementById('e-amount').value = exp.amount || '';
        document.getElementById('e-category').value = exp.category || 'other';
        document.getElementById('e-date').value = (exp.date||exp.createdAt||'').slice(0,10);
      }
    } catch(e) {}
  }
  document.getElementById('expenseModal').classList.remove('hidden');
}

function closeExpenseModal() {
  document.getElementById('expenseModal').classList.add('hidden');
}

async function saveExpense() {
  const id = document.getElementById('expenseId').value;
  const description = document.getElementById('e-description').value.trim();
  const amount = Number(document.getElementById('e-amount').value);
  if (!description) { showToast('Tavsif majburiy', 'error'); return; }
  if (!amount) { showToast('Summa majburiy', 'error'); return; }

  const btn = document.getElementById('expSaveBtn');
  btn.disabled = true;
  const body = { description, amount, category: document.getElementById('e-category').value, date: document.getElementById('e-date').value || null };

  try {
    const url = id ? '/api/expenses/' + id : '/api/expenses';
    const r = await fetch(url, { method: id ? 'PATCH' : 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    if (!r.ok) {
      let msg = 'Xatolik yuz berdi';
      try {
        const data = await r.json();
        msg = data.message || msg;
      } catch(je) {
        msg = `Xato: ${r.status} ${r.statusText}`;
      }
      throw new Error(msg);
    }
    showToast(id ? 'Yangilandi' : "Xarajat qo'shildi", 'success');
    closeExpenseModal();
    await loadExpenses();
  } catch(e) { showToast(e.message||'Xato', 'error'); }
  finally { btn.disabled = false; }
}

async function deleteExpense(id) {
  if (!confirm("O'chirishni tasdiqlaysizmi?")) return;
  try {
    const r = await fetch('/api/expenses/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    showToast("O'chirildi", 'success');
    await loadExpenses();
  } catch(e) { showToast("O'chirishda xato", 'error'); }
}

function clearFilters() {
  document.getElementById('filterCategory').value = '';
  document.getElementById('filterFrom').value = '';
  document.getElementById('filterTo').value = '';
  loadExpenses();
}

loadExpenses();
</script>
<%- include('../layouts/footer') %>
