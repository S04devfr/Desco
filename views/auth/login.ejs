<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kirish — DESCO CRM</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script>(function(){const t=localStorage.getItem('crm-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    :root{
      --brand:#4F46E5;--brand-hover:#4338CA;--brand-soft:rgba(79,70,229,0.08);
      --text-900:#0D0F1A;--text-700:#374151;--text-500:#6B7280;--text-300:#9CA3AF;
      --surface-card:#FFFFFF;--surface-input:#F0F1F5;
      --border:rgba(0,0,0,0.07);--border-strong:rgba(0,0,0,0.12);
      --danger:#DC2626;--danger-bg:#FEF2F2;--danger-border:#FECACA;
    }
    [data-theme="dark"]{
      --text-900:#F1F2F6;--text-700:#B8BCC8;--text-500:#7A7F8E;--text-300:#4A4F61;
      --surface-card:#151820;--surface-input:#1C1F2A;
      --border:rgba(255,255,255,0.07);--border-strong:rgba(255,255,255,0.12);
      --danger-bg:rgba(220,38,38,0.1);--danger-border:rgba(220,38,38,0.25);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;font-family:'Inter',-apple-system,sans-serif;-webkit-font-smoothing:antialiased}
    body{min-height:100vh;display:flex;color:var(--text-900);overflow:hidden;transition:background .3s,color .3s}

    /* Left brand panel */
    .auth-left{
      width:44%;background:linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
      display:flex;flex-direction:column;justify-content:space-between;
      padding:48px;position:relative;overflow:hidden;flex-shrink:0;
    }
    .auth-left::before{
      content:'';position:absolute;width:500px;height:500px;
      background:radial-gradient(circle,rgba(79,70,229,0.35) 0%,transparent 70%);
      top:-100px;right:-100px;pointer-events:none;
    }
    .auth-left::after{
      content:'';position:absolute;width:350px;height:350px;
      background:radial-gradient(circle,rgba(99,102,241,0.2) 0%,transparent 70%);
      bottom:-80px;left:-80px;pointer-events:none;
    }
    .left-logo{display:flex;align-items:center;gap:12px;position:relative;z-index:1;}
    .left-logo-icon{
      width:40px;height:40px;background:rgba(255,255,255,0.1);
      border:1px solid rgba(255,255,255,0.15);border-radius:12px;
      display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px;
    }
    .left-logo-text{font-size:20px;font-weight:700;color:#fff;letter-spacing:-0.5px;}
    .left-logo-text span{color:rgba(255,255,255,0.4);}
    .left-content{position:relative;z-index:1;flex:1;display:flex;flex-direction:column;justify-content:center;padding:40px 0;}
    .left-tagline{font-size:30px;font-weight:700;color:#fff;line-height:1.3;letter-spacing:-1px;margin-bottom:16px;}
    .left-tagline span{color:rgba(165,180,252,0.9);}
    .left-desc{font-size:14px;color:rgba(255,255,255,0.48);line-height:1.7;max-width:360px;}
    .left-features{display:flex;flex-direction:column;gap:14px;margin-top:32px;}
    .left-feature{display:flex;align-items:center;gap:12px;color:rgba(255,255,255,0.6);font-size:13.5px;}
    .left-feature-icon{
      width:28px;height:28px;background:rgba(255,255,255,0.08);border-radius:8px;
      display:flex;align-items:center;justify-content:center;
      color:rgba(165,180,252,0.9);font-size:12px;flex-shrink:0;
    }
    .left-footer{position:relative;z-index:1;font-size:12px;color:rgba(255,255,255,0.22);}

    /* Right form panel */
    .auth-right{
      flex:1;display:flex;align-items:center;justify-content:center;
      padding:48px 40px;background:var(--surface-card);position:relative;
    }
    .auth-form-wrap{width:100%;max-width:380px;animation:formIn .5s cubic-bezier(.16,1,.3,1) both;}
    @keyframes formIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

    .form-top{margin-bottom:32px;}
    .form-title{font-size:24px;font-weight:700;color:var(--text-900);letter-spacing:-0.6px;margin-bottom:8px;}
    .form-subtitle{font-size:14px;color:var(--text-500);line-height:1.6;}

    .error-box{
      background:var(--danger-bg);color:var(--danger);
      padding:12px 14px;border-radius:12px;font-size:13.5px;
      margin-bottom:20px;display:none;border:1px solid var(--danger-border);
      font-weight:500;align-items:center;gap:10px;
    }
    .error-box.show{display:flex;}

    .field{margin-bottom:18px;}
    .field label{display:block;font-size:13px;font-weight:500;color:var(--text-700);margin-bottom:6px;}
    .field-inner{position:relative;}
    .field-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-300);font-size:14px;pointer-events:none;}

    .field input{
      width:100%;padding:11px 14px 11px 38px;
      background:var(--surface-input);border:1px solid var(--border);border-radius:12px;
      font-size:14px;color:var(--text-900);font-family:'Inter',sans-serif;outline:none;
      transition:border-color .15s,box-shadow .15s,background .15s;
    }
    .field input::placeholder{color:var(--text-300);}
    .field input:focus{border-color:var(--brand);background:var(--surface-card);box-shadow:0 0 0 3px var(--brand-soft);}

    .pw-toggle{
      position:absolute;right:12px;top:50%;transform:translateY(-50%);
      background:none;border:none;color:var(--text-300);cursor:pointer;font-size:14px;padding:4px;
      transition:color .15s;
    }
    .pw-toggle:hover{color:var(--text-500);}

    .submit-btn{
      width:100%;padding:13px;background:var(--brand);color:#fff;border:none;border-radius:12px;
      font-size:15px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;
      display:flex;align-items:center;justify-content:center;gap:8px;
      transition:background .15s,transform .15s,box-shadow .15s;
      box-shadow:0 4px 14px rgba(79,70,229,0.3);margin-top:8px;
    }
    .submit-btn:hover{background:var(--brand-hover);transform:translateY(-1px);box-shadow:0 8px 20px rgba(79,70,229,0.35);}
    .submit-btn:active{transform:scale(0.98);}
    .submit-btn:disabled{opacity:.55;cursor:not-allowed;transform:none!important;}

    .spinner{
      width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);
      border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite;display:inline-block;
    }
    @keyframes spin{to{transform:rotate(360deg)}}

    .form-links{margin-top:28px;text-align:center;font-size:13px;color:var(--text-500);}
    .form-links a{color:var(--brand);text-decoration:none;font-weight:500;transition:opacity .15s;}
    .form-links a:hover{opacity:.75;}
    .form-links-row{display:flex;justify-content:center;gap:20px;margin-top:8px;}

    .theme-toggle{
      position:absolute;top:20px;right:20px;width:36px;height:36px;
      background:var(--surface-input);border:1px solid var(--border);border-radius:8px;
      color:var(--text-500);display:flex;align-items:center;justify-content:center;
      cursor:pointer;font-size:14px;transition:background .15s,color .15s;
    }
    .theme-toggle:hover{color:var(--text-900);}

    @media(max-width:900px){.auth-left{display:none}.auth-right{padding:32px 24px;}}
    @media(max-width:480px){.auth-right{padding:24px 16px}.auth-form-wrap{max-width:100%;}}
  </style>
  <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
</head>
<body>

<div class="auth-left">
  <div id="particles-js" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;"></div>
  <div class="left-logo">
    <div class="left-logo-icon"><i class="fas fa-layer-group"></i></div>
    <div class="left-logo-text">Desco<span>.crm</span></div>
  </div>

  <div class="left-content">
    <div class="left-tagline">
      Biznes boshqaruvini<br>
      <span>yangi darajaga</span><br>
      olib chiqing
    </div>
    <p class="left-desc">Sdelkalar, mijozlar, moliya va omborni — barchasini bir tizimda, real vaqtda boshqaring.</p>
    <div class="left-features">
      <div class="left-feature"><div class="left-feature-icon"><i class="fas fa-chart-line"></i></div><span>Real vaqtdagi tahlil va hisobotlar</span></div>
      <div class="left-feature"><div class="left-feature-icon"><i class="fas fa-handshake"></i></div><span>Sdelkalar va nasiya boshqaruvi</span></div>
      <div class="left-feature"><div class="left-feature-icon"><i class="fas fa-warehouse"></i></div><span>Ombor va mahsulot nazorati</span></div>
      <div class="left-feature"><div class="left-feature-icon"><i class="fab fa-instagram"></i></div><span>Instagram lead integratsiyasi</span></div>
    </div>
  </div>

  <div class="left-footer">&copy; 2024 Desco CRM. Barcha huquqlar himoyalangan.</div>
</div>

<div class="auth-right">
  <button class="theme-toggle" onclick="toggleTheme()" title="Mavzuni o'zgartirish">
    <i class="fas fa-moon" id="themeIcon"></i>
  </button>

  <div class="auth-form-wrap">
    <div class="form-top">
      <h1 class="form-title">Xush kelibsiz</h1>
      <p class="form-subtitle">Davom etish uchun hisobingizga kiring</p>
    </div>

    <div class="error-box" id="errorBox">
      <i class="fas fa-exclamation-circle"></i>
      <span id="errorText"></span>
    </div>

    <form id="loginForm" novalidate>
      <div class="field">
        <label for="email">Email manzil</label>
        <div class="field-inner">
          <i class="fas fa-envelope field-icon"></i>
          <input type="email" id="email" name="email" placeholder="email@example.com" required autofocus autocomplete="username">
        </div>
      </div>

      <div class="field">
        <label for="password">Parol</label>
        <div class="field-inner">
          <i class="fas fa-lock field-icon"></i>
          <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
          <button type="button" class="pw-toggle" onclick="togglePw()" tabindex="-1">
            <i class="fas fa-eye" id="pwIcon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="submit-btn" id="loginBtn">
        <i class="fas fa-right-to-bracket"></i>
        <span id="btnText">Kirish</span>
      </button>
    </form>

    <div class="form-links">
      <span>Muammo? Bog'laning:</span>
      <div class="form-links-row">
        <a href="mailto:muhammedaminov169@gmail.com"><i class="fas fa-envelope"></i> Email</a>
        <a href="https://t.me/useraminov" target="_blank" rel="noopener noreferrer"><i class="fab fa-telegram"></i> Telegram</a>
      </div>
    </div>
  </div>
</div>

<script>
function applyTheme(t){
  document.documentElement.setAttribute('data-theme',t);
  localStorage.setItem('crm-theme',t);
  const icon=document.getElementById('themeIcon');
  if(icon) icon.className=t==='dark'?'fas fa-sun':'fas fa-moon';
}
function toggleTheme(){
  const cur=document.documentElement.getAttribute('data-theme')||'light';
  applyTheme(cur==='dark'?'light':'dark');
}
applyTheme(localStorage.getItem('crm-theme')||'light');

function togglePw(){
  const inp=document.getElementById('password');
  const icon=document.getElementById('pwIcon');
  if(inp.type==='password'){inp.type='text';icon.className='fas fa-eye-slash';}
  else{inp.type='password';icon.className='fas fa-eye';}
}

const params=new URLSearchParams(window.location.search);
const msg=params.get('msg');
if(msg) showError(msg);

function showError(text){
  document.getElementById('errorText').textContent=text;
  document.getElementById('errorBox').classList.add('show');
}
function hideError(){document.getElementById('errorBox').classList.remove('show');}

if(typeof particlesJS !== 'undefined') {
  particlesJS("particles-js", {
    "particles": {
      "number": { "value": 70, "density": { "enable": true, "value_area": 800 } },
      "color": { "value": "#ffffff" },
      "shape": { "type": "circle", "stroke": { "width": 0, "color": "#000000" }, "polygon": { "nb_sides": 5 } },
      "opacity": { "value": 0.6, "random": false, "anim": { "enable": false, "speed": 1, "opacity_min": 0.1, "sync": false } },
      "size": { "value": 3, "random": true, "anim": { "enable": false, "speed": 40, "size_min": 0.1, "sync": false } },
      "line_linked": { "enable": true, "distance": 150, "color": "#ffffff", "opacity": 0.5, "width": 1 },
      "move": { "enable": true, "speed": 3, "direction": "none", "random": false, "straight": false, "out_mode": "out", "bounce": false, "attract": { "enable": false, "rotateX": 600, "rotateY": 1200 } }
    },
    "interactivity": {
      "detect_on": "canvas",
      "events": {
        "onhover": { "enable": true, "mode": "grab" },
        "onclick": { "enable": true, "mode": "push" },
        "resize": true
      },
      "modes": {
        "grab": { "distance": 140, "line_linked": { "opacity": 1 } },
        "bubble": { "distance": 400, "size": 40, "duration": 2, "opacity": 8, "speed": 3 },
        "repulse": { "distance": 200, "duration": 0.4 },
        "push": { "particles_nb": 4 },
        "remove": { "particles_nb": 2 }
      }
    },
    "retina_detect": true
  });
}

document.getElementById('loginForm').addEventListener('submit',async(e)=>{
  e.preventDefault();
  hideError();
  const email=document.getElementById('email').value.trim();
  const password=document.getElementById('password').value;
  const btn=document.getElementById('loginBtn');
  const btnText=document.getElementById('btnText');
  if(!email||!password){showError("Email va parolni kiriting");return;}
  btn.disabled=true;
  btnText.innerHTML='<span class="spinner"></span> Kirilmoqda...';
  try{
    const res=await fetch('/api/auth/login',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({email,password})
    });
    const data=await res.json();
    if(!res.ok){
      showError(data.message||"Email yoki parol noto'g'ri");
      btn.disabled=false;
      btnText.innerHTML='<i class="fas fa-right-to-bracket"></i> Kirish';
      return;
    }
    window.location.href='/';
  }catch{
    showError("Server bilan bog'lanishda xatolik yuz berdi");
    btn.disabled=false;
    btnText.innerHTML='<i class="fas fa-right-to-bracket"></i> Kirish';
  }
});
</script>
</body>
</html>
