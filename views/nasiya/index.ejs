<%- include('../layouts/header', {
  title: "Nasiya Bo'limi — DESCO CRM",
  activePage: 'nasiya-' + subPage,
  user: user}) %>

<div class="page-header">
  <div>
    <h1 id="nasiyaTitle">Nasiya</h1>
    <p>Sdelka voronkasidan kelgan nasiya to'lovlari ro'yxati</p>
  </div>
  <div class="page-header-actions">
    <button class="btn btn-secondary btn-sm" onclick="loadNasiyaDeals()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
  </div>
</div>

<div class="card">
  <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
    <h3 id="tableHeader">Mijozlar to'lovlari</h3>
    <span id="dealCount" class="badge badge-blue">0</span>
  </div>
  <div class="table-wrap">
    <table class="deals-tbl" style="width:100%">
      <thead>
        <tr>
          <th>ID</th>
          <th>Mahsulot</th>
          <th>Mijoz</th>
          <th>Telefon</th>
          <th>To'liq Summa</th>
          <th>Qancha Berdi</th>
          <th>Qancha Qoldi (Qarz)</th>
          <th>Izoh</th>
          <th>Yangilangan Vaqt</th>
          <th style="width:80px">Amallar</th>
        </tr>
      </thead>
      <tbody id="nasiyaTableBody">
        <tr>
          <td colspan="10" style="text-align:center; padding:40px;">
            <div class="spinner" style="margin:auto"></div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
const activeStageKey = '<%= subPage %>';
const titlesMap = {
  'shopir': 'Shopirdagi pul',
  'desco': 'Nasiya Desco',
  'ishonch': 'Nasiya Ishonch',
  'baraka': 'Nasiya Baraka'
};

document.getElementById('nasiyaTitle').textContent = titlesMap[activeStageKey] || 'Nasiya';
document.getElementById('tableHeader').textContent = (titlesMap[activeStageKey] || 'Nasiya') + ' ro\'yxati';

async function loadNasiyaDeals() {
  try {
    const tbody = document.getElementById('nasiyaTableBody');
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center; padding:40px;"><div class="spinner" style="margin:auto"></div></td></tr>';

    const r = await fetch('/api/nasiya/list-deals?stage=' + activeStageKey);
    const deals = await r.json();
    
    if (!r.ok) throw new Error(deals.message || 'Xatolik');

    document.getElementById('dealCount').textContent = deals.length;

    if (!deals.length) {
      tbody.innerHTML = '<tr><td colspan="10" style="text-align:center; padding:40px; color:var(--text-tertiary)"><i class="fas fa-wallet" style="font-size:28px; display:block; margin-bottom:8px;"></i>Bu bosqichda sdelkalar yo\'q</td></tr>';
      return;
    }

    tbody.innerHTML = deals.map(d => {
      const qolgan = Math.max(0, (d.amount || 0) - (d.paidAmount || 0));
      const formattedDate = new Date(d.updatedAt).toLocaleDateString('uz-UZ', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });

      return `
        <tr>
          <td style="color:var(--text-tertiary); font-size:12px;">#${d.id}</td>
          <td><strong>${escHtml(d.productName)}</strong></td>
          <td>${d.client ? escHtml(d.client.name) : '<span style="color:var(--text-tertiary)">—</span>'}</td>
          <td>${d.client && d.client.phone ? escHtml(d.client.phone) : '—'}</td>
          <td style="font-weight:700;">${fmtMoney(d.amount)}</td>
          <td style="color:var(--success); font-weight:600;">${fmtMoney(d.paidAmount)}</td>
          <td style="color:var(--danger); font-weight:700;">${fmtMoney(qolgan)}</td>
          <td style="font-size:12px; color:var(--text-secondary); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${escHtml(d.notes || '')}">${escHtml(d.notes || '—')}</td>
          <td style="font-size:12px; color:var(--text-tertiary);">${formattedDate}</td>
          <td>
            <div style="display:flex; gap:4px">
              <a href="/deals?openDealId=${d.id}" class="btn btn-ghost btn-icon btn-sm" title="Sdelkani ko\'rish">
                <i class="fas fa-eye" style="color:var(--accent)"></i>
              </a>
            </div>
          </td>
        </tr>
      `;
    }).join('');
  } catch(e) {
    document.getElementById('nasiyaTableBody').innerHTML = '<tr><td colspan="10" style="text-align:center; padding:40px; color:var(--danger)"><i class="fas fa-exclamation-triangle" style="font-size:28px; display:block; margin-bottom:8px;"></i>Yuklashda xato: ' + escHtml(e.message) + '</td></tr>';
  }
}

function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function fmtMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + " so'm";
}

document.addEventListener('DOMContentLoaded', loadNasiyaDeals);
</script>
<%- include('../layouts/footer') %>
