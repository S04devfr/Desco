<%- include('../layouts/header', {
  title: "Nasiya Bo'limi — DESCO CRM",
  activePage: 'nasiya-' + subPage,
  user: user}) %>

<div class="page-header">
  <div>
    <h1 id="nasiyaTitle">Nasiya</h1>
    <p id="nasiyaSubtitle">Sdelka voronkasidan kelgan nasiya to'lovlari ro'yxati</p>
  </div>
  <div class="page-header-actions">
    <button class="btn btn-secondary btn-sm" onclick="loadNasiyaDeals()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
  </div>
</div>

<div class="card">
  <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
    <h3 id="tableHeader" style="margin:0; font-size:15px; font-weight:600;"></h3>
    <span id="dealCount" class="badge badge-blue">0</span>
  </div>
  <div style="overflow-x:auto;">
    <table class="deals-tbl" id="nasiyaTable" style="width:100%; border-collapse:collapse;">
      <thead id="nasiyaThead"></thead>
      <tbody id="nasiyaTableBody">
        <tr><td colspan="8" style="text-align:center; padding:40px;">
          <div class="spinner" style="margin:auto"></div>
        </td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ── Nasiya Desco: Muddatli to'lov modal ── -->
<div id="nasiyaDescoModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)closeDescoModal()">
  <div class="modal-dialog" style="max-width:620px;">
    <div class="modal-header">
      <h3 class="modal-title"><i class="fas fa-calendar-alt" style="color:var(--brand)"></i> Nasiya Desco — Muddatli to'lov</h3>
      <button class="modal-close" onclick="closeDescoModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" style="padding:20px; display:flex; flex-direction:column; gap:14px;">
      <input type="hidden" id="descoModalDealId">

      <!-- Mijoz info strip -->
      <div id="descoClientInfo" style="background:var(--surface-input); border:1px solid var(--border); border-radius:10px; padding:12px 16px; display:flex; flex-direction:column; gap:4px;">
        <div style="font-weight:600; font-size:14px;" id="descoClientName">—</div>
        <div style="font-size:12px; color:var(--text-500);" id="descoClientPhone">—</div>
        <div style="font-size:12px; color:var(--text-500);">
          Mahsulot: <span id="descoProduct" style="font-weight:500; color:var(--text-700)">—</span> &nbsp;|&nbsp;
          Jami summa: <span id="descoTotal" style="font-weight:600; color:var(--brand)">—</span>
        </div>
      </div>

      <!-- Quick action: auto-generate plan -->
      <div style="background:var(--bg-tertiary); padding:10px; border-radius:8px; display:flex; justify-content:space-between; align-items:center; gap:8px;">
        <span style="font-size:11.5px; color:var(--text-secondary); font-weight:500;">
          <i class="fas fa-magic" style="color:var(--accent); margin-right:4px;"></i> Avto-Bo'lib to'lash plani
        </span>
        <div style="display:flex; gap:6px;">
          <button class="btn btn-sm btn-ghost" onclick="autoGenerateDescoInstallments(3)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">3 oy</button>
          <button class="btn btn-sm btn-ghost" onclick="autoGenerateDescoInstallments(6)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">6 oy</button>
          <button class="btn btn-sm btn-ghost" onclick="autoGenerateDescoInstallments(12)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">12 oy</button>
        </div>
      </div>

      <!-- Installments rows -->
      <div style="font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary); margin-bottom:2px; margin-top:8px;">To'lov jadvali</div>
      <div id="descoInstRowsContainer" style="display:flex; flex-direction:column; gap:6px; max-height:220px; overflow-y:auto; margin-bottom:12px; padding-right:4px;"></div>
      
      <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border); padding-top:12px;">
        <button class="btn btn-sm btn-ghost" onclick="addDescoInstallmentRow()" style="border:1px dashed var(--border); font-size:12px;">
          <i class="fas fa-plus"></i> To'lov qo'shish
        </button>
        <div style="display:flex; gap:8px;">
          <button class="btn btn-sm btn-danger" onclick="deleteDescoInstallmentPlan()" style="font-size:12px;">
            <i class="fas fa-trash-alt"></i> Planni O'chirish
          </button>
          <button class="btn btn-sm btn-primary" onclick="saveDescoInstallmentPlan()" id="descoSaveBtn">
            <i class="fas fa-save"></i> Planni Saqlash
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.nasiya-client-cell { display:flex; flex-direction:column; gap:2px; padding:8px 10px; }
.nasiya-client-name { font-weight:600; font-size:13px; color:var(--text-primary); }
.nasiya-client-phone { font-size:11px; color:var(--brand); }
.nasiya-client-city  { font-size:11px; color:var(--text-500); }
.inst-badge { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:20px; font-size:11px; font-weight:600; }
.inst-badge.paid   { background:rgba(52,199,89,0.12); color:#34C759; }
.inst-badge.unpaid { background:rgba(255,59,48,0.12);  color:#FF3B30; }
.inst-progress { height:4px; border-radius:2px; background:var(--surface-input); overflow:hidden; margin-top:4px; }
.inst-progress-bar { height:100%; background:var(--brand); border-radius:2px; transition:width .3s; }
</style>

<script>
const activeStageKey = '<%= subPage %>';
const titlesMap = {
  'desco':   'Nasiya Desco',
  'ishonch': 'Nasiya Ishonch',
  'baraka':  'Nasiya Baraka'
};

const isDescoStage = activeStageKey === 'desco';

document.getElementById('nasiyaTitle').textContent = titlesMap[activeStageKey] || 'Nasiya';
document.getElementById('tableHeader').textContent = (titlesMap[activeStageKey] || 'Nasiya') + ' jadvali';
document.getElementById('nasiyaSubtitle').textContent = isDescoStage
  ? 'Muddatli to\'lov jadvali bilan boshqariladigan nasiyalar'
  : 'Mijoz ma\'lumotlari va to\'lov holati';

// Thead columns by stage
function buildThead() {
  const thead = document.getElementById('nasiyaThead');
  if (isDescoStage) {
    thead.innerHTML = `<tr style="background:var(--bg-secondary)">
      <th style="width:20%">Mijoz</th>
      <th style="width:16%">Mahsulot</th>
      <th style="width:10%">Jami</th>
      <th style="width:10%">Oylar</th>
      <th style="width:12%">Oylik</th>
      <th style="width:12%">To'langan</th>
      <th style="width:10%">Holat</th>
      <th style="width:10%; text-align:center">Amal</th>
    </tr>`;
  } else {
    thead.innerHTML = `<tr style="background:var(--bg-secondary)">
      <th style="width:22%">Mijoz</th>
      <th style="width:18%">Mahsulot</th>
      <th style="width:12%">Summa</th>
      <th style="width:14%">Menejer</th>
      <th style="width:10%">Sana</th>
      <th style="width:14%">Izoh</th>
      <th style="width:10%; text-align:center">Amal</th>
    </tr>`;
  }
}
buildThead();

function fmtMoney(n) {
  if (!n) return '0';
  return Number(n).toLocaleString('uz-UZ') + ' so\'m';
}
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('uz-UZ', { day:'2-digit', month:'2-digit', year:'2-digit' });
}
function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function loadNasiyaDeals() {
  const tbody = document.getElementById('nasiyaTableBody');
  const cols = isDescoStage ? 8 : 7;
  tbody.innerHTML = `<tr><td colspan="${cols}" style="text-align:center;padding:40px;"><div class="spinner" style="margin:auto"></div></td></tr>`;

  try {
    const r = await fetch('/api/nasiya/list-deals?stage=' + activeStageKey);
    if (!r.ok) throw new Error();
    const deals = await r.json();

    document.getElementById('dealCount').textContent = deals.length + ' ta';

    if (!deals.length) {
      tbody.innerHTML = `<tr><td colspan="${cols}" style="text-align:center;padding:40px;color:var(--text-500)">
        <i class="fas fa-wallet" style="font-size:28px;display:block;margin-bottom:8px;opacity:.3"></i>
        Hozircha hech narsa yo'q</td></tr>`;
      return;
    }

    let html = '';
    for (const d of deals) {
      const client = d.client || {};
      const clientCell = `<div class="nasiya-client-cell">
        <div class="nasiya-client-name">${escHtml(client.name || "Noma'lum")}</div>
        <div class="nasiya-client-phone">${escHtml(client.phone || '—')}</div>
        <div class="nasiya-client-city">${escHtml(client.city || '')}</div>
      </div>`;

      if (isDescoStage) {
        // Installment progress
        const insts = d.installments || [];
        const totalMonths = insts.length;
        const paidCount = insts.filter(i => i.paid).length;
        const paidAmt = insts.filter(i => i.paid).reduce((s, i) => s + (i.amount || 0), 0);
        const monthly = insts[0]?.amount || 0;
        const pct = totalMonths ? Math.round(paidCount / totalMonths * 100) : 0;
        const badge = paidCount === totalMonths && totalMonths > 0
          ? `<span class="inst-badge paid"><i class="fas fa-check"></i> Yopilgan</span>`
          : `<span class="inst-badge unpaid">${paidCount}/${totalMonths} oy</span>`;

        html += `<tr style="border-bottom:1px solid var(--border-light);">
          <td style="border:1px solid var(--border-light);">${clientCell}</td>
          <td style="padding:8px 10px; font-size:13px;">${escHtml(d.productName)}</td>
          <td style="padding:8px 10px; font-size:12px; font-weight:600; color:var(--brand);">${fmtMoney(d.amount)}</td>
          <td style="padding:8px 10px; font-size:13px; text-align:center;">${totalMonths || '—'} oy</td>
          <td style="padding:8px 10px; font-size:12px; font-weight:600;">${fmtMoney(monthly)}</td>
          <td style="padding:8px 10px;">
            <div style="font-size:12px; color:var(--text-500);">${fmtMoney(paidAmt)}</div>
            <div class="inst-progress"><div class="inst-progress-bar" style="width:${pct}%"></div></div>
          </td>
          <td style="padding:8px 10px; text-align:center;">${badge}</td>
          <td style="padding:8px 10px; text-align:center;">
            <div style="display:flex;justify-content:center;gap:4px;">
              <button class="btn btn-sm btn-primary" onclick="openDescoEdit(${d.id})" title="Tahrirlash"><i class="fas fa-edit"></i></button>
              <button class="btn btn-sm btn-ghost text-danger" onclick="deleteNasiya(${d.id})" title="O'chirish"><i class="fas fa-trash"></i></button>
            </div>
          </td>
        </tr>`;
      } else {
        html += `<tr style="border-bottom:1px solid var(--border-light);">
          <td style="border:1px solid var(--border-light);">${clientCell}</td>
          <td style="padding:8px 10px; font-size:13px;">${escHtml(d.productName)}</td>
          <td style="padding:8px 10px; font-size:12px; font-weight:600; color:var(--brand);">${fmtMoney(d.amount)}</td>
          <td style="padding:8px 10px; font-size:12px; color:var(--text-500);">${escHtml(d.manager?.fullName || '—')}</td>
          <td style="padding:8px 10px; font-size:11px; color:var(--text-500);">${fmtDate(d.createdAt)}</td>
          <td style="padding:8px 10px; font-size:12px; color:var(--text-500);">${escHtml(d.notes || '—')}</td>
          <td style="padding:8px 10px; text-align:center;">
            <button class="btn btn-sm btn-ghost text-danger" onclick="deleteNasiya(${d.id})" title="O'chirish"><i class="fas fa-trash"></i></button>
          </td>
        </tr>`;
      }
    }
    tbody.innerHTML = html;
  } catch(e) {
    document.getElementById('dealCount').textContent = '0 ta';
    tbody.innerHTML = `<tr><td colspan="${isDescoStage ? 8 : 7}" style="text-align:center;padding:40px;color:var(--text-500)">Yuklanishda xato</td></tr>`;
  }
}

async function deleteNasiya(dealId) {
  if (!confirm("O'chirishni tasdiqlaysizmi?")) return;
  try {
    const r = await fetch('/api/deals/' + dealId, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast("O'chirildi", 'success');
    loadNasiyaDeals();
  } catch(e) {
    if (typeof showToast === 'function') showToast("O'chirishda xatolik", 'error');
  }
}

// ── Nasiya Desco Modal ────────────────────────────────────────
let _descoCurrentDeal = null;

async function openDescoEdit(dealId) {
  try {
    const r = await fetch('/api/deals/' + dealId);
    const d = await r.json();
    openDescoModal(d);
  } catch(e) {}
}

async function openDescoModal(deal) {
  _descoCurrentDeal = deal;
  document.getElementById('descoModalDealId').value = deal.id;
  document.getElementById('descoClientName').textContent = deal.client?.name || "Noma'lum mijoz";
  document.getElementById('descoClientPhone').textContent = deal.client?.phone || '—';
  document.getElementById('descoProduct').textContent = deal.productName || '—';
  document.getElementById('descoTotal').textContent = fmtMoney(deal.amount);

  const remainingDebt = deal.amount - deal.paidAmount;
  const container = document.getElementById('descoInstRowsContainer');
  container.innerHTML = '<div>Yuklanmoqda...</div>';

  try {
    const r = await fetch('/api/deals/' + deal.id + '/installments');
    const list = await r.json();
    if (list && list.length) {
      container.innerHTML = list.map((inst, idx) => getDescoInstallmentRowHtml(idx, inst.dueDate.slice(0, 10), inst.amount, inst.paid, inst.productName, inst.month, inst.notes)).join('');
    } else {
      container.innerHTML = getDescoInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false, deal.productName, '1-oy', '');
    }
  } catch(e) {
    container.innerHTML = getDescoInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false, deal.productName, '1-oy', '');
  }

  document.getElementById('nasiyaDescoModal').style.display = 'flex';
}

function closeDescoModal() {
  document.getElementById('nasiyaDescoModal').style.display = 'none';
  _descoCurrentDeal = null;
}

function getDescoInstallmentRowHtml(index, dateVal, amountVal, paidVal, productVal, monthVal, notesVal) {
  return `
    <div class="installment-row" style="display:flex; align-items:center; gap:6px; background:var(--surface-input); border:1px solid var(--border); padding:6px 8px; border-radius:6px; margin-bottom:4px;">
      <span style="font-size:12px; color:var(--text-500); width:16px; font-weight:600;">#${index + 1}</span>
      <input type="text" class="form-control inst-product" value="${escHtml(productVal || '')}" style="width:120px; height:28px; font-size:12px; padding:0 6px;" placeholder="Mahsulot">
      <input type="text" class="form-control inst-month" value="${escHtml(monthVal || '')}" style="width:65px; height:28px; font-size:12px; padding:0 6px;" placeholder="Oy">
      <input type="date" class="form-control inst-date" value="${dateVal}" style="width:115px; height:28px; font-size:12px; padding:0 6px;">
      <input type="number" class="form-control inst-amount" value="${amountVal}" style="width:85px; height:28px; font-size:12px; padding:0 6px; font-weight:600;" placeholder="Summa">
      <input type="text" class="form-control inst-notes" value="${escHtml(notesVal || '')}" style="flex:1; height:28px; font-size:12px; padding:0 6px;" placeholder="Izoh">
      
      <label style="display:inline-flex; align-items:center; gap:4px; font-size:11.5px; color:var(--text-500); cursor:pointer; margin:0 4px; user-select:none; white-space:nowrap;">
        <input type="checkbox" class="inst-paid" ${paidVal ? 'checked' : ''} style="cursor:pointer;"> To'landi
      </label>
      
      <button class="btn btn-ghost btn-sm text-danger" onclick="this.parentElement.remove()" style="padding:2px 6px; font-size:11px;" title="Qatorni o'chirish">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  `;
}

function addDescoInstallmentRow() {
  const container = document.getElementById('descoInstRowsContainer');
  const index = container.querySelectorAll('.installment-row').length;
  
  const lastRowDate = container.querySelector('.installment-row:last-child .inst-date');
  const lastProduct = container.querySelector('.installment-row:last-child .inst-product');
  let dateStr = new Date().toISOString().slice(0,10);
  let pName = lastProduct ? lastProduct.value : (_descoCurrentDeal?.productName || '');
  
  if (lastRowDate && lastRowDate.value) {
    const d = new Date(lastRowDate.value);
    d.setMonth(d.getMonth() + 1);
    dateStr = d.toISOString().slice(0,10);
  }

  const div = document.createElement('div');
  div.innerHTML = getDescoInstallmentRowHtml(index, dateStr, 0, false, pName, `${index+1}-oy`, '');
  container.appendChild(div.firstElementChild);
}

function autoGenerateDescoInstallments(months) {
  if (!_descoCurrentDeal) return;
  const remaining = _descoCurrentDeal.amount - _descoCurrentDeal.paidAmount;
  const eachVal = Math.round(remaining / months);

  const container = document.getElementById('descoInstRowsContainer');
  container.innerHTML = '';
  
  for (let i = 0; i < months; i++) {
    const d = new Date();
    d.setMonth(d.getMonth() + i);
    const dateStr = d.toISOString().slice(0, 10);
    const amount = (i === months - 1) ? (remaining - (eachVal * (months - 1))) : eachVal;
    
    container.innerHTML += getDescoInstallmentRowHtml(i, dateStr, amount, false, _descoCurrentDeal.productName, `${i+1}-oy`, '');
  }
}

async function saveDescoInstallmentPlan() {
  const btn = document.getElementById('descoSaveBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saqlanmoqda...';
  
  const container = document.getElementById('descoInstRowsContainer');
  const rows = container.querySelectorAll('.installment-row');
  const installments = [];
  
  for (const row of rows) {
    const dueDate = row.querySelector('.inst-date').value;
    const amount = Number(row.querySelector('.inst-amount').value) || 0;
    const paid = row.querySelector('.inst-paid').checked;
    const productName = row.querySelector('.inst-product').value;
    const month = row.querySelector('.inst-month').value;
    const notes = row.querySelector('.inst-notes').value;
    
    if (!dueDate) {
      if (typeof showToast === 'function') showToast('Sana kiritilishi majburiy', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save"></i> Planni Saqlash';
      return;
    }
    installments.push({ dueDate, amount, paid, productName, month, notes });
  }

  try {
    const r = await fetch('/api/deals/' + _descoCurrentDeal.id + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('To\'lov plani saqlandi', 'success');
    closeDescoModal();
    loadNasiyaDeals();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xatolik', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-save"></i> Planni Saqlash';
  }
}

async function deleteDescoInstallmentPlan() {
  if (!confirm("Haqiqatan ham ushbu nasiya to'lov rejasini o'chirmoqchimisiz? (Bu barcha rejalashtirilgan oylik to'lovlarni o'chiradi)")) return;
  
  try {
    const r = await fetch('/api/deals/' + _descoCurrentDeal.id + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments: [] })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('Nasiya rejasi o\'chirildi', 'success');
    closeDescoModal();
    loadNasiyaDeals();
  } catch(e) {
    if (typeof showToast === 'function') showToast('O\'chirishda xatolik', 'error');
  }
}

document.addEventListener('DOMContentLoaded', loadNasiyaDeals);
</script>

<%- include('../layouts/footer') %>
