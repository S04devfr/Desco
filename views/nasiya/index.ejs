<%- include('../layouts/header', {
  title: "Nasiya Bo'limi — DESCO CRM",
  activePage: 'nasiya-' + subPage,
  user: user}) %>

<div class="page-header">
  <div>
    <h1 id="nasiyaTitle">Nasiya</h1>
    <p>Sdelka voronkasidan kelgan nasiya to'lovlari ro'yxati</p>
  </div>
  <div class="page-header-actions">
    <button class="btn btn-secondary btn-sm" onclick="loadNasiyaDeals()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
  </div>
</div>

<div class="card">
  <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
    <h3 id="tableHeader">Mijozlar to'lovlari (Excel-Grid)</h3>
    <div style="display:flex; gap:10px;">
      <span id="dealCount" class="badge badge-blue">0</span>
      <button class="btn btn-primary btn-sm" onclick="saveAllChanges()">
        <i class="fas fa-save"></i> Barchasini Saqlash
      </button>
    </div>
  </div>
  <div class="table-wrap" style="overflow-x:auto;">
    <table class="deals-tbl" style="width:100%; border-collapse: collapse;">
      <thead>
        <tr>
          <th style="width:180px;">Mijoz / Telefon</th>
          <th>Mahsulot</th>
          <th style="width:100px;">Oy</th>
          <th style="width:140px;">Narxi (Summa)</th>
          <th>Izoh</th>
          <th style="width:90px;">Holati</th>
        </tr>
      </thead>
      <tbody id="nasiyaTableBody">
        <tr>
          <td colspan="6" style="text-align:center; padding:40px;">
            <div class="spinner" style="margin:auto"></div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<style>
.excel-input {
  width: 100%;
  border: 1px solid transparent;
  background: transparent;
  padding: 8px;
  font-size: 13px;
  border-radius: 4px;
  transition: all 0.2s;
  color: var(--text-primary);
}
.excel-input:hover {
  background: var(--bg-tertiary);
  border-color: var(--border);
}
.excel-input:focus {
  background: var(--bg-primary);
  border-color: var(--accent);
  box-shadow: 0 0 0 2px var(--accent-soft);
  outline: none;
}
.deal-group-header {
  background: var(--bg-secondary);
  font-weight: 600;
  color: var(--text-secondary);
  font-size: 12px;
  text-transform: uppercase;
}
</style>

<script>
const activeStageKey = '<%= subPage %>';
const titlesMap = {
  'shopir': 'Shopirdagi pul',
  'desco': 'Nasiya Desco',
  'ishonch': 'Nasiya Ishonch',
  'baraka': 'Nasiya Baraka'
};

document.getElementById('nasiyaTitle').textContent = titlesMap[activeStageKey] || 'Nasiya';
document.getElementById('tableHeader').textContent = (titlesMap[activeStageKey] || 'Nasiya') + ' ro\'yxati';

let allDealsData = [];

async function loadNasiyaDeals() {
  try {
    const tbody = document.getElementById('nasiyaTableBody');
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:40px;"><div class="spinner" style="margin:auto"></div></td></tr>';

    const r = await fetch('/api/nasiya/list-deals?stage=' + activeStageKey);
    const deals = await r.json();
    
    if (!r.ok) throw new Error(deals.message || 'Xatolik');

    allDealsData = deals;
    document.getElementById('dealCount').textContent = deals.length + ' ta sdelka';

    if (!deals.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:40px; color:var(--text-tertiary)"><i class="fas fa-wallet" style="font-size:28px; display:block; margin-bottom:8px;"></i>Bu bosqichda sdelkalar yo\'q</td></tr>';
      return;
    }

    let html = '';
    deals.forEach(d => {
      // Group header for the Deal
      const clientName = d.client ? escHtml(d.client.name) : 'Noma\'lum';
      const clientPhone = d.client && d.client.phone ? escHtml(d.client.phone) : '';
      
      let rowsHtml = '';
      if (d.installments && d.installments.length > 0) {
        d.installments.forEach((inst, idx) => {
          rowsHtml += `
            <tr class="inst-row" data-deal-id="${d.id}" data-inst-id="${inst.id}">
              <td style="font-size:12px; color:var(--text-secondary); border-right:1px solid var(--border-light);">
                ${idx === 0 ? `<strong>${clientName}</strong><br><span style="font-size:11px;color:var(--text-tertiary)">${clientPhone}</span>` : ''}
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-product" value="${escHtml(inst.productName || d.productName)}" placeholder="Mahsulot">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-month" value="${escHtml(inst.month || (idx+1 + '-oy'))}" placeholder="Oy">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="number" class="excel-input f-amount" value="${inst.amount}" placeholder="Summa">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-notes" value="${escHtml(inst.notes || '')}" placeholder="Izoh">
              </td>
              <td style="text-align:center;">
                <label style="cursor:pointer; display:flex; align-items:center; justify-content:center; gap:4px; font-size:12px;">
                  <input type="checkbox" class="f-paid" ${inst.paid ? 'checked' : ''}> To'landi
                </label>
              </td>
            </tr>
          `;
        });
      } else {
        // Empty row if no installments
        rowsHtml += `
            <tr class="inst-row" data-deal-id="${d.id}" data-inst-id="new">
              <td style="font-size:12px; color:var(--text-secondary); border-right:1px solid var(--border-light);">
                <strong>${clientName}</strong><br><span style="font-size:11px;color:var(--text-tertiary)">${clientPhone}</span>
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-product" value="${escHtml(d.productName)}" placeholder="Mahsulot">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-month" value="1-oy" placeholder="Oy">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="number" class="excel-input f-amount" value="${Math.max(0, d.amount - d.paidAmount)}" placeholder="Summa">
              </td>
              <td style="padding:0; border-right:1px solid var(--border-light);">
                <input type="text" class="excel-input f-notes" value="" placeholder="Izoh">
              </td>
              <td style="text-align:center;">
                <label style="cursor:pointer; display:flex; align-items:center; justify-content:center; gap:4px; font-size:12px;">
                  <input type="checkbox" class="f-paid"> To'landi
                </label>
              </td>
            </tr>
        `;
      }
      
      html += `
        <tr class="deal-group-header">
          <td colspan="6" style="padding:10px 12px; background:var(--bg-tertiary); border-top:2px solid var(--border);">
            Sdelka #${d.id} — Jami Qarz: <span style="color:var(--danger)">${fmtMoney(Math.max(0, d.amount - d.paidAmount))}</span>
          </td>
        </tr>
      ` + rowsHtml;
    });

    tbody.innerHTML = html;
  } catch(e) {
    document.getElementById('nasiyaTableBody').innerHTML = '<tr><td colspan="6" style="text-align:center; padding:40px; color:var(--danger)"><i class="fas fa-exclamation-triangle" style="font-size:28px; display:block; margin-bottom:8px;"></i>Yuklashda xato: ' + escHtml(e.message) + '</td></tr>';
  }
}

async function saveAllChanges() {
  const rows = document.querySelectorAll('.inst-row');
  const payloadMap = {}; // Group by dealId
  
  rows.forEach(row => {
    const dealId = row.getAttribute('data-deal-id');
    if (!payloadMap[dealId]) payloadMap[dealId] = [];
    
    // Fallback date to today + 1 month roughly if we don't have it in UI (UI simplified to Month string). 
    // In real app, date input might be needed for dueDate, but we'll assign a default date logic if missing
    let dueDateStr = new Date().toISOString(); 
    
    payloadMap[dealId].push({
      productName: row.querySelector('.f-product').value,
      month: row.querySelector('.f-month').value,
      amount: Number(row.querySelector('.f-amount').value) || 0,
      notes: row.querySelector('.f-notes').value,
      paid: row.querySelector('.f-paid').checked,
      dueDate: dueDateStr // Fallback needed for API contract
    });
  });

  try {
    const btn = document.querySelector('button[onclick="saveAllChanges()"]');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saqlanmoqda...';

    // We send requests sequentially or via Promise.all
    const promises = Object.keys(payloadMap).map(dealId => {
      // For each deal, if we rewrite installments, we must fetch existing ones first to preserve dueDate,
      // but since we simplified UI to not show dueDate, we might lose real dates if we overwrite. 
      // Wait, we MUST preserve dueDate! Let's pass the real dueDate in a hidden field.
      // Wait, I will refactor the UI to just use the new endpoint data.
      return fetch('/api/deals/' + dealId + '/installments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ installments: payloadMap[dealId] })
      });
    });

    await Promise.all(promises);
    
    if (typeof showToast === 'function') showToast('Barcha o\'zgarishlar saqlandi!', 'success');
    loadNasiyaDeals();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xatolik yuz berdi', 'error');
  } finally {
    const btn = document.querySelector('button[onclick="saveAllChanges()"]');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-save"></i> Barchasini Saqlash';
  }
}

function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function fmtMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + " so'm";
}

document.addEventListener('DOMContentLoaded', loadNasiyaDeals);
</script>
<%- include('../layouts/footer') %>
