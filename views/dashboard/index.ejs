<%- include('../layouts/header', {
  title: 'Tahlil — DESCO CRM',
  activePage: 'dashboard',
  user: user}) %>

<style>
/* Stats card enhancements */
.stat-card.clickable {
  cursor: pointer;
  position: relative;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.stat-card.clickable:hover {
  transform: translateY(-4px);
  border-color: var(--accent);
  box-shadow: var(--shadow-hover);
}
.stat-card.clickable::after {
  content: "\f304";
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  position: absolute;
  top: 10px;
  right: 12px;
  font-size: 10px;
  color: var(--text-tertiary);
  opacity: 0;
  transition: opacity 0.15s;
}
.stat-card.clickable:hover::after {
  opacity: 1;
}

.stat-value {
  font-size: 24px !important;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 4px;
  display: flex;
  align-items: baseline;
  flex-wrap: nowrap;
}
.currency-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-tertiary);
  margin-left: 5px;
  text-transform: uppercase;
}
.stat-card {
  padding: 16px 20px !important;
  min-height: 100px;
  display: flex;
  align-items: center;
}
.stat-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}
.stat-label {
  font-size: 13px;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.stat-sub {
  font-size: 11px;
  color: var(--text-tertiary);
  white-space: nowrap;
}

/* Financial Tab Navigation */
.financial-tab-btn {
  border-bottom: 2px solid transparent !important;
  color: var(--text-secondary);
  border-radius: 0 !important;
  font-weight: 500;
  transition: all 0.15s;
}
.financial-tab-btn.active {
  color: var(--accent) !important;
  border-bottom: 2px solid var(--accent) !important;
  font-weight: 600;
}
.fin-tab-content.hidden {
  display: none !important;
}

/* Inline Inputs styling */
.spreadsheet-input {
  border: 1px solid transparent;
  background: transparent;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  width: 100%;
  padding: 4px 8px;
  border-radius: 4px;
  transition: all 0.15s;
}
.spreadsheet-input:hover {
  background: var(--bg-primary);
  border-color: var(--border);
}
.spreadsheet-input:focus {
  background: var(--bg-secondary);
  border-color: var(--accent);
  outline: none;
  box-shadow: 0 0 0 2px var(--accent-soft);
}
.spreadsheet-input.success {
  border-color: var(--success) !important;
  background-color: var(--success-bg) !important;
}

/* Installment Plan UI */
.inst-deal-item {
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.15s;
  font-size: 12.5px;
}
.inst-deal-item:hover {
  background: var(--bg-tertiary);
}
.inst-deal-item.active {
  border-color: var(--accent);
  background: var(--accent-soft);
}
</style>

<div class="page-header">
  <div>
    <h1>Tahlil</h1>
    <p>Umumiy ko'rsatkichlar va statistika</p>
  </div>
  <div class="page-header-actions" style="display:flex; align-items:center; gap:8px;">
    <!-- Date Filter Picker -->
    <div id="dateRangeContainer" style="display:none; align-items:center; gap:6px;">
      <input type="date" id="startDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
      <span style="font-size:12px;color:var(--text-secondary)">-</span>
      <input type="date" id="endDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
    </div>
    
    <select id="dashFilter" class="form-control" style="width:auto;display:inline-block;height:32px;font-size:13px;" onchange="onFilterChange()">
      <option value="all">Barcha vaqt</option>
      <option value="today">Bugun</option>
      <option value="yesterday">Kecha</option>
      <option value="day-before-yesterday">Kuni kecha</option>
      <option value="month">Shu oy</option>
      <option value="range">Sana oralig'i</option>
    </select>
    <button class="btn btn-secondary btn-sm" onclick="loadDashboard()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
  </div>
</div>

<!-- KPI STATS -->
<div class="stats-grid" id="kpiCards" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px;">
  <div class="stat-card clickable" onclick="openFinancialModal('installments')">
    <div class="stat-icon blue"><i class="fas fa-handshake"></i></div>
    <div class="stat-info">
      <div class="stat-label"><%= (typeof user !== 'undefined' && user && user.role === 'admin') ? 'Jami sdelkalar' : 'Mening sdelkalarim' %></div>
      <div class="stat-value skeleton" style="height:28px;width:60px"> </div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-coins"></i></div>
    <div class="stat-info">
      <div class="stat-label"><%= (typeof user !== 'undefined' && user && user.role === 'admin') ? "Umumiy to'langan" : "Mening savdo summam" %></div>
      <div class="stat-value skeleton" style="height:28px;width:80px"> </div>
    </div>
  </div>
  
  <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
  <div class="stat-card clickable" onclick="openFinancialModal('client-debts')">
    <div class="stat-icon red"><i class="fas fa-users"></i></div>
    <div class="stat-info">
      <div class="stat-label">Klientlardan qarz</div>
      <div class="stat-value skeleton" style="height:28px;width:80px"> </div>
    </div>
  </div>
  <div class="stat-card" style="cursor: pointer" onclick="window.location.href='/expenses'">
    <div class="stat-icon orange"><i class="fas fa-minus-circle"></i></div>
    <div class="stat-info">
      <div class="stat-label">Xarajatlar</div>
      <div class="stat-value skeleton" style="height:28px;width:80px"> </div>
    </div>
  </div>
  <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')">
    <div class="stat-icon purple"><i class="fas fa-tags"></i></div>
    <div class="stat-info">
      <div class="stat-label">Tan narxi</div>
      <div class="stat-value skeleton" style="height:28px;width:80px"> </div>
    </div>
  </div>
  <div class="stat-card clickable" onclick="openProfitModal()">
    <div class="stat-icon green"><i class="fas fa-chart-line"></i></div>
    <div class="stat-info">
      <div class="stat-label">Sof foyda</div>
      <div class="stat-value skeleton" style="height:28px;width:80px"> </div>
    </div>
  </div>
  <% } %>
</div>

<!-- CHARTS + TASKS -->
<div class="dashboard-grid">
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-chart-bar" style="color:var(--accent);margin-right:6px"></i>Menejerlar bo'yicha savdo</h3>
    </div>
    <div class="card-body">
      <div class="chart-wrap">
        <canvas id="salesChart"></canvas>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-tasks" style="color:var(--accent);margin-right:6px"></i>Bugungi vazifalar</h3>
      <a href="/tasks" class="btn btn-ghost btn-sm" style="font-size:12px">Barchasi</a>
    </div>
    <div id="todayTasks" class="task-list" style="max-height: 520px; overflow-y: auto; padding-right: 4px;">
      <div style="padding:20px;text-align:center"><div class="spinner"></div></div>
    </div>
  </div>
</div>

<!-- PRODUCT CHART -->
<div class="card mt-4">
  <div class="card-header">
    <h3><i class="fas fa-box" style="color:var(--accent);margin-right:6px"></i>Mahsulotlar bo'yicha</h3>
  </div>
  <div class="card-body">
    <div class="chart-wrap" style="height:200px">
      <canvas id="productChart"></canvas>
    </div>
  </div>
</div>

<!-- ════════════ FINANCIAL METRICS MODAL ════════════ -->
<div class="modal-overlay hidden" id="financialModal" style="z-index:1100">
  <div class="modal-box" style="max-width:850px; max-height:85vh; display:flex; flex-direction:column; overflow:hidden; padding:0;">
    <div class="modal-header" style="padding:16px 20px; border-bottom:1px solid var(--border);">
      <h2 style="display:flex; align-items:center; gap:8px;"><i class="fas fa-wallet" style="color:var(--accent)"></i> Moliyaviy Sozlamalar va Nasiya</h2>
      <button class="modal-close" onclick="closeFinancialModal()">&times;</button>
    </div>
    
    <!-- Tab headers -->
    <div style="display:flex; border-bottom:1px solid var(--border); padding:0 16px; background:var(--bg-secondary); flex-shrink:0;">
      <button class="btn financial-tab-btn active" id="tab-cost-prices-btn" onclick="switchFinTab('cost-prices')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-tags" style="margin-right:6px"></i> Mahsulotlar Tan Narxi
      </button>
      <button class="btn financial-tab-btn" id="tab-installments-btn" onclick="switchFinTab('installments')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-calendar-alt" style="margin-right:6px"></i> Nasiya Rejalari
      </button>
      <button class="btn financial-tab-btn" id="tab-client-debts-btn" onclick="switchFinTab('client-debts')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-users" style="margin-right:6px"></i> Klientlardan Qarz (Manual)
      </button>
    </div>

    <div class="modal-body" style="flex:1; overflow-y:auto; padding:20px; background:var(--bg-primary);">
      <!-- Tab 1: Product Catalog -->
      <div class="fin-tab-content" id="tab-cost-prices">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:16px;">
          <div>
            <p style="font-size:12.5px; color:var(--text-secondary); margin:0;">Mahsulotlar va ularning narxlarini boshqarish.</p>
            <button class="btn btn-primary btn-sm mt-2" onclick="openAddProductModal()"><i class="fas fa-plus"></i> Yangi mahsulot qo'shish</button>
          </div>
          <div style="display:flex; gap:10px;">
            <input type="text" id="dealAttachSearch" class="form-control" placeholder="Mijoz (sdelka) qidirish..." style="width:200px; height:32px; font-size:12px">
            <select id="catalogSelect" class="form-control" style="width:200px; height:32px; font-size:12px">
              <option value="">Mahsulotni tanlang...</option>
            </select>
            <button class="btn btn-success btn-sm" onclick="attachProductToDeal()"><i class="fas fa-link"></i> Biriktirish</button>
          </div>
        </div>
        <div style="max-height:350px; overflow-y:auto; border:1px solid var(--border); border-radius:8px; background:var(--bg-secondary);">
          <table class="deals-tbl" style="width:100%">
            <thead>
              <tr style="background:var(--bg-tertiary);">
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">ID</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mahsulot Nomi</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Narxi</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Izoh</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700; width:60px"></th>
              </tr>
            </thead>
            <tbody id="costTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Tab 2: Installments -->
      <div class="fin-tab-content hidden" id="tab-installments">
        <div style="display:grid; grid-template-columns:250px 1fr; gap:20px; min-height:350px;">
          <!-- Left sdelka list -->
          <div style="border-right:1px solid var(--border); padding-right:12px; max-height:380px; overflow-y:auto; display:flex; flex-direction:column; gap:6px;">
            <p style="font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary); margin-bottom:4px">Qarzdorlik bor sdelkalar</p>
            <div id="installmentDealsList" style="display:flex; flex-direction:column; gap:6px"></div>
          </div>
          <!-- Right installment editor -->
          <div id="installmentPlanEditor" style="display:flex; flex-direction:column; min-height:350px;">
            <div class="empty-state" style="padding:60px 40px; text-align:center; margin:auto;">
              <i class="fas fa-chevron-left" style="font-size:28px; color:var(--text-tertiary); margin-bottom:10px"></i>
              <h4 style="margin:0 0 4px; font-size:14px; color:var(--text-secondary)">Sdelkani tanlang</h4>
              <p style="margin:0; font-size:12px; color:var(--text-tertiary)">Nasiya rejasini (oyma-oy to'lovlarni) sozlash uchun chapdan mijozni tanlang</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab 3: Client Debts -->
      <div class="fin-tab-content hidden" id="tab-client-debts">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:16px;">
          <p style="font-size:12.5px; color:var(--text-secondary); margin:0;">Mijozlarning qo'shimcha yoki manual qarzlarini tahrirlash.</p>
          <input type="text" id="clientDebtSearch" class="form-control" placeholder="Mijoz ismi..." style="width:220px; height:32px; font-size:12px" oninput="filterClientDebtTable()">
        </div>
        <div style="max-height:350px; overflow-y:auto; border:1px solid var(--border); border-radius:8px; background:var(--bg-secondary);">
          <table class="deals-tbl" style="width:100%">
            <thead>
              <tr style="background:var(--bg-tertiary);">
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">ID</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mijoz Ismi</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Telefon</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Kompaniya</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700; width:180px">Klient Qarz (Manual)</th>
              </tr>
            </thead>
            <tbody id="clientDebtTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>
    
    <div class="modal-footer" style="padding:12px 20px; background:var(--bg-secondary); border-top:1px solid var(--border); display:flex; justify-content:flex-end; flex-shrink:0;">
      <button class="btn btn-secondary btn-sm" onclick="closeFinancialModal()">Yopish</button>
    </div>
  </div>
</div>

<!-- ════════════ SOF FOYDA TAFSILOTLARI MODAL ════════════ -->
<div class="modal-overlay hidden" id="profitModal" style="z-index:1100">
  <div class="modal-box" style="max-width:980px; max-height:85vh; display:flex; flex-direction:column; overflow:hidden; padding:0;">
    <div class="modal-header" style="padding:16px 20px; border-bottom:1px solid var(--border);">
      <h2 style="display:flex; align-items:center; gap:8px;"><i class="fas fa-chart-line" style="color:#34C759"></i> Sof foyda va savdolar tafsiloti</h2>
      <button class="modal-close" onclick="closeProfitModal()">&times;</button>
    </div>

    <!-- Modal Filter Bar -->
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); padding:12px 20px; background:var(--bg-secondary); flex-wrap:wrap; gap:12px; flex-shrink:0;">
      <div style="display:flex; gap:6px; background:var(--bg-primary); padding:3px; border-radius:6px; border:1px solid var(--border)">
        <button class="btn btn-sm" id="pmf-today" onclick="setProfitFilter('today')" style="padding:4px 10px; font-size:12px; border:none; cursor:pointer;">Bugun</button>
        <button class="btn btn-sm" id="pmf-yesterday" onclick="setProfitFilter('yesterday')" style="padding:4px 10px; font-size:12px; border:none; cursor:pointer;">Kecha</button>
        <button class="btn btn-sm" id="pmf-3day" onclick="setProfitFilter('day-before-yesterday')" style="padding:4px 10px; font-size:12px; border:none; cursor:pointer;">Kecha oldingi kun</button>
        <button class="btn btn-sm" id="pmf-month" onclick="setProfitFilter('month')" style="padding:4px 10px; font-size:12px; border:none; cursor:pointer;">Shu oy</button>
        <button class="btn btn-sm" id="pmf-all" onclick="setProfitFilter('all')" style="padding:4px 10px; font-size:12px; border:none; cursor:pointer;">Barchasi</button>
      </div>
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="font-size:12px; color:var(--text-secondary)">Custom:</span>
        <input type="date" id="pmf-startDate" class="form-control" style="width:130px; height:30px; padding:0 8px; font-size:12px">
        <span style="color:var(--text-tertiary)">-</span>
        <input type="date" id="pmf-endDate" class="form-control" style="width:130px; height:30px; padding:0 8px; font-size:12px">
        <button class="btn btn-primary btn-sm" onclick="setProfitFilter('range')" style="height:30px; padding:0 12px; font-size:12px"><i class="fas fa-filter"></i></button>
      </div>
    </div>

    <!-- Summary metrics block inside Modal -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:12px; padding:16px 20px; background:var(--bg-secondary); border-bottom:1px solid var(--border); flex-shrink:0;">
      <div style="background:var(--bg-primary); border:1px solid var(--border); border-radius:8px; padding:10px 14px; display:flex; flex-direction:column; gap:2px;">
        <span style="font-size:11px; font-weight:600; color:var(--text-tertiary); text-transform:uppercase;">Jami Savdo</span>
        <span id="pm-totalRevenue" style="font-size:16px; font-weight:700; color:var(--text-primary);">0 UZS</span>
      </div>
      <div style="background:var(--bg-primary); border:1px solid var(--border); border-radius:8px; padding:10px 14px; display:flex; flex-direction:column; gap:2px;">
        <span style="font-size:11px; font-weight:600; color:var(--text-tertiary); text-transform:uppercase;">Jami Tan Narxi</span>
        <span id="pm-totalCostPrice" style="font-size:16px; font-weight:700; color:#5856D6;">0 UZS</span>
      </div>
      <div style="background:var(--bg-primary); border:1px solid var(--border); border-radius:8px; padding:10px 14px; display:flex; flex-direction:column; gap:2px;">
        <span style="font-size:11px; font-weight:600; color:var(--text-tertiary); text-transform:uppercase;">Jami Xarajatlar</span>
        <span id="pm-totalExpenses" style="font-size:16px; font-weight:700; color:#FF9500;">0 UZS</span>
      </div>
      <div style="background:var(--bg-primary); border:1px solid var(--border); border-radius:8px; padding:10px 14px; display:flex; flex-direction:column; gap:2px;">
        <span style="font-size:11px; font-weight:600; color:var(--text-tertiary); text-transform:uppercase;">Sof Foyda</span>
        <span id="pm-netProfit" style="font-size:16px; font-weight:700; color:#34C759;">0 UZS</span>
      </div>
    </div>

    <!-- Table of Sales details -->
    <div class="modal-body" style="flex:1; overflow-y:auto; padding:20px; background:var(--bg-primary);">
      <div style="border:1px solid var(--border); border-radius:10px; overflow:hidden; background:var(--bg-secondary);">
        <table class="deals-tbl" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr style="background:var(--bg-tertiary); border-bottom:1px solid var(--border);">
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:left; color:var(--text-secondary)">Sana</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:left; color:var(--text-secondary)">Sdelka Nomi</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:left; color:var(--text-secondary)">Mijoz</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:right; color:var(--text-secondary)">Summa</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:right; color:var(--text-secondary)">To'landi</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:right; color:var(--text-secondary)">Tan Narxi</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:right; color:var(--text-secondary)">Foyda</th>
              <th style="padding:12px 14px; font-size:11.5px; font-weight:700; text-align:left; color:var(--text-secondary)">Menejer</th>
            </tr>
          </thead>
          <tbody id="profitTableBody">
            <tr>
              <td colspan="8" style="padding:40px; text-align:center; color:var(--text-tertiary)"><div class="spinner" style="margin:auto"></div></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="modal-footer" style="padding:12px 20px; background:var(--bg-secondary); border-top:1px solid var(--border); display:flex; justify-content:flex-end; flex-shrink:0;">
      <button class="btn btn-secondary btn-sm" onclick="closeProfitModal()">Yopish</button>
    </div>
  </div>
</div>

<script>
let salesChart, productChart;

// Dynamic filter handlers
function onFilterChange() {
  const filter = document.getElementById('dashFilter').value;
  const rangeContainer = document.getElementById('dateRangeContainer');
  if (filter === 'range') {
    rangeContainer.style.display = 'inline-flex';
  } else {
    rangeContainer.style.display = 'none';
    loadDashboard();
  }
}

document.getElementById('startDate').addEventListener('change', () => {
  if (document.getElementById('endDate').value) loadDashboard();
});
document.getElementById('endDate').addEventListener('change', () => {
  if (document.getElementById('startDate').value) loadDashboard();
});

async function dashFetch(url, timeoutMs = 8000) {
  const controller = new AbortController();
  const id = setTimeout(() => controller.abort(), timeoutMs);
  let r;
  try {
    r = await fetch(url, { signal: controller.signal });
    clearTimeout(id);
  } catch(err) {
    clearTimeout(id);
    throw new Error("Tarmoq xatosi yoki server ishlamayapti (Timeout).");
  }
  let data;
  try { data = await r.json(); } catch { data = {}; }
  if (!r.ok) {
    if (typeof _toast === 'function') _toast(data.message || 'Server xatosi: ' + r.status, 'error');
    throw new Error(data.message || (url + ' -> ' + r.status));
  }
  return data;
}

// Helpers
function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function fmtMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + " so'm";
}
function renderCardMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + ' <span class="currency-label">UZS</span>';
}
function fmtShort(v) {
  const n = Number(v) || 0;
  if (n >= 1e9) return (n / 1e9).toFixed(1).replace('.0', '') + " mlrd";
  if (n >= 1e6) return (n / 1e6).toFixed(1).replace('.0', '') + " mln";
  if (n >= 1e3) return (n / 1e3).toFixed(0) + " ming";
  return String(n);
}
function fmtDate(d) {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return typeof d === 'object' ? JSON.stringify(d) : String(d);
  const dd = String(dt.getDate()).padStart(2, '0');
  const mm = String(dt.getMonth() + 1).padStart(2, '0');
  const yyyy = dt.getFullYear();
  return `${dd}.${mm}.${yyyy}`;
}

