<%- include('../layouts/header', {
  title: 'Tahlil — DESCO CRM',
  activePage: 'dashboard',
  user: user}) %>

<% const isAdmin = typeof user !== 'undefined' && user && user.role === 'admin'; %>

<div class="page-header fluxen-page-header">
  <div>
    <h1 id="greetingText" style="font-size:22px;font-weight:800;letter-spacing:-0.5px;">Xayrli kun! 👋</h1>
    <p id="greetingDate" style="font-size:13px;color:var(--text-300);margin-top:2px;">Umumiy ko'rsatkichlar va statistika</p>
  </div>
  <div class="page-header-actions flex items-center gap-2 flex-wrap">
    <div id="dateRangeContainer" style="display:none; align-items:center; gap:6px;">
      <input type="date" id="startDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
      <span style="font-size:12px;color:var(--text-secondary)">-</span>
      <input type="date" id="endDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
    </div>
    <select id="dashFilter" class="form-control" style="width:auto;display:inline-block;height:32px;font-size:13px;" onchange="onFilterChange()">
      <option value="all">Barcha vaqt</option>
      <option value="today">Bugun</option>
      <option value="yesterday">Kecha</option>
      <option value="day-before-yesterday">Kuni kecha</option>
      <option value="month">Shu oy</option>
      <option value="range">Sana oralig'i</option>
    </select>
    <button class="btn btn-secondary btn-sm" onclick="loadDashboard()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
    <% if (isAdmin) { %>
    <a id="exportCsvBtn" href="/api/export/excel?filter=month" class="btn btn-secondary btn-sm" style="display:flex;align-items:center;gap:5px;">
      <i class="fas fa-file-excel" style="color:#34C759"></i> Excel eksport
    </a>
    <% } %>
  </div>
</div>

<script>
(function() {
  var h = new Date().getHours();
  var name = '<%= user && user.fullName ? user.fullName.split(" ")[0] : "Admin" %>';
  var greeting = h < 12 ? 'Xayrli tong' : (h < 17 ? 'Xayrli kun' : 'Xayrli kech');
  var el = document.getElementById('greetingText');
  if (el) el.textContent = greeting + ', ' + name + ' 👋';
  var days = ['Yakshanba','Dushanba','Seshanba','Chorshanba','Payshanba','Juma','Shanba'];
  var months = ['Yanvar','Fevral','Mart','Aprel','May','Iyun','Iyul','Avgust','Sentabr','Oktabr','Noyabr','Dekabr'];
  var now = new Date();
  var dateEl = document.getElementById('greetingDate');
  if (dateEl) dateEl.textContent = days[now.getDay()] + ', ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();
})();
</script>

<div id="debugErrorContainer" style="display:none; margin-bottom: 20px; padding: 15px; border-radius: 8px; background-color: rgba(255, 59, 48, 0.1); border: 1px solid #FF3B30; color: #FF3B30; font-family: monospace; font-size: 13px; white-space: pre-wrap; word-break: break-all;">
  <strong>[DEBUG] Tahlil Xatoligi:</strong>
  <span id="debugErrorMessage"></span>
</div>

<!-- ══════════════════════════════════════════════════════ -->
<!-- BO'LIM 1: TAHLIL -->
<!-- ══════════════════════════════════════════════════════ -->
<div class="section-header">
  <div class="section-bar brand"></div>
  <h2 class="section-title"><i class="fas fa-chart-line text-brand"></i>Tahlil</h2>
  <div class="section-line"></div>
</div>

<!-- QATOR 1: Asosiy moliyaviy raqamlar -->
<div class="stats-grid mb-4" id="kpiRow1">
  <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-spinner fa-spin"></i></div><div class="stat-info"><div class="stat-label">Yuklanmoqda...</div></div></div>
</div>

<!-- QATOR 2: Kanallar va jarayonlar -->
<div class="stats-grid mb-6" id="kpiRow2">
  <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-spinner fa-spin"></i></div><div class="stat-info"><div class="stat-label">Yuklanmoqda...</div></div></div>
</div>

<!-- ADVANCED METRICS GRID (FUNNEL & GEOGRAPHIC) -->
<div class="dashboard-grid-2">
  <!-- HubSpot style Conversion Funnel -->
  <div class="card">
    <div class="card-header flex justify-between items-center">
      <h3 class="section-title"><i class="fas fa-filter text-brand"></i>Savdo Voronkasi</h3>
      <span class="badge badge-brand">Konversiya</span>
    </div>
    <div class="card-body">
      <div id="funnelContainer" class="funnel-container">
        <div class="empty-state" style="padding:40px;"><div class="spinner" style="margin:auto;"></div></div>
      </div>
    </div>
  </div>

  <!-- Marketing / Target Section (Admin) or Mening Vazifalarim (Manager) -->
  <% if (isAdmin) { %>
  <div class="card" id="marketingSection">
    <div class="card-header flex justify-between items-center">
      <h3 class="section-title"><i class="fas fa-bullhorn text-brand"></i>Marketing va Target</h3>
      <button class="btn btn-sm btn-primary" onclick="openMarketingModal()">
        <i class="fas fa-plus"></i> Kunlik ma'lumot
      </button>
    </div>
    <!-- Marketing body — flex column ichida -->
    <div class="mkt-inner">
      <!-- Summary stats -->
      <div id="marketingSummary" class="mkt-stats-row">
        <div class="mkt-stat"><span class="mkt-stat-label">Jami xarajat</span><span class="mkt-stat-val" id="mktTotalSpent">—</span></div>
        <div class="mkt-stat"><span class="mkt-stat-label">Jami lead</span><span class="mkt-stat-val" id="mktTotalLeads">—</span></div>
        <div class="mkt-stat"><span class="mkt-stat-label">CPL (1 lead)</span><span class="mkt-stat-val" id="mktCpl">—</span></div>
      </div>
      <!-- Channel breakdown -->
      <div id="mktChannelContainer" class="mkt-channel-row"></div>
      <!-- Recent logs table -->
      <div class="mkt-table-wrap">
        <table class="deals-tbl">
          <thead>
            <tr>
              <th>Sana</th>
              <th>Kanal</th>
              <th>Kampaniya</th>
              <th class="tr">Xarajat</th>
              <th class="tc">Lead</th>
              <th class="tr">CPL</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="mktLogsBody">
            <tr><td colspan="7" class="tc" style="padding:20px;"><div class="spinner" style="margin:auto;"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="card" id="myTasksSection">
    <div class="card-header flex justify-between items-center">
      <h3 class="section-title"><i class="fas fa-tasks text-brand"></i>Mening Vazifalarim</h3>
      <span class="badge badge-brand" id="myTasksCount">0 ta faol</span>
    </div>
    <div class="card-body" style="padding: 12px; height: 350px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px;" id="myTasksContainer">
      <div style="padding:40px;text-align:center"><div class="spinner" style="margin:auto;"></div></div>
    </div>
  </div>
  <% } %>
</div>

<% if (isAdmin) { %>
<!-- ═══════════════════════════════════════════════════════
     MENEJERLAR — SAVDO GRAFIGI + OYLIK/KPI (yonma-yon)
════════════════════════════════════════════════════════ -->
<div class="card mb-6" id="managerKpiSection">
  <div class="card-header flex justify-between items-center">
    <div class="flex items-center" style="gap:10px;">
      <h3 class="section-title"><i class="fas fa-users-cog text-brand"></i>Menejerlar — Savdo & Oylik/KPI</h3>
    </div>
    <div class="mgr-formula-badge">
      <i class="fas fa-calculator"></i>
      Asosiy maosh &plus; (Won &times; 100 000) &minus; Jarima
    </div>
  </div>
  <!-- Split layout: chart left | table right -->
  <div class="mgr-split-layout">

    <!-- LEFT: bar chart + debtors sidebar -->
    <div class="mgr-chart-panel">
      <div style="display: flex; gap: 20px; width: 100%; flex-wrap: wrap;">
        <!-- Chart container -->
        <div style="flex: 2; min-width: 300px; display: flex; flex-direction: column; justify-content: space-between;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; gap: 10px;">
            <div style="display: flex; gap: 10px; align-items: center;">
              <div style="width: 36px; height: 36px; border-radius: 8px; background: var(--brand-soft); display: flex; align-items: center; justify-content: center; color: var(--brand);">
                <i class="fas fa-calendar-alt" style="font-size: 16px;"></i>
              </div>
              <div>
                <div style="font-weight: 700; font-size: 14px; color: var(--text-primary);">Kunlar kesimida</div>
                <div style="font-size: 11px; color: var(--text-tertiary);" id="chartSubtitleMonth">Kunlik statistika</div>
              </div>
            </div>
            <div style="text-align: right;">
              <div style="font-weight: 800; font-size: 18px; color: var(--text-primary); line-height: 1.1;" id="chartTotalWonSales">0 UZS</div>
              <div style="font-size: 10px; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase;">Jami Savdo</div>
            </div>
          </div>
          <div class="mgr-chart-wrap" style="min-height: 190px; max-height: 230px;">
            <canvas id="salesChart"></canvas>
          </div>
          <div style="display: flex; justify-content: center; gap: 20px; margin-top: 12px; font-size: 11px; font-weight: 700;">
            <span style="display: flex; align-items: center; gap: 6px; color: var(--text-secondary);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: #FF3B30; display: inline-block;"></span>
              Qarz (Nasiya)
            </span>
            <span style="display: flex; align-items: center; gap: 6px; color: var(--text-secondary);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: #34C759; display: inline-block;"></span>
              Muvaffaqiyatli Savdo
            </span>
          </div>
        </div>
        <!-- Debtors Sidebar -->
        <div style="flex: 1; min-width: 240px; border-left: 1px solid var(--border); padding-left: 20px;" id="topDebtorsPanel">
          <div class="mgr-panel-label" style="margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <span><i class="fas fa-hand-holding-usd text-danger"></i> Eng Katta Qarzdorlar</span>
            <span class="badge badge-danger" id="debtorsCountBadge" style="font-size: 9px;">0 ta</span>
          </div>
          <div id="topDebtorsList" style="display: flex; flex-direction: column; gap: 8px; max-height: 200px; overflow-y: auto; padding-right: 4px;">
            <div class="text-muted" style="font-size: 11.5px; text-align: center; padding: 20px;">Yuklanmoqda...</div>
          </div>
        </div>
      </div>
    </div>

    <!-- divider -->
    <div class="mgr-divider"></div>

    <!-- RIGHT: KPI/salary table -->
    <div class="mgr-table-panel">
      <div class="mgr-panel-label"><i class="fas fa-calculator"></i> Oylik hisob-kitob</div>
      <div class="mgr-table-scroll">
        <table class="deals-tbl mgr-kpi-tbl">
          <thead>
            <tr>
              <th>Menejer</th>
              <th class="tc" style="width:60px;">Holat</th>
              <th class="tc" style="width:72px;">Bugun</th>
              <th class="tc">Won</th>
              <th class="tc">Win%</th>
              <th class="tr kpi-th-plus">+ Asosiy maosh</th>
              <th class="tr kpi-th-plus">+ KPI bonus</th>
              <th class="tc kpi-th-minus">− Jarima</th>
              <th class="tr kpi-th-total">= Jami to'lov</th>
            </tr>
          </thead>
          <tbody id="managerKpiTableBody">
            <tr><td colspan="9" class="tc kpi-empty"><div class="spinner" style="margin:auto;"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Fine Modal -->
<div id="fineModal" class="modal-overlay" style="display:none;" onclick="if(event.target===this)closeFineModal()">
  <div class="modal-dialog" style="max-width:420px;">
    <div class="modal-header flex justify-between items-center">
      <h3><i class="fas fa-exclamation-triangle text-danger" style="margin-right:8px;"></i>Jarima qo'shish</h3>
      <button class="modal-close" onclick="closeFineModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" style="display:flex; flex-direction:column; gap:14px;">
      <input type="hidden" id="fineManagerId">
      <div>
        <label class="form-label">Menejer</label>
        <input type="text" id="fineManagerName" class="form-control" readonly>
      </div>
      <div>
        <label class="form-label">Jarima summasi (so'm)</label>
        <input type="number" id="fineAmount" class="form-control" placeholder="100000" min="0" step="10000">
      </div>
      <div>
        <label class="form-label">Sabab</label>
        <input type="text" id="fineReason" class="form-control" placeholder="Masalan: kechikish, qoidabuzarlik...">
      </div>
    </div>
    <div class="modal-footer flex justify-end gap-2">
      <button class="btn btn-secondary" onclick="closeFineModal()">Bekor</button>
      <button class="btn btn-danger" onclick="submitFine()"><i class="fas fa-save"></i> Saqlash</button>
    </div>
  </div>
</div>

<!-- Shopirdagi Pullar Details Modal -->
<div id="shopirDealsModal" class="modal-overlay" style="display:none; z-index:1100;" onclick="if(event.target===this)closeShopirDealsModal()">
  <div class="modal-dialog" style="max-width:680px; width:95%;">
    <div class="modal-header flex justify-between items-center">
      <h3><i class="fas fa-truck-moving text-brand" style="margin-right:8px;"></i>Shopirdagi pullar tafsiloti</h3>
      <button class="modal-close" onclick="closeShopirDealsModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div style="max-height:400px; overflow-y:auto; border:1px solid var(--border); border-radius:8px; background:var(--bg-secondary);">
        <table class="deals-tbl" style="width:100%">
          <thead>
            <tr style="background:var(--bg-tertiary);">
              <th style="padding:10px 12px; font-size:11px; font-weight:700;">ID</th>
              <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mahsulot</th>
              <th style="padding:10px 12px; font-size:11px; font-weight:700; width:100px;">Qabul qilingan sana</th>
              <th style="padding:10px 12px; font-size:11px; font-weight:700;">Menejer</th>
              <th style="padding:10px 12px; font-size:11px; font-weight:700; text-align:right; width:120px;">Umumiy narxi</th>
              <th style="padding:10px 12px; font-size:11px; font-weight:700; text-align:right; width:120px;">Kutilayotgan (Qarz)</th>
            </tr>
          </thead>
          <tbody id="shopirDealsTableBody"></tbody>
        </table>
      </div>
    </div>
    <div class="modal-footer flex justify-end">
      <button class="btn btn-secondary" onclick="closeShopirDealsModal()">Yopish</button>
    </div>
  </div>
</div>

<!-- Client Debt Edit/Create Modal -->
<div id="clientDebtModal" class="modal-overlay" style="display:none; z-index:1100;" onclick="if(event.target===this)closeClientDebtModal()">
  <div class="modal-dialog" style="max-width:480px;">
    <div class="modal-header flex justify-between items-center">
      <h3 id="clientDebtModalTitle"><i class="fas fa-hand-holding-usd text-brand" style="margin-right:8px;"></i>Qarzdorlikni tahrirlash</h3>
      <button class="modal-close" onclick="closeClientDebtModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" style="display:flex; flex-direction:column; gap:14px;">
      <input type="hidden" id="debtClientId">
      <div>
        <label class="form-label">Mijoz ismi <span style="color:var(--danger)">*</span></label>
        <input type="text" id="debtClientName" class="form-control" placeholder="Mijoz ismi">
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div>
          <label class="form-label">Telefon raqami</label>
          <input type="text" id="debtClientPhone" class="form-control" placeholder="+998901234567">
        </div>
        <div>
          <label class="form-label">Viloyat / Shahar</label>
          <input type="text" id="debtClientCity" class="form-control" placeholder="Toshkent">
        </div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div>
          <label class="form-label">Qarz summasi (so'm) <span style="color:var(--danger)">*</span></label>
          <input type="number" id="debtClientAmount" class="form-control" placeholder="1000000" min="0" step="10000">
        </div>
        <div>
          <label class="form-label">Qarz berilgan sana</label>
          <input type="date" id="debtClientDate" class="form-control">
        </div>
      </div>
      <div>
        <label class="form-label">Qarz izohi</label>
        <input type="text" id="debtClientNotes" class="form-control" placeholder="Izoh...">
      </div>
    </div>
    <div class="modal-footer flex justify-end gap-2" style="padding-top:14px; border-top:1px solid var(--border);">
      <button class="btn btn-secondary" onclick="closeClientDebtModal()">Bekor qilish</button>
      <button class="btn btn-primary" onclick="submitClientDebtForm()"><i class="fas fa-save"></i> Saqlash</button>
    </div>
  </div>
</div>
<% } %>

<% if (isAdmin) { %>
