<%- include('../layouts/header', {
  title: 'Tahlil — DESCO CRM',
  activePage: 'dashboard',
  user: user}) %>

<style>
/* Stats card enhancements */
.stat-card.clickable {
  cursor: pointer;
  position: relative;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.stat-card.clickable:hover {
  transform: translateY(-4px);
  border-color: var(--accent);
  box-shadow: var(--glass-shadow-hover);
}
.stat-card.clickable::after {
  content: "\\f304";
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  position: absolute;
  top: 10px;
  right: 12px;
  font-size: 10px;
  color: var(--text-tertiary);
  opacity: 0;
  transition: opacity 0.15s;
}
.stat-card.clickable:hover::after {
  opacity: 1;
}

/* Financial Tab Navigation */
.financial-tab-btn {
  border-bottom: 2px solid transparent !important;
  color: var(--text-secondary);
  border-radius: 0 !important;
  font-weight: 500;
  transition: all 0.15s;
}
.financial-tab-btn.active {
  color: var(--accent) !important;
  border-bottom: 2px solid var(--accent) !important;
  font-weight: 600;
}
.fin-tab-content.hidden {
  display: none !important;
}

/* Inline Inputs styling */
.spreadsheet-input {
  border: 1px solid transparent;
  background: transparent;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  width: 100%;
  padding: 4px 8px;
  border-radius: 4px;
  transition: all 0.15s;
}
.spreadsheet-input:hover {
  background: var(--bg-primary);
  border-color: var(--border);
}
.spreadsheet-input:focus {
  background: var(--bg-secondary);
  border-color: var(--accent);
  outline: none;
  box-shadow: 0 0 0 2px var(--accent-soft);
}
.spreadsheet-input.success {
  border-color: var(--success) !important;
  background-color: var(--success-bg) !important;
}

/* Installment Plan UI */
.inst-deal-item {
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  background: var(--bg-secondary);
  border: 1px solid var(--glass-border);
  cursor: pointer;
  transition: all 0.15s;
  font-size: 12.5px;
}
.inst-deal-item:hover {
  background: var(--bg-tertiary);
}
.inst-deal-item.active {
  border-color: var(--accent);
  background: var(--accent-soft);
}
</style>

<div class="page-header">
  <div>
    <h1>Tahlil</h1>
    <p>Umumiy ko'rsatkichlar va statistika</p>
  </div>
  <div class="page-header-actions" style="display:flex; align-items:center; gap:8px;">
    <!-- Date Filter Picker -->
    <div id="dateRangeContainer" style="display:none; align-items:center; gap:6px;">
      <input type="date" id="startDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
      <span style="font-size:12px;color:var(--text-secondary)">-</span>
      <input type="date" id="endDate" class="form-control" style="width:130px;height:32px;font-size:12px;padding:0 8px;">
    </div>
    
    <select id="dashFilter" class="form-control" style="width:auto;display:inline-block;height:32px;font-size:13px;" onchange="onFilterChange()">
      <option value="all">Barcha vaqt</option>
      <option value="today">Bugun</option>
      <option value="yesterday">Kecha</option>
      <option value="day-before-yesterday">Kuni kecha</option>
      <option value="month">Shu oy</option>
      <option value="range">Sana oralig'i</option>
    </select>
    <button class="btn btn-secondary btn-sm" onclick="loadDashboard()">
      <i class="fas fa-sync-alt"></i> Yangilash
    </button>
  </div>
</div>

<!-- KPI STATS -->
<div class="stats-grid" id="kpiCards" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin-bottom: 24px;">
  <div class="stat-card clickable" onclick="openFinancialModal('installments')"><div class="stat-icon blue"><i class="fas fa-handshake"></i></div><div class="stat-info"><div class="stat-label">Jami sdelkalar</div><div class="stat-value skeleton" style="height:28px;width:60px"> </div></div></div>
  <div class="stat-card"><div class="stat-icon green"><i class="fas fa-coins"></i></div><div class="stat-info"><div class="stat-label">To'langan</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
  <div class="stat-card clickable" onclick="openFinancialModal('installments')"><div class="stat-icon orange"><i class="fas fa-clock"></i></div><div class="stat-info"><div class="stat-label">Qarz</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
  <div class="stat-card clickable" onclick="openFinancialModal('client-debts')"><div class="stat-icon red"><i class="fas fa-users"></i></div><div class="stat-info"><div class="stat-label">Klientlardan qarz</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
  <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')"><div class="stat-icon purple"><i class="fas fa-tags"></i></div><div class="stat-info"><div class="stat-label">Tan narxi</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
  <div class="stat-card" style="cursor: pointer" onclick="window.location.href='/expenses'"><div class="stat-icon red"><i class="fas fa-minus-circle"></i></div><div class="stat-info"><div class="stat-label">Xarajatlar</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
  <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')"><div class="stat-icon purple"><i class="fas fa-chart-line"></i></div><div class="stat-info"><div class="stat-label">Sof foyda</div><div class="stat-value skeleton" style="height:28px;width:80px"> </div></div></div>
</div>

<!-- CHARTS + TASKS -->
<div class="dashboard-grid">
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-chart-bar" style="color:var(--accent);margin-right:6px"></i>Menejerlar bo'yicha savdo</h3>
    </div>
    <div class="card-body">
      <div class="chart-wrap">
        <canvas id="salesChart"></canvas>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-tasks" style="color:var(--accent);margin-right:6px"></i>Bugungi vazifalar</h3>
      <a href="/tasks" class="btn btn-ghost btn-sm" style="font-size:12px">Barchasi</a>
    </div>
    <div id="todayTasks" class="task-list">
      <div style="padding:20px;text-align:center"><div class="spinner"></div></div>
    </div>
  </div>
</div>

<!-- PRODUCT CHART -->
<div class="card mt-4">
  <div class="card-header">
    <h3><i class="fas fa-box" style="color:var(--accent);margin-right:6px"></i>Mahsulotlar bo'yicha</h3>
  </div>
  <div class="card-body">
    <div class="chart-wrap" style="height:200px">
      <canvas id="productChart"></canvas>
    </div>
  </div>
</div>

<!-- ════════════ FINANCIAL METRICS MODAL ════════════ -->
<div class="modal-overlay hidden" id="financialModal" style="z-index:1100">
  <div class="modal-box" style="max-width:850px; max-height:85vh; display:flex; flex-direction:column; overflow:hidden; padding:0;">
    <div class="modal-header" style="padding:16px 20px; border-bottom:1px solid var(--glass-border);">
      <h2 style="display:flex; align-items:center; gap:8px;"><i class="fas fa-wallet" style="color:var(--accent)"></i> Moliyaviy Sozlamalar va Nasiya</h2>
      <button class="modal-close" onclick="closeFinancialModal()">&times;</button>
    </div>
    
    <!-- Tab headers -->
    <div style="display:flex; border-bottom:1px solid var(--glass-border); padding:0 16px; background:var(--bg-secondary); flex-shrink:0;">
      <button class="btn financial-tab-btn active" id="tab-cost-prices-btn" onclick="switchFinTab('cost-prices')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-tags" style="margin-right:6px"></i> Mahsulotlar Tan Narxi
      </button>
      <button class="btn financial-tab-btn" id="tab-installments-btn" onclick="switchFinTab('installments')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-calendar-alt" style="margin-right:6px"></i> Nasiya Rejalari
      </button>
      <button class="btn financial-tab-btn" id="tab-client-debts-btn" onclick="switchFinTab('client-debts')" style="border-radius:0; border:none; padding:12px 16px; background:none; font-size:13px; cursor:pointer;">
        <i class="fas fa-users" style="margin-right:6px"></i> Klientlardan Qarz (Manual)
      </button>
    </div>

    <div class="modal-body" style="flex:1; overflow-y:auto; padding:20px; background:var(--bg-primary);">
      <!-- Tab 1: Cost Prices -->
      <div class="fin-tab-content" id="tab-cost-prices">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:16px;">
          <p style="font-size:12.5px; color:var(--text-secondary); margin:0;">Sdelkalar bo'yicha mahsulotlar tan narxini (cost price) tahrirlang. Sof foyda shu qiymatga qarab hisoblanadi.</p>
          <input type="text" id="costSearch" class="form-control" placeholder="Mahsulot yoki mijoz..." style="width:220px; height:32px; font-size:12px" oninput="filterCostTable()">
        </div>
        <div style="max-height:350px; overflow-y:auto; border:1px solid var(--glass-border); border-radius:8px; background:var(--bg-secondary);">
          <table class="deals-tbl" style="width:100%">
            <thead>
              <tr style="background:var(--bg-tertiary);">
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">ID</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mahsulot</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mijoz</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Sotilgan Summa</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700; width:160px">Tan Narxi (Cost Price)</th>
              </tr>
            </thead>
            <tbody id="costTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Tab 2: Installments -->
      <div class="fin-tab-content hidden" id="tab-installments">
        <div style="display:grid; grid-template-columns:250px 1fr; gap:20px; min-height:350px;">
          <!-- Left sdelka list -->
          <div style="border-right:1px solid var(--glass-border); padding-right:12px; max-height:380px; overflow-y:auto; display:flex; flex-direction:column; gap:6px;">
            <p style="font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary); margin-bottom:4px">Qarzdorlik bor sdelkalar</p>
            <div id="installmentDealsList" style="display:flex; flex-direction:column; gap:6px"></div>
          </div>
          <!-- Right installment editor -->
          <div id="installmentPlanEditor" style="display:flex; flex-direction:column; min-height:350px;">
            <div class="empty-state" style="padding:60px 40px; text-align:center; margin:auto;">
              <i class="fas fa-chevron-left" style="font-size:28px; color:var(--text-tertiary); margin-bottom:10px"></i>
              <h4 style="margin:0 0 4px; font-size:14px; color:var(--text-secondary)">Sdelkani tanlang</h4>
              <p style="margin:0; font-size:12px; color:var(--text-tertiary)">Nasiya rejasini (oyma-oy to'lovlarni) sozlash uchun chapdan mijozni tanlang</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab 3: Client Debts -->
      <div class="fin-tab-content hidden" id="tab-client-debts">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:16px;">
          <p style="font-size:12.5px; color:var(--text-secondary); margin:0;">Mijozlarning qo'shimcha yoki manual qarzlarini tahrirlash.</p>
          <input type="text" id="clientDebtSearch" class="form-control" placeholder="Mijoz ismi..." style="width:220px; height:32px; font-size:12px" oninput="filterClientDebtTable()">
        </div>
        <div style="max-height:350px; overflow-y:auto; border:1px solid var(--glass-border); border-radius:8px; background:var(--bg-secondary);">
          <table class="deals-tbl" style="width:100%">
            <thead>
              <tr style="background:var(--bg-tertiary);">
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">ID</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Mijoz Ismi</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Telefon</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700;">Kompaniya</th>
                <th style="padding:10px 12px; font-size:11px; font-weight:700; width:180px">Klient Qarz (Manual)</th>
              </tr>
            </thead>
            <tbody id="clientDebtTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>
    
    <div class="modal-footer" style="padding:12px 20px; background:var(--bg-secondary); border-top:1px solid var(--glass-border); display:flex; justify-content:flex-end; flex-shrink:0;">
      <button class="btn btn-secondary btn-sm" onclick="closeFinancialModal()">Yopish</button>
    </div>
  </div>
</div>

<script>
let salesChart, productChart;

// Dynamic filter handlers
function onFilterChange() {
  const filter = document.getElementById('dashFilter').value;
  const rangeContainer = document.getElementById('dateRangeContainer');
  if (filter === 'range') {
    rangeContainer.style.display = 'inline-flex';
  } else {
    rangeContainer.style.display = 'none';
    loadDashboard();
  }
}

document.getElementById('startDate').addEventListener('change', () => {
  if (document.getElementById('endDate').value) loadDashboard();
});
document.getElementById('endDate').addEventListener('change', () => {
  if (document.getElementById('startDate').value) loadDashboard();
});

async function dashFetch(url) {
  const fetchFn = (typeof fetchWithTimeout === 'function') ? fetchWithTimeout : fetch;
  let r;
  try {
    r = await fetchFn(url);
  } catch(err) {
    throw new Error("Tarmoq xatosi yoki server ishlamayapti.");
  }
  let data;
  try { data = await r.json(); } catch { data = {}; }
  if (!r.ok) {
    if (typeof _toast === 'function') _toast(data.message || 'Server xatosi: ' + r.status, 'error');
    throw new Error(data.message || (url + ' -> ' + r.status));
  }
  return data;
}

// Helpers
function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function fmtMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + " so'm";
}
function fmtShort(v) {
  const n = Number(v) || 0;
  if (n >= 1e9) return (n / 1e9).toFixed(1).replace('.0', '') + " mlrd";
  if (n >= 1e6) return (n / 1e6).toFixed(1).replace('.0', '') + " mln";
  if (n >= 1e3) return (n / 1e3).toFixed(0) + " ming";
  return String(n);
}
function fmtDate(d) {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt)) return '';
  return dt.toLocaleDateString('uz-UZ', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

// Main loader
async function loadDashboard() {
  try {
    const filter = document.getElementById('dashFilter') ? document.getElementById('dashFilter').value : 'all';
    let urlParams = 'filter=' + filter;
    if (filter === 'range') {
      const start = document.getElementById('startDate').value;
      const end = document.getElementById('endDate').value;
      if (start && end) {
        urlParams += '&startDate=' + start + '&endDate=' + end;
      }
    }

    const [kpis, salesData, productData, tasks] = await Promise.all([
      dashFetch('/api/dashboard/kpis?' + urlParams),
      dashFetch('/api/dashboard/sales-by-manager?' + urlParams),
      dashFetch('/api/dashboard/product-popularity?' + urlParams),
      dashFetch('/api/dashboard/today-tasks')
    ]);

    // KPI Cards rendering
    document.getElementById('kpiCards').innerHTML = \`
      <div class="stat-card clickable" onclick="openFinancialModal('installments')">
        <div class="stat-icon blue"><i class="fas fa-handshake"></i></div>
        <div class="stat-info">
          <div class="stat-label">Jami sdelkalar</div>
          <div class="stat-value">\${kpis.totalOrders ?? 0}</div>
          <div class="stat-sub">Yutilgan: \${kpis.won ?? 0} · Yo'qotilgan: \${kpis.lost ?? 0}</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-coins"></i></div>
        <div class="stat-info">
          <div class="stat-label">To'langan</div>
          <div class="stat-value">\${fmtMoney(kpis.totalRevenue ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="openFinancialModal('installments')">
        <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
          <div class="stat-label">Qarz</div>
          <div class="stat-value">\${fmtMoney(kpis.totalDebt ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="openFinancialModal('client-debts')">
        <div class="stat-icon red"><i class="fas fa-users"></i></div>
        <div class="stat-info">
          <div class="stat-label">Klientlardan qarz</div>
          <div class="stat-value">\${fmtMoney(kpis.totalClientDebt ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')">
        <div class="stat-icon purple"><i class="fas fa-tags"></i></div>
        <div class="stat-info">
          <div class="stat-label">Tan narxi</div>
          <div class="stat-value">\${fmtMoney(kpis.totalCostPrice ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card" style="cursor: pointer" onclick="window.location.href='/expenses'">
        <div class="stat-icon red"><i class="fas fa-minus-circle"></i></div>
        <div class="stat-info">
          <div class="stat-label">Xarajatlar</div>
          <div class="stat-value">\${fmtMoney(kpis.totalExpenses ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')">
        <div class="stat-icon purple"><i class="fas fa-chart-line"></i></div>
        <div class="stat-info">
          <div class="stat-label">Sof foyda</div>
          <div class="stat-value \${(kpis.netProfit ?? 0) >= 0 ? 'text-success' : 'text-danger'}">\${fmtMoney(kpis.netProfit ?? 0)}</div>
        </div>
      </div>
    \`;

    // Charts rendering
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    const textColor = isDark ? '#98989d' : '#6e6e73';

    if (salesChart) salesChart.destroy();
    salesChart = new Chart(document.getElementById('salesChart'), {
      type: 'bar',
      data: {
        labels: salesData.map(d => d.manager),
        datasets: [{
          label: "Savdo (so'm)",
          data: salesData.map(d => d.totalSales),
          backgroundColor: 'rgba(0,122,255,0.7)',
          borderRadius: 8, borderSkipped: false
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { grid: { color: gridColor }, ticks: { color: textColor, callback: v => fmtShort(v) } },
          x: { grid: { display: false }, ticks: { color: textColor } }
        }
      }
    });

    if (productChart) productChart.destroy();
    const top = productData.slice(0, 8);
    const colors = ['#007AFF','#34C759','#FF9500','#FF3B30','#5856D6','#00C7BE','#FF2D55','#AC8E68'];
    productChart = new Chart(document.getElementById('productChart'), {
      type: 'doughnut',
      data: {
        labels: top.map(d => d.product),
        datasets: [{ data: top.map(d => d.count), backgroundColor: colors, borderWidth: 0 }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'right', labels: { color: textColor, boxWidth: 12, padding: 14, font: { size: 12 } } } }
      }
    });

    // Today's tasks rendering
    const tasksEl = document.getElementById('todayTasks');
    if (!tasks.length) {
      tasksEl.innerHTML = '<div class="empty-state" style="padding:24px"><div class="empty-state-icon"><i class="fas fa-check-circle"></i></div><h3>Bugungi vazifalar yo\\'q</h3></div>';
    } else {
      tasksEl.innerHTML = tasks.map(t => \`
        <div class="task-item">
          <div class="task-check \${t.completed ? 'done' : ''}" onclick="toggleTask(\${t.id}, this)">
            \${t.completed ? '<i class="fas fa-check" style="font-size:9px"></i>' : ''}
          </div>
          <div class="task-info">
            <div class="task-title \${t.completed ? 'done' : ''}">\${escHtml(t.title)}</div>
            <div class="task-meta">
              <span class="priority-dot \${t.priority}"></span>
              \${t.dueDate ? '<span class="task-due"><i class="fas fa-clock"></i> ' + fmtDate(t.dueDate) + '</span>' : ''}
            </div>
          </div>
        </div>
      \`).join('');
    }
  } catch(e) {
    console.error('Dashboard yuk xatosi:', e);
    const kpiCards = document.getElementById('kpiCards');
    if (kpiCards) {
      kpiCards.innerHTML = \`
        <div class="stat-card" style="grid-column:1/-1">
          <div class="stat-icon red"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-info">
            <div class="stat-label">Yuklashda xato</div>
            <div class="stat-value" style="font-size:14px;font-weight:500">\${escHtml(e.message)}</div>
          </div>
          <button class="btn btn-secondary btn-sm" style="margin-left:auto" onclick="loadDashboard()"><i class="fas fa-redo"></i> Qayta urinish</button>
        </div>
      \`;
    }
  }
}

async function toggleTask(id, el) {
  const completed = !el.classList.contains('done');
  try {
    const r = await fetch('/api/tasks/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ completed })
    });
    if (r.ok) {
      el.classList.toggle('done');
      el.innerHTML = completed ? '<i class="fas fa-check" style="font-size:9px"></i>' : '';
      el.nextElementSibling.querySelector('.task-title').classList.toggle('done');
    }
  } catch(e) {}
}

// ── FINANCIAL MODAL LOGIC ──
let allDealsData = [];
let allClientsData = [];
let selectedDealIdForInstallments = null;

function openFinancialModal(tab) {
  document.getElementById('financialModal').classList.remove('hidden');
  switchFinTab(tab);
  loadFinancialData();
}

function closeFinancialModal() {
  document.getElementById('financialModal').classList.add('hidden');
}

function switchFinTab(tab) {
  document.querySelectorAll('.financial-tab-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  document.querySelectorAll('.fin-tab-content').forEach(content => {
    content.classList.add('hidden');
  });

  document.getElementById('tab-' + tab + '-btn').classList.add('active');
  document.getElementById('tab-' + tab).classList.remove('hidden');
}

async function loadFinancialData() {
  try {
    const [deals, clients] = await Promise.all([
      dashFetch('/api/deals'),
      dashFetch('/api/clients')
    ]);
    allDealsData = deals || [];
    allClientsData = clients || [];
    
    renderCostTable();
    renderInstallmentTab();
    renderClientDebtTable();
  } catch(e) {
    console.error('Moliya yuklashda xato:', e);
  }
}

// Tab 1: Cost Price rendering & updating
function renderCostTable() {
  const tbody = document.getElementById('costTableBody');
  const q = document.getElementById('costSearch').value.toLowerCase();
  
  const filtered = allDealsData.filter(d => 
    (d.productName || '').toLowerCase().includes(q) || 
    (d.client?.name || '').toLowerCase().includes(q)
  );

  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-tertiary)">Sdelkalar topilmadi</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map(d => \`
    <tr>
      <td style="padding:10px 12px; font-size:12.5px; color:var(--text-tertiary)">#\${d.id}</td>
      <td style="padding:10px 12px; font-size:13px; font-weight:600">\${escHtml(d.productName)}</td>
      <td style="padding:10px 12px; font-size:12.5px">\${escHtml(d.client?.name || 'Noma\\'lum')}</td>
      <td style="padding:10px 12px; font-size:12.5px; font-weight:600">\${fmtMoney(d.amount)}</td>
      <td style="padding:6px 12px;">
        <input type="number" class="spreadsheet-input" value="\${d.costPrice || 0}"
               onchange="saveDealCostPrice(\${d.id}, this)">
      </td>
    </tr>
  \`).join('');
}

function filterCostTable() {
  renderCostTable();
}

async function saveDealCostPrice(id, inputEl) {
  const val = Number(inputEl.value) || 0;
  try {
    inputEl.disabled = true;
    const r = await fetch('/api/deals/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ costPrice: val })
    });
    if (!r.ok) throw new Error();
    
    // Success feedback animation
    inputEl.classList.add('success');
    setTimeout(() => inputEl.classList.remove('success'), 1000);
    
    // Update local data
    const d = allDealsData.find(x => x.id === id);
    if (d) d.costPrice = val;
    
    loadDashboard(); // Recalculate dashboard metrics
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
  } finally {
    inputEl.disabled = false;
  }
}

// Tab 2: Installments rendering & planners
function renderInstallmentTab() {
  const listEl = document.getElementById('installmentDealsList');
  
  // Only deals that have outstanding debt
  const debtorDeals = allDealsData.filter(d => d.amount > d.paidAmount);
  
  if (!debtorDeals.length) {
    listEl.innerHTML = '<div style="color:var(--text-tertiary);font-size:12px;padding:10px;text-align:center;">Qarzdorlar yo\\'q</div>';
    document.getElementById('installmentPlanEditor').innerHTML = \`
      <div class="empty-state" style="padding:60px 40px; text-align:center; margin:auto;">
        <i class="fas fa-check-circle" style="font-size:28px; color:var(--success); margin-bottom:10px"></i>
        <h4 style="margin:0; font-size:14px; color:var(--text-secondary)">Barcha qarzdorliklar yopilgan</h4>
      </div>
    \`;
    return;
  }

  listEl.innerHTML = debtorDeals.map(d => \`
    <div class="inst-deal-item \${selectedDealIdForInstallments === d.id ? 'active' : ''}" onclick="selectDealForInstallments(\${d.id})">
      <div style="font-weight:600; color:var(--text-primary);">\${escHtml(d.client?.name || 'Mijoz #' + d.id)}</div>
      <div style="font-size:11px; color:var(--text-secondary); margin-top:2px;">\${escHtml(d.productName)}</div>
      <div style="display:flex; justify-content:space-between; font-size:11px; margin-top:4px;">
        <span style="color:var(--text-tertiary)">Qarz:</span>
        <span style="color:var(--danger); font-weight:700;">\${fmtMoney(d.amount - d.paidAmount)}</span>
      </div>
    </div>
  \`).join('');

  if (selectedDealIdForInstallments) {
    renderInstallmentPlanEditor(selectedDealIdForInstallments);
  }
}

async function selectDealForInstallments(dealId) {
  selectedDealIdForInstallments = dealId;
  renderInstallmentTab();
}

async function renderInstallmentPlanEditor(dealId) {
  const deal = allDealsData.find(d => d.id === dealId);
  const editorEl = document.getElementById('installmentPlanEditor');
  if (!deal) return;

  const remainingDebt = deal.amount - deal.paidAmount;

  editorEl.innerHTML = \`
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px dashed var(--glass-border); padding-bottom:10px; margin-bottom:12px;">
      <div>
        <h3 style="font-size:14px; font-weight:700; margin:0;">\${escHtml(deal.client?.name)} · \${escHtml(deal.productName)}</h3>
        <p style="font-size:11px; color:var(--text-tertiary); margin:0;">Sdelka #\${deal.id}</p>
      </div>
      <div style="text-align:right">
        <div style="font-size:10px; color:var(--text-tertiary); text-transform:uppercase;">Qolgan Qarz</div>
        <div style="font-size:16px; font-weight:800; color:var(--danger)">\${fmtMoney(remainingDebt)}</div>
      </div>
    </div>

    <!-- Quick action: auto-generate plan -->
    <div style="background:var(--bg-tertiary); padding:10px; border-radius:8px; margin-bottom:16px; display:flex; justify-content:space-between; align-items:center; gap:8px;">
      <span style="font-size:11.5px; color:var(--text-secondary); font-weight:500;">
        <i class="fas fa-magic" style="color:var(--accent); margin-right:4px;"></i> Avto-Bo'lib to'lash plani
      </span>
      <div style="display:flex; gap:6px;">
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(\${deal.id}, 3)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border-med)">3 oy</button>
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(\${deal.id}, 6)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border-med)">6 oy</button>
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(\${deal.id}, 12)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border-med)">12 oy</button>
      </div>
    </div>

    <!-- Installments rows -->
    <div style="font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary); margin-bottom:6px;">To'lov jadvali</div>
    <div id="instRowsContainer" style="display:flex; flex-direction:column; gap:6px; max-height:220px; overflow-y:auto; margin-bottom:16px; padding-right:4px;"></div>
    
    <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--glass-border); padding-top:12px;">
      <button class="btn btn-sm btn-ghost" onclick="addInstallmentRow()" style="border:1px dashed var(--border-med); font-size:12px;">
        <i class="fas fa-plus"></i> To'lov qo'shish
      </button>
      <button class="btn btn-sm btn-primary" onclick="saveInstallmentPlan(\${deal.id})" id="saveInstPlanBtn">
        <i class="fas fa-save"></i> Planni Saqlash
      </button>
    </div>
  \`;

  // Fetch current plan
  try {
    const list = await dashFetch('/api/deals/' + dealId + '/installments');
    const container = document.getElementById('instRowsContainer');
    if (list && list.length) {
      container.innerHTML = list.map((inst, idx) => getInstallmentRowHtml(idx, inst.dueDate.slice(0, 10), inst.amount, inst.paid)).join('');
    } else {
      // Default: 1 row pre-filled with remaining debt
      container.innerHTML = getInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false);
    }
  } catch(e) {
    document.getElementById('instRowsContainer').innerHTML = getInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false);
  }
}

function getInstallmentRowHtml(index, dateVal, amountVal, paidVal) {
  return \`
    <div class="installment-row" style="display:flex; align-items:center; gap:8px; background:var(--bg-secondary); border:1px solid var(--glass-border); padding:6px 8px; border-radius:6px;">
      <span style="font-size:12px; color:var(--text-tertiary); width:20px; font-weight:600;">#\${index + 1}</span>
      <input type="date" class="form-control inst-date" value="\${dateVal}" style="width:130px; height:28px; font-size:12px; padding:0 6px;">
      <input type="number" class="form-control inst-amount" value="\${amountVal}" style="flex:1; height:28px; font-size:12px; padding:0 6px; font-weight:600;" placeholder="Summa">
      
      <label style="display:inline-flex; align-items:center; gap:4px; font-size:11.5px; color:var(--text-secondary); cursor:pointer; margin:0; user-select:none;">
        <input type="checkbox" class="inst-paid" \${paidVal ? 'checked' : ''} style="cursor:pointer;"> To'landi
      </label>
      
      <button class="btn btn-ghost btn-sm text-danger" onclick="this.parentElement.remove()" style="padding:2px 6px; font-size:11px;" title="Qatorni o'chirish">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  \`;
}

function addInstallmentRow() {
  const container = document.getElementById('instRowsContainer');
  const index = container.querySelectorAll('.installment-row').length;
  
  // Calculate next month's date by default
  const lastRowDate = container.querySelector('.installment-row:last-child .inst-date');
  let dateStr = new Date().toISOString().slice(0,10);
  if (lastRowDate && lastRowDate.value) {
    const d = new Date(lastRowDate.value);
    d.setMonth(d.getMonth() + 1);
    dateStr = d.toISOString().slice(0,10);
  }

  const div = document.createElement('div');
  div.innerHTML = getInstallmentRowHtml(index, dateStr, 0, false);
  container.appendChild(div.firstElementChild);
}

function autoGenerateInstallments(dealId, months) {
  const deal = allDealsData.find(d => d.id === dealId);
  if (!deal) return;
  const remaining = deal.amount - deal.paidAmount;
  const eachVal = Math.round(remaining / months);

  const container = document.getElementById('instRowsContainer');
  container.innerHTML = '';
  
  for (let i = 0; i < months; i++) {
    const d = new Date();
    d.setMonth(d.getMonth() + i); // monthly increments
    const dateStr = d.toISOString().slice(0, 10);
    const amount = (i === months - 1) ? (remaining - (eachVal * (months - 1))) : eachVal; // deal with rounding error on last item
    
    container.innerHTML += getInstallmentRowHtml(i, dateStr, amount, false);
  }
}

async function saveInstallmentPlan(dealId) {
  const btn = document.getElementById('saveInstPlanBtn');
  btn.disabled = true;
  
  const container = document.getElementById('instRowsContainer');
  const rows = container.querySelectorAll('.installment-row');
  const installments = [];
  
  let totalScheduled = 0;
  for (const row of rows) {
    const dueDate = row.querySelector('.inst-date').value;
    const amount = Number(row.querySelector('.inst-amount').value) || 0;
    const paid = row.querySelector('.inst-paid').checked;
    
    if (!dueDate) {
      if (typeof showToast === 'function') showToast('Sana kiritilishi majburiy', 'error');
      btn.disabled = false;
      return;
    }
    installments.push({ dueDate, amount, paid });
    totalScheduled += amount;
  }

  try {
    const r = await fetch('/api/deals/' + dealId + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('To\\'lov plani saqlandi', 'success');
    loadFinancialData(); // Refresh metrics locally
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xatolik', 'error');
  } finally {
    btn.disabled = false;
  }
}

// Tab 3: Client Manual Debt rendering & updating
function renderClientDebtTable() {
  const tbody = document.getElementById('clientDebtTableBody');
  const q = document.getElementById('clientDebtSearch').value.toLowerCase();
  
  const filtered = allClientsData.filter(c => 
    (c.name || '').toLowerCase().includes(q) ||
    (c.company || '').toLowerCase().includes(q) ||
    (c.phone || '').toLowerCase().includes(q)
  );

  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-tertiary)">Mijozlar topilmadi</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map(c => \`
    <tr>
      <td style="padding:10px 12px; font-size:12.5px; color:var(--text-tertiary)">#\${c.id}</td>
      <td style="padding:10px 12px; font-size:13px; font-weight:600">\${escHtml(c.name)}</td>
      <td style="padding:10px 12px; font-size:12.5px">\${escHtml(c.phone || '—')}</td>
      <td style="padding:10px 12px; font-size:12.5px">\${escHtml(c.company || '—')}</td>
      <td style="padding:6px 12px;">
        <input type="number" class="spreadsheet-input" value="\${c.debt || 0}"
               onchange="saveClientDebt(\${c.id}, this)">
      </td>
    </tr>
  \`).join('');
}

function filterClientDebtTable() {
  renderClientDebtTable();
}

async function saveClientDebt(id, inputEl) {
  const val = Number(inputEl.value) || 0;
  try {
    inputEl.disabled = true;
    const r = await fetch('/api/clients/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ debt: val })
    });
    if (!r.ok) throw new Error();
    
    // Success feedback animation
    inputEl.classList.add('success');
    setTimeout(() => inputEl.classList.remove('success'), 1000);
    
    // Update local data
    const c = allClientsData.find(x => x.id === id);
    if (c) c.debt = val;
    
    loadDashboard(); // Recalculate dashboard metrics
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
  } finally {
    inputEl.disabled = false;
  }
}

// Start
loadDashboard();
</script>
