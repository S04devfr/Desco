            <th style="padding: 10px 12.5px; font-size: 11px; font-weight: 700; width: 140px;">Yuborilgan vaqt</th>
            <th style="padding: 10px 12.5px; font-size: 11px; font-weight: 700; width: 140px;">Menejer</th>
            <th style="padding: 10px 12.5px; font-size: 11px; font-weight: 700; width: 150px;">Logistika Holati</th>
