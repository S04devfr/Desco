    allClientsData = clients || [];
    allCatalogData = catalog || [];
    
    renderCatalogTable();
    updateCatalogDropdown();
    renderInstallmentTab();
    renderClientDebtTable();
  } catch(e) {
    console.error('Moliya yuklashda xato:', e);
  }
}

// Tab 1: Product Catalog rendering & updating
function renderCatalogTable() {
  const tbody = document.getElementById('costTableBody');
  
  if (!allCatalogData.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-tertiary)">Katalog bo\'sh</td></tr>';
    return;
  }

  tbody.innerHTML = allCatalogData.map(d => `
    <tr>
      <td style="padding:10px 12px; font-size:12.5px; color:var(--text-tertiary)">#${d.id}</td>
      <td style="padding:10px 12px; font-size:13px; font-weight:600">${escHtml(d.name)}</td>
      <td style="padding:10px 12px; font-size:12.5px; font-weight:600">${fmtMoney(d.price)}</td>
      <td style="padding:10px 12px; font-size:12.5px">${escHtml(d.notes || '-')}</td>
      <td style="padding:6px 12px; text-align:right;">
        <button class="btn btn-ghost btn-sm text-danger" onclick="deleteCatalogProduct(${d.id})"><i class="fas fa-trash"></i></button>
      </td>
    </tr>
  `).join('');
}

function updateCatalogDropdown() {
  const select = document.getElementById('catalogSelect');
  select.innerHTML = '<option value="">Mahsulotni tanlang...</option>' + 
    allCatalogData.map(c => `<option value="${c.id}" data-price="${c.price}" data-name="${escHtml(c.name)}">${escHtml(c.name)} (${fmtMoney(c.price)})</option>`).join('');
}

function openAddProductModal() {
  // We'll create a simple prompt-based modal logic for adding
  const name = prompt("Mahsulot nomi:");
  if (!name) return;
  const price = prompt("Narxi (raqamda):");
  if (!price) return;
  const notes = prompt("Izoh (masalan qaysi shaharga qancha):");
  
  saveNewProduct(name, price, notes);
}

async function saveNewProduct(name, price, notes) {
  try {
    const r = await fetch('/api/product-catalog', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, price, notes })
    });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast('Qo\'shildi', 'success');
    loadFinancialData();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
  }
}

async function deleteCatalogProduct(id) {
  if (!confirm('Rostdan ham o\'chirmoqchimisiz?')) return;
  try {
    const r = await fetch('/api/product-catalog/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    loadFinancialData();
  } catch(e) {}
}

async function attachProductToDeal() {
  const searchQ = document.getElementById('dealAttachSearch').value.toLowerCase();
  const selectEl = document.getElementById('catalogSelect');
  const catId = selectEl.value;
  
  if (!searchQ || !catId) return alert('Mijozni qidiring va mahsulotni tanlang!');
  
  const deal = allDealsData.find(d => 
    (d.client?.name || '').toLowerCase().includes(searchQ) ||
    String(d.client?.phone || '').includes(searchQ)
  );
  
  if (!deal) return alert('Sdelka (mijoz) topilmadi!');
  
  const opt = selectEl.options[selectEl.selectedIndex];
  const price = opt.getAttribute('data-price');
  const pName = opt.getAttribute('data-name');
  
  if (!confirm(`Sdelka: ${deal.client?.name}\nMahsulot: ${pName}\nNarx: ${price}\nBiriktirilsinmi?`)) return;
  
  try {
    const r = await fetch('/api/deals/' + deal.id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productName: pName, amount: Number(price) })
    });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast('Mahsulot biriktirildi', 'success');
    document.getElementById('dealAttachSearch').value = '';
    loadFinancialData();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Xatolik yuz berdi', 'error');
  }
}

// Tab 2: Installments rendering & planners
function renderInstallmentTab() {
  const listEl = document.getElementById('installmentDealsList');
  
  // Only deals that have outstanding debt
  const debtorDeals = allDealsData.filter(d => d.amount > d.paidAmount);
  
  if (!debtorDeals.length) {
    listEl.innerHTML = '<div style="color:var(--text-tertiary);font-size:12px;padding:10px;text-align:center;">Qarzdorlar yo\'q</div>';
    document.getElementById('installmentPlanEditor').innerHTML = `
      <div class="empty-state" style="padding:60px 40px; text-align:center; margin:auto;">
        <i class="fas fa-check-circle" style="font-size:28px; color:var(--success); margin-bottom:10px"></i>
        <h4 style="margin:0; font-size:14px; color:var(--text-secondary)">Barcha qarzdorliklar yopilgan</h4>
      </div>
    `;
    return;
  }

  listEl.innerHTML = debtorDeals.map(d => `
    <div class="inst-deal-item ${selectedDealIdForInstallments === d.id ? 'active' : ''}" onclick="selectDealForInstallments(${d.id})">
      <div style="font-weight:600; color:var(--text-primary);">${escHtml(d.client?.name || 'Mijoz #' + d.id)}</div>
      <div style="font-size:11px; color:var(--text-secondary); margin-top:2px;">${escHtml(d.productName)}</div>
      <div style="display:flex; justify-content:space-between; font-size:11px; margin-top:4px;">
        <span style="color:var(--text-tertiary)">Qarz:</span>
        <span style="color:var(--danger); font-weight:700;">${fmtMoney(d.amount - d.paidAmount)}</span>
      </div>
    </div>
  `).join('');

  if (selectedDealIdForInstallments) {
    renderInstallmentPlanEditor(selectedDealIdForInstallments);
  }
}

async function selectDealForInstallments(dealId) {
  selectedDealIdForInstallments = dealId;
  renderInstallmentTab();
}

async function renderInstallmentPlanEditor(dealId) {
  const deal = allDealsData.find(d => d.id === dealId);
  const editorEl = document.getElementById('installmentPlanEditor');
  if (!deal) return;

  const remainingDebt = deal.amount - deal.paidAmount;

  editorEl.innerHTML = `
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px dashed var(--border); padding-bottom:10px; margin-bottom:12px;">
      <div>
        <h3 style="font-size:14px; font-weight:700; margin:0;">${escHtml(deal.client?.name)} · ${escHtml(deal.productName)}</h3>
        <p style="font-size:11px; color:var(--text-tertiary); margin:0;">Sdelka #${deal.id}</p>
      </div>
      <div style="text-align:right">
        <div style="font-size:10px; color:var(--text-tertiary); text-transform:uppercase;">Qolgan Qarz</div>
        <div style="font-size:16px; font-weight:800; color:var(--danger)">${fmtMoney(remainingDebt)}</div>
      </div>
    </div>

    <!-- Quick action: auto-generate plan -->
    <div style="background:var(--bg-tertiary); padding:10px; border-radius:8px; margin-bottom:16px; display:flex; justify-content:space-between; align-items:center; gap:8px;">
      <span style="font-size:11.5px; color:var(--text-secondary); font-weight:500;">
        <i class="fas fa-magic" style="color:var(--accent); margin-right:4px;"></i> Avto-Bo'lib to'lash plani
      </span>
      <div style="display:flex; gap:6px;">
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(${deal.id}, 3)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">3 oy</button>
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(${deal.id}, 6)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">6 oy</button>
        <button class="btn btn-sm btn-ghost" onclick="autoGenerateInstallments(${deal.id}, 12)" style="padding:4px 8px; font-size:11px; border:1px solid var(--border)">12 oy</button>
      </div>
    </div>

    <!-- Installments rows -->
    <div style="font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-tertiary); margin-bottom:6px;">To'lov jadvali</div>
    <div id="instRowsContainer" style="display:flex; flex-direction:column; gap:6px; max-height:220px; overflow-y:auto; margin-bottom:16px; padding-right:4px;"></div>
    
    <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border); padding-top:12px;">
      <button class="btn btn-sm btn-ghost" onclick="addInstallmentRow()" style="border:1px dashed var(--border); font-size:12px;">
        <i class="fas fa-plus"></i> To'lov qo'shish
      </button>
      <button class="btn btn-sm btn-primary" onclick="saveInstallmentPlan(${deal.id})" id="saveInstPlanBtn">
        <i class="fas fa-save"></i> Planni Saqlash
      </button>
    </div>
  `;

  // Fetch current plan
  try {
    const list = await dashFetch('/api/deals/' + dealId + '/installments');
    const container = document.getElementById('instRowsContainer');
    if (list && list.length) {
      container.innerHTML = list.map((inst, idx) => getInstallmentRowHtml(idx, inst.dueDate.slice(0, 10), inst.amount, inst.paid, inst.productName, inst.month, inst.notes)).join('');
    } else {
      // Default: 1 row pre-filled with remaining debt
      container.innerHTML = getInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false, deal.productName, '1-oy', '');
    }
  } catch(e) {
    document.getElementById('instRowsContainer').innerHTML = getInstallmentRowHtml(0, new Date().toISOString().slice(0, 10), remainingDebt, false, deal.productName, '1-oy', '');
  }
}

function getInstallmentRowHtml(index, dateVal, amountVal, paidVal, productVal, monthVal, notesVal) {
  return `
    <div class="installment-row" style="display:flex; align-items:center; gap:6px; background:var(--bg-secondary); border:1px solid var(--border); padding:6px 8px; border-radius:6px; margin-bottom:4px;">
      <span style="font-size:12px; color:var(--text-tertiary); width:16px; font-weight:600;">#${index + 1}</span>
      <input type="text" class="form-control inst-product spreadsheet-input" value="${escHtml(productVal || '')}" style="width:130px; height:28px; font-size:12px; padding:0 6px;" placeholder="Mahsulot">
      <input type="text" class="form-control inst-month spreadsheet-input" value="${escHtml(monthVal || '')}" style="width:70px; height:28px; font-size:12px; padding:0 6px;" placeholder="Oy (1 oy)">
      <input type="date" class="form-control inst-date spreadsheet-input" value="${dateVal}" style="width:115px; height:28px; font-size:12px; padding:0 6px;">
      <input type="number" class="form-control inst-amount spreadsheet-input" value="${amountVal}" style="flex:1; max-width:100px; height:28px; font-size:12px; padding:0 6px; font-weight:600;" placeholder="Summa">
      <input type="text" class="form-control inst-notes spreadsheet-input" value="${escHtml(notesVal || '')}" style="flex:1.5; height:28px; font-size:12px; padding:0 6px;" placeholder="Izoh">
      
      <label style="display:inline-flex; align-items:center; gap:4px; font-size:11.5px; color:var(--text-secondary); cursor:pointer; margin:0 8px 0 4px; user-select:none; white-space:nowrap;">
        <input type="checkbox" class="inst-paid" ${paidVal ? 'checked' : ''} style="cursor:pointer;"> To'landi
      </label>
      
      <button class="btn btn-ghost btn-sm text-danger" onclick="this.parentElement.remove()" style="padding:2px 6px; font-size:11px;" title="Qatorni o'chirish">
        <i class="fas fa-trash"></i>
      </button>
    </div>
  `;
}

function addInstallmentRow() {
  const container = document.getElementById('instRowsContainer');
  const index = container.querySelectorAll('.installment-row').length;
  
  const lastRowDate = container.querySelector('.installment-row:last-child .inst-date');
  const lastProduct = container.querySelector('.installment-row:last-child .inst-product');
  let dateStr = new Date().toISOString().slice(0,10);
  let pName = lastProduct ? lastProduct.value : '';
  
  if (lastRowDate && lastRowDate.value) {
    const d = new Date(lastRowDate.value);
    d.setMonth(d.getMonth() + 1);
    dateStr = d.toISOString().slice(0,10);
  }

  const div = document.createElement('div');
  div.innerHTML = getInstallmentRowHtml(index, dateStr, 0, false, pName, `${index+1}-oy`, '');
  container.appendChild(div.firstElementChild);
}

function autoGenerateInstallments(dealId, months) {
  const deal = allDealsData.find(d => d.id === dealId);
  if (!deal) return;
  const remaining = deal.amount - deal.paidAmount;
  const eachVal = Math.round(remaining / months);

  const container = document.getElementById('instRowsContainer');
  container.innerHTML = '';
  
  for (let i = 0; i < months; i++) {
    const d = new Date();
    d.setMonth(d.getMonth() + i);
    const dateStr = d.toISOString().slice(0, 10);
    const amount = (i === months - 1) ? (remaining - (eachVal * (months - 1))) : eachVal;
    
    container.innerHTML += getInstallmentRowHtml(i, dateStr, amount, false, deal.productName, `${i+1}-oy`, '');
  }
}

async function saveInstallmentPlan(dealId) {
  const btn = document.getElementById('saveInstPlanBtn');
  btn.disabled = true;
  
  const container = document.getElementById('instRowsContainer');
  const rows = container.querySelectorAll('.installment-row');
  const installments = [];
  
  let totalScheduled = 0;
  for (const row of rows) {
    const dueDate = row.querySelector('.inst-date').value;
    const amount = Number(row.querySelector('.inst-amount').value) || 0;
    const paid = row.querySelector('.inst-paid').checked;
    const productName = row.querySelector('.inst-product').value;
    const month = row.querySelector('.inst-month').value;
    const notes = row.querySelector('.inst-notes').value;
    
    if (!dueDate) {
      if (typeof showToast === 'function') showToast('Sana kiritilishi majburiy', 'error');
      btn.disabled = false;
      return;
    }
    installments.push({ dueDate, amount, paid, productName, month, notes });
    totalScheduled += amount;
  }

  try {
    const r = await fetch('/api/deals/' + dealId + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('To\'lov plani saqlandi', 'success');
    loadFinancialData(); // Refresh metrics locally
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xatolik', 'error');
  } finally {
    btn.disabled = false;
  }
}

// Tab 3: Client Manual Debt rendering & updating
function renderClientDebtTable() {
  const tbody = document.getElementById('clientDebtTableBody');
  const q = document.getElementById('clientDebtSearch').value.toLowerCase();
  
  const filtered = allClientsData.filter(c => 
    (c.name || '').toLowerCase().includes(q) ||
    (c.company || '').toLowerCase().includes(q) ||
    (c.phone || '').toLowerCase().includes(q)
  );

  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-tertiary)">Mijozlar topilmadi</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map(c => `
    <tr>
      <td style="padding:10px 12px; font-size:12.5px; color:var(--text-tertiary)">#${c.id}</td>
      <td style="padding:10px 12px; font-size:13px; font-weight:600">${escHtml(c.name)}</td>
      <td style="padding:10px 12px; font-size:12.5px">${escHtml(c.phone || '—')}</td>
      <td style="padding:10px 12px; font-size:12.5px">${escHtml(c.company || '—')}</td>
      <td style="padding:6px 12px;">
        <input type="number" class="spreadsheet-input" value="${c.debt || 0}"
               onchange="saveClientDebt(${c.id}, this)">
      </td>
    </tr>
  `).join('');
}

function filterClientDebtTable() {
  renderClientDebtTable();
}

async function saveClientDebt(id, inputEl) {
  const val = Number(inputEl.value) || 0;
  try {
    inputEl.disabled = true;
    const r = await fetch('/api/clients/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ debt: val })
    });
    if (!r.ok) throw new Error();
    
    // Success feedback animation
    inputEl.classList.add('success');
    setTimeout(() => inputEl.classList.remove('success'), 1000);
    
    // Update local data
    const c = allClientsData.find(x => x.id === id);
    if (c) c.debt = val;
    
    loadDashboard(); // Recalculate dashboard metrics
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
  } finally {
    inputEl.disabled = false;
  }
}

// Emergency override: Majburiy loading to'xtatuvchi
setTimeout(() => {
  const gl = document.getElementById('global-loader');
  if (gl) gl.style.display = 'none'; // yashirish
  document.querySelectorAll('.spinner, .fa-spinner').forEach(el => {
    // try to remove spinners or parent fallback
    if(el.parentElement && el.parentElement.tagName !== 'BUTTON') el.remove();
  });
  const refreshBtn = document.querySelector('button[onclick="loadDashboard()"]');
  if (refreshBtn && refreshBtn.disabled) {
    refreshBtn.disabled = false;
    refreshBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Yangilash';
  }
}, 2000);

// Start
loadDashboard();
</script>
