function getInstallmentRowHtml(index, dateVal, amountVal, paidVal, productVal, monthVal, notesVal) {
  return `
    <div class="installment-row" style="display:flex; align-items:center; gap:6px; background:var(--bg-secondary); border:1px solid var(--border); padding:6px 8px; border-radius:6px; margin-bottom:4px;">
