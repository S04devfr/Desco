      }

      if (productChart) productChart.destroy();
      const top = safeProductData.slice(0, 8);
      const COLORS = ['#6366F1','#34C759','#FF9500','#FF3B30','#A855F7','#00C7BE','#FF2D55','#AC8E68'];
      const fmtS = v => v >= 1e9 ? (v/1e9).toFixed(1)+'B' : v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v.toString();

