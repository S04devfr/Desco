<script>
// ── Dashboard real-time yangilanish (WebSocket) ──
(function() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  let _ws, _retryTimer, _debounce;

  function connect() {
    _ws = new WebSocket(proto + '//' + location.host);
    _ws.onmessage = (evt) => {
      try {
        const data = JSON.parse(evt.data);
        if (['deal_created','deal_updated','deal_deleted'].includes(data.type)) {
          clearTimeout(_debounce);
          _debounce = setTimeout(() => {
            if (typeof loadDashboard === 'function') loadDashboard();
          }, 800); // 800ms debounce — bir nechta event kelsa bitta refresh
        }
      } catch(_) {}
    };
    _ws.onclose = () => {
      clearTimeout(_retryTimer);
      _retryTimer = setTimeout(connect, 4000); // 4s dan keyin qayta ulanish
    };
    _ws.onerror = () => _ws.close();
  }

  // Sahifa yuklangandan keyin ulan
  window.addEventListener('load', connect);
})();
</script>
