async function saveQuickNasiyaCreate() {
  const contactName = document.getElementById('quickNasiyaClientName').value.trim();
  const contactPhone = document.getElementById('quickNasiyaClientPhone').value.trim();
  const city = document.getElementById('quickNasiyaClientCity').value.trim();
  const productName = document.getElementById('quickNasiyaProductName').value.trim();
  const amount = Number(document.getElementById('quickNasiyaAmount').value) || 0;
  const paidAmount = Number(document.getElementById('quickNasiyaPaidAmount').value) || 0;
  
  if (!contactName || !contactPhone || !productName || !amount) {
    alert("Iltimos, yulduzcha (*) qo'yilgan barcha maydonlarni to'ldiring!");
    return;
  }
  
  const saveBtn = document.getElementById('btnSaveQuickNasiya');
  saveBtn.disabled = true;
  
  try {
    // 1. Fetch pipelines to get a default pipelineId and stageId
    const pipelines = await dashFetch('/api/pipelines');
    let pipelineId = null;
    let stageId = null;
    if (pipelines && pipelines.length > 0) {
      pipelineId = pipelines[0].id;
      if (pipelines[0].stages && pipelines[0].stages.length > 0) {
        stageId = pipelines[0].stages[0].id;
      }
    }
    
    // 2. Create the deal via POST /api/deals
    const r = await fetch('/api/deals', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        productName,
        amount,
        paidAmount,
        contactName,
        contactPhone,
        city,
        pipelineId,
        stageId,
        status: 'new'
      })
    });
    
    if (!r.ok) {
      const errData = await r.json();
      throw new Error(errData.message || "Sdelka yaratishda xato");
    }
    
    const newDeal = await r.json();
    if (typeof showToast === 'function') showToast('Sdelka yaratildi. Endi nasiya planni tuzishingiz mumkin.', 'success');
    
    // Add to local manuallyAddedDealIds and load editor for this deal
    manuallyAddedDealIds.push(newDeal.id);
    
    // Reload financial data from server (so the deal list is fully updated)
    await loadFinancialData();
    
    // Automatically select the newly created deal for installments
    selectedDealIdForInstallments = newDeal.id;
    renderInstallmentTab();
    
  } catch(e) {
    console.error(e);
    alert("Xatolik yuz berdi: " + e.message);
  } finally {
    if (saveBtn) saveBtn.disabled = false;
  }
}

