  const allDebts = [];
  // Manual client debts
  allClientsData.forEach(c => {
    if (c.debt && c.debt > 0) {
      allDebts.push({
        id: c.id,
        name: c.name,
        amount: c.debt,
        type: 'manual',
        notes: c.debtNotes || 'Manual qarzdorlik'
      });
