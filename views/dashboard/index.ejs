}

async function toggleTask(id, el) {
  const completed = !el.classList.contains('done');
  try {
    const r = await fetch('/api/tasks/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ completed })
    });
    if (r.ok) {
      el.classList.toggle('done');
      el.innerHTML = completed ? '<i class="fas fa-check" style="font-size:9px"></i>' : '';
      el.nextElementSibling.querySelector('.task-title').classList.toggle('done');
      if (typeof window.updateSidebarTaskBadge === 'function') window.updateSidebarTaskBadge();
    }
  } catch(e) {}
}

// ── PROFIT MODAL LOGIC ──
let profitDeals = [];
let profitKpis = {};
let profitFilter = 'all';

function openProfitModal() {
  document.getElementById('profitModal').classList.remove('hidden');
  
  // Set initial filter to match the main dashboard filter
  const mainFilter = document.getElementById('dashFilter').value;
  profitFilter = mainFilter;
  
  if (mainFilter === 'range') {
    document.getElementById('pmf-startDate').value = document.getElementById('startDate').value;
    document.getElementById('pmf-endDate').value = document.getElementById('endDate').value;
  } else {
    document.getElementById('pmf-startDate').value = '';
    document.getElementById('pmf-endDate').value = '';
  }

  loadProfitData();
}

function closeProfitModal() {
  document.getElementById('profitModal').classList.add('hidden');
}

function setProfitFilter(filter) {
  profitFilter = filter;
  if (filter !== 'range') {
    document.getElementById('pmf-startDate').value = '';
    document.getElementById('pmf-endDate').value = '';
  }
  loadProfitData();
}

async function loadProfitData() {
  const tbody = document.getElementById('profitTableBody');
  tbody.innerHTML = '<tr><td colspan="8" style="padding:40px; text-align:center; color:var(--text-tertiary)"><div class="spinner" style="margin:auto"></div></td></tr>';

  try {
    let urlParams = `filter=${profitFilter}`;
    if (profitFilter === 'range') {
      const sDate = document.getElementById('pmf-startDate').value;
      const eDate = document.getElementById('pmf-endDate').value;
      if (sDate && eDate) {
        urlParams += `&startDate=${sDate}&endDate=${eDate}`;
      }
    }

    // Fetch KPIs and Deals
    const [kpis, deals] = await Promise.all([
      dashFetch(`/api/dashboard/kpis?${urlParams}`),
      dashFetch(`/api/deals`)
    ]);

    profitKpis = kpis || { totalRevenue:0, totalCostPrice:0, totalExpenses:0, netProfit:0 };
    profitDeals = deals || [];

    // Render Stats
    document.getElementById('pm-totalRevenue').textContent = fmtMoney(profitKpis.totalRevenue);
    document.getElementById('pm-totalCostPrice').textContent = fmtMoney(profitKpis.totalCostPrice);
    document.getElementById('pm-totalExpenses').textContent = fmtMoney(profitKpis.totalExpenses);
    document.getElementById('pm-netProfit').textContent = fmtMoney(profitKpis.netProfit);
    document.getElementById('pm-netProfit').className = profitKpis.netProfit >= 0 ? 'text-success' : 'text-danger';

    // Highlight active filter button
    const btns = ['today', 'yesterday', 'day-before-yesterday', 'month', 'all'];
    btns.forEach(b => {
      const btnEl = document.getElementById(`pmf-${b === 'day-before-yesterday' ? '3day' : b}`);
      if (btnEl) {
        if (profitFilter === b) {
          btnEl.style.background = 'var(--accent)';
          btnEl.style.color = '#fff';
        } else {
          btnEl.style.background = 'none';
          btnEl.style.color = 'var(--text-secondary)';
        }
      }
    });

    renderProfitTable();
  } catch(e) {
    console.error('Error loading profit details:', e);
    tbody.innerHTML = '<tr><td colspan="8" style="padding:20px; text-align:center; color:var(--danger)">Ma\'lumotlarni yuklashda xatolik yuz berdi.</td></tr>';
  }
}

function renderProfitTable() {
  const tbody = document.getElementById('profitTableBody');

  // Filter deals based on selected date range
  let start = null, end = null;
  const now = new Date();
  
  if (profitFilter === 'today') {
    start = new Date(now); start.setHours(0,0,0,0);
    end = new Date(now); end.setHours(23,59,59,999);
  } else if (profitFilter === 'yesterday') {
    start = new Date(now); start.setDate(start.getDate() - 1); start.setHours(0,0,0,0);
    end = new Date(now); end.setDate(end.getDate() - 1); end.setHours(23,59,59,999);
  } else if (profitFilter === 'day-before-yesterday') {
    start = new Date(now); start.setDate(start.getDate() - 2); start.setHours(0,0,0,0);
    end = new Date(now); end.setDate(end.getDate() - 2); end.setHours(23,59,59,999);
  } else if (profitFilter === 'month') {
    start = new Date(now); start.setDate(1); start.setHours(0,0,0,0);
    end = new Date(now); end.setHours(23,59,59,999);
  } else if (profitFilter === 'range') {
    const sVal = document.getElementById('pmf-startDate').value;
    const eVal = document.getElementById('pmf-endDate').value;
    if (sVal && eVal) {
      start = new Date(sVal); start.setHours(0,0,0,0);
      end = new Date(eVal); end.setHours(23,59,59,999);
    }
  }

  const getEffectivePaid = (d) => {
    const stageName = (d.stage?.name || '').toLowerCase();
    const isWon = d.status === 'won' || 
                  stageName.includes('100%') || 
                  stageName.includes('yutil') || 
                  stageName.includes('won');
    return isWon ? (d.amount || 0) : (d.paidAmount || 0);
  };

  const filteredDeals = profitDeals.filter(d => {
    const effectivePaid = getEffectivePaid(d);
    // Only show priced deals that are 100% paid effectively
    if (d.amount <= 0 || d.amount - effectivePaid > 0) return false;
    
    if (start && end) {
      const dDate = new Date(d.createdAt);
      return dDate >= start && dDate <= end;
    }
    return true;
  });

  if (!filteredDeals.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="padding:30px; text-align:center; color:var(--text-tertiary)"><i class="fas fa-box-open" style="font-size:24px; opacity:0.4; display:block; margin-bottom:8px"></i>Ushbu davrda sotuvlar topilmadi</td></tr>';
    return;
  }

  tbody.innerHTML = filteredDeals.map(d => {
    const dateFormatted = d.createdAt ? new Date(d.createdAt).toLocaleString('uz-UZ', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '-';
    const effectivePaid = getEffectivePaid(d);
    const profit = effectivePaid - (d.costPrice || 0);
    return `
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:10px 14px; font-size:12.5px; color:var(--text-tertiary)">${dateFormatted}</td>
        <td style="padding:10px 14px; font-size:13px; font-weight:600; color:var(--text-primary)"><i class="fas fa-shopping-bag" style="color:var(--accent); margin-right:6px"></i>${escHtml(d.productName)}</td>
        <td style="padding:10px 14px; font-size:12.5px;">
          ${d.client ? `
            <div style="font-weight:600; color:var(--text-primary)">${escHtml(d.client.name)}</div>
            ${d.client.phone ? `<a href="tel:${escHtml(d.client.phone)}" style="font-size:11px; color:var(--accent); font-weight:500">${escHtml(d.client.phone)}</a>` : ''}
          ` : '<span style="color:var(--text-tertiary)">-</span>'}
        </td>
        <td style="padding:10px 14px; font-size:12.5px; font-weight:600; text-align:right">${fmtMoney(d.amount)}</td>
        <td style="padding:10px 14px; font-size:12.5px; font-weight:600; color:#34C759; text-align:right">${fmtMoney(effectivePaid)}</td>
        <td style="padding:10px 14px; font-size:12.5px; font-weight:600; color:#5856D6; text-align:right">${fmtMoney(d.costPrice || 0)}</td>
        <td style="padding:10px 14px; font-size:12.5px; font-weight:700; color:${profit >= 0 ? '#34C759' : '#FF3B30'}; text-align:right">${fmtMoney(profit)}</td>
