<script>
let salesChart, productChart;
const USER_ROLE = '<%= typeof user !== "undefined" && user ? user.role : "" %>';

// Dynamic filter handlers
function onFilterChange() {
  const filter = document.getElementById('dashFilter').value;
  const rangeContainer = document.getElementById('dateRangeContainer');
  if (filter === 'range') {
    rangeContainer.style.display = 'inline-flex';
  } else {
    rangeContainer.style.display = 'none';
    loadDashboard();
  }
}

document.getElementById('startDate').addEventListener('change', () => {
  if (document.getElementById('endDate').value) loadDashboard();
});
document.getElementById('endDate').addEventListener('change', () => {
  if (document.getElementById('startDate').value) loadDashboard();
});

async function dashFetch(url, timeoutMs = 8000) {
  const controller = new AbortController();
  const id = setTimeout(() => controller.abort(), timeoutMs);
  let r;
  try {
    r = await fetch(url, { signal: controller.signal });
    clearTimeout(id);
  } catch(err) {
    clearTimeout(id);
    throw new Error("Tarmoq xatosi yoki server ishlamayapti (Timeout).");
  }
  let data;
  try { data = await r.json(); } catch { data = {}; }
  if (!r.ok) {
    if (typeof _toast === 'function') _toast(data.message || 'Server xatosi: ' + r.status, 'error');
    throw new Error(data.message || (url + ' -> ' + r.status));
  }
  return data;
}

// Helpers
function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function fmtMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + " so'm";
}
function renderCardMoney(v) {
  return (Number(v) || 0).toLocaleString('uz-UZ') + ' <span class="currency-label">UZS</span>';
}
function fmtShort(v) {
  const n = Number(v) || 0;
  if (n >= 1e9) return (n / 1e9).toFixed(1).replace('.0', '') + " mlrd";
  if (n >= 1e6) return (n / 1e6).toFixed(1).replace('.0', '') + " mln";
  if (n >= 1e3) return (n / 1e3).toFixed(0) + " ming";
  return String(n);
}
function fmtDate(d) {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return typeof d === 'object' ? JSON.stringify(d) : String(d);
  const dd = String(dt.getDate()).padStart(2, '0');
  const mm = String(dt.getMonth() + 1).padStart(2, '0');
  const yyyy = dt.getFullYear();
  return `${dd}.${mm}.${yyyy}`;
}

// Export Excel (multi-sheet professional)
function exportCSV() {
  const filter = document.getElementById('dashFilter')?.value || 'month';
  let url = '/api/export/excel?filter=' + filter;
  if (filter === 'range') {
    const s = document.getElementById('startDate')?.value;
    const e = document.getElementById('endDate')?.value;
    if (s && e) url += '&startDate=' + s + '&endDate=' + e;
  }
  // Show loading state
  const card = document.getElementById('exportCard');
  if (card) {
    card.style.opacity = '0.6';
    card.style.pointerEvents = 'none';
    setTimeout(() => { card.style.opacity = '1'; card.style.pointerEvents = ''; }, 3000);
  }
  window.location.href = url;
}

// Update export button URL when filter changes
function updateExportUrl() {
  const filter = document.getElementById('dashFilter')?.value || 'month';
  let url = '/api/export/excel?filter=' + filter;
  if (filter === 'range') {
    const s = document.getElementById('startDate')?.value;
    const e = document.getElementById('endDate')?.value;
    if (s && e) url += '&startDate=' + s + '&endDate=' + e;
  }
  const btn = document.getElementById('exportCsvBtn');
  if (btn) btn.href = url;
}

// Main loader
async function loadDashboard() {
  try {
    const filter = document.getElementById('dashFilter') ? document.getElementById('dashFilter').value : 'all';
    let urlParams = 'filter=' + filter;
    if (filter === 'range') {
      const start = document.getElementById('startDate').value;
      const end = document.getElementById('endDate').value;
      if (start && end) {
        urlParams += '&startDate=' + start + '&endDate=' + end;
      }
    }
    updateExportUrl();

    const [kpis, salesData, productData, igStats, pipelineStats, clientInsights, mktSummary, activityStats] = await Promise.all([
      dashFetch('/api/dashboard/kpis?' + urlParams).catch(err => ({ error: err.message })),
      dashFetch('/api/dashboard/sales-by-manager?' + urlParams).catch(() => []),
      dashFetch('/api/dashboard/product-popularity?' + urlParams).catch(() => []),
      dashFetch('/api/dashboard/instagram-stats?' + urlParams).catch(() => ({})),
      dashFetch('/api/dashboard/pipeline-stats?' + urlParams).catch(() => []),
      dashFetch('/api/dashboard/client-insights?' + urlParams).catch(() => ({})),
      dashFetch('/api/marketing/summary?' + urlParams).catch(() => ({ totalSpent:0, totalLeads:0, cpl:0, byChannel:[], logs:[] })),
      dashFetch('/api/activity/stats').catch(() => ({ managers: [], daily: [] }))
    ]);

    const safeKpis = kpis || {};
    if (safeKpis.error) {
      document.getElementById('debugErrorContainer').style.display = 'block';
      document.getElementById('debugErrorMessage').innerText = safeKpis.error;
    } else {
      document.getElementById('debugErrorContainer').style.display = 'none';
    }
    const netProfitVal = safeKpis.netProfit ?? 0;
    const profitClass = netProfitVal >= 0 ? 'text-success' : 'text-danger';
    const cplVal = safeKpis.cpl ?? 0;
    const roiVal = safeKpis.marketingRoi ?? 0;

    const nasiya = (safeKpis.nasiyaDesco?.amount || 0) + (safeKpis.nasiyaIshonch?.amount || 0) + (safeKpis.nasiyaBaraka?.amount || 0);
    const nasiyaCount = (safeKpis.nasiyaDesco?.count || 0) + (safeKpis.nasiyaIshonch?.count || 0) + (safeKpis.nasiyaBaraka?.count || 0);

    // ══════════════════════════════════════════
    // QATOR 1: Leadlar | Zakazlar | Nasiya/Savdo/Qarzdorlar | Klientlardagi Qarz (admin) | Zakazlar holati
    // ══════════════════════════════════════════
    let row1Html = `
      <div class="stat-card clickable" onclick="window.location.href='/deals'">
        <div class="stat-icon blue"><i class="fas fa-bullseye"></i></div>
        <div class="stat-info">
          <div class="stat-label">Leadlar</div>
          <div class="stat-value">${safeKpis.totalOrders ?? 0}</div>
          <div class="stat-sub">Jami kirgan buyurtmalar</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="openFinancialModal('installments')">
        <div class="stat-icon green"><i class="fas fa-shopping-cart"></i></div>
        <div class="stat-info">
          <div class="stat-label">Zakazlar</div>
          <div class="stat-value">${safeKpis.won ?? 0}</div>
          <div class="stat-sub">Yopilgan (Won): ${renderCardMoney(safeKpis.totalRevenue ?? 0)}</div>
        </div>
      </div>
      <div class="stat-card clickable" onclick="window.location.href='/nasiya/list?stage=nasiya'">
        <div class="stat-icon green"><i class="fas fa-coins"></i></div>
        <div class="stat-info">
          <div class="stat-label">Nasiya / Savdo / Qarzdorlar</div>
          <div class="stat-value">${renderCardMoney(nasiya)}</div>
          <div class="stat-sub">Soni: ${nasiyaCount} ta nasiya · Shopir: ${fmtMoney(safeKpis.shopir?.amount ?? 0)}</div>
        </div>
      </div>
    `;

    if (USER_ROLE === 'admin') {
      row1Html += `
        <div class="stat-card clickable" onclick="openFinancialModal('client-debts')">
          <div class="stat-icon red"><i class="fas fa-hand-holding-usd"></i></div>
          <div class="stat-info">
            <div class="stat-label">Klientlardagi Qarz</div>
            <div class="stat-value">${renderCardMoney(safeKpis.totalClientDebt ?? 0)}</div>
            <div class="stat-sub">To'lanmagan qoldiq</div>
          </div>
        </div>
      `;
    }

    row1Html += `
      <div class="stat-card clickable" onclick="window.location.href='/deals'" style="padding:14px 16px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          <div class="stat-icon blue" style="margin:0;flex-shrink:0;"><i class="fas fa-layer-group"></i></div>
          <div>
            <div class="stat-label" style="margin:0;">Zakazlar holati</div>
            <div style="font-size:13px;font-weight:700;color:var(--text-primary);">${(safeKpis.totalOrders ?? 0)} ta jami</div>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          ${(function() {
            var stgs = Array.isArray(pipelineStats) ? pipelineStats.slice().sort(function(a,b){return b.count-a.count;}).slice(0,4) : [];
            if (!stgs.length) return '<div style="font-size:11px;color:var(--text-muted);">Bosqich yo\'q</div>';
            var total = stgs.reduce(function(s,st){return s+st.count;},0) || 1;
            var colors = ['#6366F1','#34C759','#FF9500','#FF3B30'];
            return stgs.map(function(st,i) {
              var pct = Math.round((st.count/total)*100);
              var c = colors[i] || '#888';
              return '<div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;">'
                + '<div style="width:7px;height:7px;border-radius:50%;background:' + c + ';flex-shrink:0;"></div>'
                + '<div style="flex:1;font-size:10.5px;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + escHtml(st.name) + '</div>'
                + '<div style="font-size:10.5px;font-weight:700;color:var(--text-primary);min-width:16px;text-align:right;">' + st.count + '</div>'
                + '<div style="width:36px;height:4px;background:var(--surface-elevated);border-radius:2px;flex-shrink:0;margin-left:4px;">'
                +   '<div style="width:' + pct + '%;height:100%;background:' + c + ';border-radius:2px;"></div>'
                + '</div>'
              + '</div>';
            }).join('');
          })()}
        </div>
      </div>
    `;

    document.getElementById('kpiRow1').innerHTML = row1Html;

    // ══════════════════════════════════════════
    // QATOR 2: Marketing/Target | Xodimlar/Maosh/KPI | Tan narx (admin) | Harajatlar (admin) | Sof foyda (admin)
    // ══════════════════════════════════════════
    let row2Html = '';

    if (USER_ROLE === 'admin') {
      row2Html = `
        <div class="stat-card clickable" onclick="window.location.href='/expenses'">
          <div class="stat-icon orange"><i class="fas fa-bullhorn"></i></div>
          <div class="stat-info">
            <div class="stat-label">Marketing / Target</div>
            <div class="stat-value">${renderCardMoney((mktSummary?.totalSpent ?? 0) || (safeKpis.totalMarketingExpenses ?? 0))}</div>
            <div class="stat-sub">Lead: ${mktSummary?.totalLeads ?? 0} ta · CPL: ${fmtMoney(cplVal)} · ROI: ${roiVal.toFixed(0)}%</div>
          </div>
        </div>

        <div class="stat-card clickable" onclick="document.getElementById('managerKpiSection')?.scrollIntoView({behavior:'smooth'})">
          <div class="stat-icon blue"><i class="fas fa-users-cog"></i></div>
          <div class="stat-info">
            <div class="stat-label">Xodimlar / Maosh / KPI</div>
            <div class="stat-value">${(safeKpis.managersList?.length ?? 0)}</div>
            <div class="stat-sub">Faol menejerlar · KPI kalkulyator ↓</div>
          </div>
        </div>

        <div class="stat-card clickable" onclick="openFinancialModal('cost-prices')">
          <div class="stat-icon purple"><i class="fas fa-tags"></i></div>
          <div class="stat-info">
            <div class="stat-label">Tan narx</div>
            <div class="stat-value">${renderCardMoney(safeKpis.totalCostPrice ?? 0)}</div>
            <div class="stat-sub">Jami mahsulot tannarxi</div>
          </div>
        </div>

        <div class="stat-card clickable" onclick="window.location.href='/expenses'">
          <div class="stat-icon red"><i class="fas fa-receipt"></i></div>
          <div class="stat-info">
            <div class="stat-label">Harajatlar</div>
            <div class="stat-value">${renderCardMoney(safeKpis.totalExpenses ?? 0)}</div>
            <div class="stat-sub">${(() => {
              const cats = safeKpis.expenseByCategory || {};
              const parts = Object.entries(cats).slice(0,3).map(([k,v]) => k + ': ' + fmtMoney(v));
              return parts.length ? parts.join(' · ') : 'Hali xarajat yoq';
            })()}</div>
          </div>
        </div>

        <div class="stat-card clickable" onclick="openProfitModal()">
          <div class="stat-icon green"><i class="fas fa-chart-line"></i></div>
          <div class="stat-info">
            <div class="stat-label">Sof foyda</div>
            <div class="stat-value ${profitClass}" style="filter: blur(5px); cursor: pointer; transition: filter 0.25s; display: inline-flex; align-items: center; gap: 8px;" onclick="event.stopPropagation(); this.style.filter = this.style.filter === 'none' ? 'blur(5px)' : 'none'; const icon = this.querySelector('i'); if (icon) { icon.className = this.style.filter === 'none' ? 'fas fa-eye' : 'fas fa-eye-slash'; }" title="Ko'rish / Yashirish uchun bosing">
              <span>${renderCardMoney(netProfitVal)}</span>
              <i class="fas fa-eye-slash" style="font-size: 11px; opacity: 0.6;"></i>
            </div>
            <div class="stat-sub">Savdo − Tannarx − Xarajat</div>
          </div>
        </div>
      `;
    }

    document.getElementById('kpiRow2').innerHTML = row2Html;

    // ══════════════════════════════════════════
    // UMUMIY STATISTIKALAR bo'limi yangilash
    // ══════════════════════════════════════════
    const ins = clientInsights || {};
    const mgrList = safeKpis.managersList || [];

    const mgrEl = document.getElementById('statMgrTotal');
    if (mgrEl) mgrEl.textContent = mgrList.length + ' ta';
    const mgrSubEl = document.getElementById('statMgrSub');
    if (mgrSubEl) mgrSubEl.textContent = 'Eng yaxshi: ' + (mgrList[0]?.name || '—');

    const satEl = document.getElementById('statSatisfaction');
    if (satEl) {
      satEl.textContent = (ins.satisfactionRate ?? 0) + '%';
      satEl.style.color = (ins.satisfactionRate ?? 0) >= 50 ? '#34C759' : '#FF9500';
    }
    const cmpEl = document.getElementById('statComplaintSub');
    if (cmpEl) cmpEl.textContent = `Qiziqish: ${ins.interested ?? 0} ta · Shikoyat: ${ins.complaints ?? 0} ta`;

    const cncEl = document.getElementById('statCanceled');
    if (cncEl) cncEl.textContent = (safeKpis.totalCanceledCount ?? 0) + ' ta';
    const cncSubEl = document.getElementById('statCanceledSub');
    if (cncSubEl) cncSubEl.textContent = `Summasi: ${fmtMoney(safeKpis.totalCanceledValue ?? 0)} · ${(safeKpis.cancellationRate ?? 0).toFixed(0)}% rad`;

    // ══════════════════════════════════════════
    // CRM bo'limi — sdelka/mijoz soni
    // ══════════════════════════════════════════
    const dealCountEl = document.getElementById('crmDealCount');
    if (dealCountEl) dealCountEl.textContent = (safeKpis.totalOrders ?? 0) + ' ta';

    // Mijoz va ombor sonini async olamiz
    dashFetch('/api/clients').then(clients => {
      const clEl = document.getElementById('crmClientCount');
      if (clEl) clEl.textContent = (Array.isArray(clients) ? clients.length : 0) + ' ta';
    }).catch(() => {});

    dashFetch('/api/warehouse').then(wh => {
      const items = wh?.inventory || [];
      const total = items.reduce((s, i) => s + (i.total || 0), 0);
      const whEl = document.getElementById('crmWarehouseCount');
      if (whEl) whEl.textContent = total + ' ta';
    }).catch(() => {});

    // ── Render Funnel (new design: track + fill) ──
    const funnel = safeKpis.funnelStages || { yangi: 0, muzokara: 0, lost: 0, total: 0 };
    const total = funnel.total || 1;
    const pctYangi = (funnel.yangi / total) * 100;
    const pctMuzokara = (funnel.muzokara / total) * 100;
    const pctLost = (funnel.lost / total) * 100;

    const funnelSteps = [
      { label: 'Yangi',          count: funnel.yangi,    pct: pctYangi,    color: 'linear-gradient(90deg,#4F46E5,#6366F1)' },
      { label: 'Muzokaralar',    count: funnel.muzokara, pct: pctMuzokara, color: 'linear-gradient(90deg,#FF9500,#FFB300)' },
      { label: 'Otmen zakazlar', count: funnel.lost,     pct: pctLost,     color: 'linear-gradient(90deg,#FF3B30,#FF453A)' },
    ];

    document.getElementById('funnelContainer').innerHTML = funnelSteps.map((s, i) => `
      <div class="funnel-step">
        <div class="funnel-track">
          <div class="funnel-fill" style="width:${Math.max(s.pct, 12)}%; background:${s.color};">
            <span class="funnel-fill-label">${i + 1}. ${s.label}</span>
            <span class="funnel-fill-count">${s.count} ta</span>
          </div>
        </div>
        <span class="funnel-pct">${s.pct.toFixed(0)}%</span>
      </div>
    `).join('');

    // ── Render Marketing section (Admin only) or Tasks section (Manager only) ──
    if (USER_ROLE !== 'admin') {
      try {
        const myTasks = await dashFetch('/api/tasks?completed=false');
        const tasksContainer = document.getElementById('myTasksContainer');
        const tasksCountEl = document.getElementById('myTasksCount');
        
        if (tasksContainer) {
          if (!myTasks || !myTasks.length) {
            tasksContainer.innerHTML = `
              <div class="empty-state" style="padding:40px; text-align:center; display:flex; flex-direction:column; justify-content:center; align-items:center; height:100%; gap:8px; flex:1;">
                <i class="fas fa-check-circle" style="font-size:32px; color:var(--success); opacity:0.8;"></i>
                <div style="font-size:13px; color:var(--text-primary); font-weight:600;">Hamma vazifalar bajarildi!</div>
                <div style="font-size:11px; color:var(--text-secondary);">Sizda faol vazifalar yo'q.</div>
              </div>
            `;
            if (tasksCountEl) tasksCountEl.textContent = '0 ta faol';
          } else {
            if (tasksCountEl) tasksCountEl.textContent = myTasks.length + ' ta faol';
            
            tasksContainer.innerHTML = myTasks.map(t => {
              const pColors = { high: '#FF3B30', medium: '#FF9500', low: '#34C759' };
              const pLabels = { high: 'Yuqori', medium: 'O\'rta', low: 'Past' };
              const pColor = pColors[t.priority] || '#8E8E93';
              const pLabel = pLabels[t.priority] || 'Noma’lum';
              
              const clientName = t.client?.name || 'Noma’lum mijoz';
              const clientPhone = t.client?.phone || '';
              
              const due = new Date(t.dueDate);
              const today = new Date();
              today.setHours(0,0,0,0);
              const isOverdue = due < today;
              const dueStr = due.toLocaleDateString('uz-UZ') + (t.dueTime ? ' ' + t.dueTime : '');
              const dueStyle = isOverdue ? 'color:#FF3B30; font-weight:600;' : 'color:var(--text-secondary);';
              
              const dealProduct = t.deal?.productName || 'Sdelka';
              const dealStage = t.deal?.stage?.name || 'Bosqichsiz';
              
              return `
                <div class="stat-card" style="padding: 10px 12px; margin: 0; border-radius: 8px; flex-shrink: 0; display: flex; flex-direction: column; gap: 6px; box-shadow: var(--shadow-xs); background: var(--surface-card); border: 1px solid var(--border); text-align: left;">
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                    <div style="font-weight: 700; font-size: 12.5px; color: var(--text-primary); text-overflow: ellipsis; overflow: hidden; white-space: nowrap; flex: 1;">
                      ${escHtml(t.title)}
                    </div>
                    <span style="font-size: 9px; font-weight: 700; color: #fff; background: ${pColor}; padding: 1px 5px; border-radius: 4px; flex-shrink: 0;">
                      ${pLabel}
                    </span>
                  </div>
                  
                  <div style="font-size: 11px; color: var(--text-secondary); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    ${escHtml(t.description || 'Izohsiz')}
                  </div>
                  
                  <div style="display: flex; justify-content: space-between; align-items: center; font-size: 10.5px; border-top: 1px dashed var(--border); padding-top: 5px; margin-top: 2px;">
                    <div>
                      <i class="fas fa-user" style="color: var(--text-secondary); margin-right: 3px;"></i>
                      <strong style="color: var(--text-primary);">${escHtml(clientName)}</strong> ${clientPhone ? `<span style="color: var(--text-secondary); font-size: 10px;">(${escHtml(clientPhone)})</span>` : ''}
                    </div>
                    <div style="${dueStyle}">
                      <i class="far fa-clock" style="margin-right: 3px;"></i>${dueStr}
                    </div>
                  </div>
                  
                  <div style="display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: var(--text-secondary);">
                    <div>
                      <i class="fas fa-shopping-bag" style="margin-right: 3px;"></i>${escHtml(dealProduct)}
                      <span class="badge badge-brand" style="font-size: 8.5px; padding: 1px 4px; margin-left: 4px; vertical-align: middle;">${escHtml(dealStage)}</span>
                    </div>
                    <a href="/deals" style="color: var(--brand); font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 3px; font-size: 10.5px;">
                      Sdelkaga o'tish <i class="fas fa-arrow-right" style="font-size: 9px;"></i>
                    </a>
                  </div>
                </div>
              `;
            }).join('');
          }
        }
      } catch (e) {
        console.error('[Dashboard Tasks Fetch error]', e);
      }
    } else {
      const mkt = mktSummary || { totalSpent:0, totalLeads:0, cpl:0, byChannel:[], logs:[] };
      const mktSpentEl = document.getElementById('mktTotalSpent');
      const mktLeadsEl = document.getElementById('mktTotalLeads');
      const mktCplEl   = document.getElementById('mktCpl');
      if (mktSpentEl) mktSpentEl.textContent = fmtMoney(mkt.totalSpent || 0);
      if (mktLeadsEl) mktLeadsEl.textContent = (mkt.totalLeads || 0) + ' ta';
      if (mktCplEl)   mktCplEl.textContent   = fmtMoney(mkt.cpl || 0);

      const channelColors = { instagram:'#E1306C', facebook:'#1877F2', google:'#EA4335', tiktok:'#010101', other:'#8E8E93' };
      const channelContainer = document.getElementById('mktChannelContainer');
      if (channelContainer && mkt.byChannel && mkt.byChannel.length) {
        channelContainer.innerHTML = mkt.byChannel.map(c => {
          const col = channelColors[c.channel] || '#6366F1';
          const label = c.channel.charAt(0).toUpperCase() + c.channel.slice(1);
          return `<div class="mkt-channel-chip" style="--ch:${col}">
            <span class="mkt-ch-dot"></span>
            <span class="mkt-ch-name">${label}</span>
            <span class="mkt-ch-stats">${fmtMoney(c.spent)} · ${c.leads} lead · CPL ${fmtMoney(c.cpl)}</span>
          </div>`;
        }).join('');
      }

      const mktLogsBody = document.getElementById('mktLogsBody');
      if (mktLogsBody) {
        const logs = mkt.logs || [];
        if (!logs.length) {
          mktLogsBody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--text-500)">Hali ma\'lumot yo\'q — + tugmasini bosing</td></tr>';
        } else {
          mktLogsBody.innerHTML = logs.map(l => {
            const cpl2 = l.leads > 0 ? l.spent / l.leads : 0;
            const col  = channelColors[l.channel] || '#6366F1';
            return `<tr>
              <td class="mkt-log-date">${new Date(l.date).toLocaleDateString('uz-UZ')}</td>
              <td><span class="mkt-ch-tag" style="--ch:${col}">${l.channel}</span></td>
              <td class="mkt-log-camp">${escHtml(l.campaign||'—')}</td>
              <td class="tr mkt-log-amt">${fmtMoney(l.spent)}</td>
              <td class="tc mkt-log-leads">${l.leads}</td>
              <td class="tr mkt-log-cpl">${fmtMoney(cpl2)}</td>
              <td class="tr mkt-log-del">
                <button class="btn btn-ghost btn-icon-sm" style="color:var(--danger)" onclick="deleteMktLog(${l.id})" title="O'chirish"><i class="fas fa-trash" style="font-size:10px;"></i></button>
              </td>
            </tr>`;
          }).join('');
        }
      }
    }

    // ── Render Manager KPI + Salary table ──
    const kpiBody = document.getElementById('managerKpiTableBody');
    if (kpiBody) {
      const managers = safeKpis.managersList || [];
      if (managers.length === 0) {
        kpiBody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-500)">Hozircha menejer ma\'lumotlari yo\'q</td></tr>';
      } else {
        // Activity stats map: userId -> {online, todayMin, todayHours}
        const actMgrs = (activityStats && activityStats.managers) ? activityStats.managers : [];
        const actMap  = {};
        actMgrs.forEach(function(a){ actMap[a.userId] = a; });

        // Har bir menejer uchun hisob-kitob
        const rows = managers.map(m => {
          const baseSalary  = m.baseSalary || 0;
          const kpiBonus    = m.kpiBonus || (m.wonCount * 100000);
          const totalFines  = m.totalFines || 0;
          const totalPay    = baseSalary + kpiBonus - totalFines;
          const winRate     = (m.winRate || 0).toFixed(0);
          const initials    = (m.name||'?').split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase();
          const winBadge    = winRate >= 60 ? 'badge-success' : winRate >= 35 ? 'badge-warning' : 'badge-danger';
          const perf        = winRate >= 60 ? 'high' : winRate >= 35 ? 'mid' : 'low';
          const finesDetail = (m.fines && m.fines.length)
            ? m.fines.map(f => '<div class="kpi-fine-item">−'+fmtMoney(f.amount)+(f.reason ? ' · '+escHtml(f.reason) : '')+'</div>').join('')
            : '';
          // Activity
          const act       = actMap[m.id] || {};
          const isOnline  = act.online === true;
          const todayMin  = act.todayMin || 0;
          const todayH    = Math.floor(todayMin / 60);
          const todayM    = todayMin % 60;
          const todayStr  = todayMin > 0 ? (todayH > 0 ? todayH+'s ' : '') + todayM+'d' : '—';
          const onlineDot = isOnline
            ? '<span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:#34C759;font-weight:600;"><span style="width:8px;height:8px;border-radius:50%;background:#34C759;display:inline-block;box-shadow:0 0 6px #34C75966;animation:pulse-green 2s infinite;"></span>Online</span>'
            : '<span style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--text-muted);"><span style="width:8px;height:8px;border-radius:50%;background:var(--text-muted);display:inline-block;opacity:0.5;"></span>Offline</span>';
          return '<tr class="kpi-row" data-perf="'+perf+'">'
            + '<td class="kpi-mgr-cell">'
            +   '<div class="kpi-avatar">'+initials+'</div>'
            +   '<span class="kpi-mgr-name">'+escHtml(m.name)+'</span>'
            + '</td>'
            + '<td class="tc" style="white-space:nowrap;">'+onlineDot+'</td>'
            + '<td class="tc" style="font-size:11px;font-weight:600;color:'+(todayMin>0?'var(--text-primary)':'var(--text-muted)')+';white-space:nowrap;">'+todayStr+'</td>'
            + '<td class="tc">'
            +   '<div class="kpi-won">'+m.wonCount+'</div>'
            +   '<div class="kpi-total-deals">/ '+m.totalCount+' jami</div>'
            + '</td>'
            + '<td class="tc"><span class="badge '+winBadge+' kpi-win-badge">'+winRate+'%</span></td>'
            + '<td class="tr"><input type="number" class="calc-input" value="'+baseSalary+'" step="100000" onchange="saveBaseSalary('+m.id+', this.value)"></td>'
            + '<td class="tr kpi-bonus-cell">'
            +   '<div class="kpi-bonus-val">'+fmtMoney(kpiBonus)+'</div>'
            +   '<div class="kpi-bonus-sub">'+m.wonCount+' × 100 000</div>'
            + '</td>'
            + '<td class="tc kpi-fine-cell">'
            +   (totalFines > 0
                  ? '<div class="kpi-fine-total">−'+fmtMoney(totalFines)+'</div>'+finesDetail
                  : '<span class="kpi-no-fine">—</span>')
            +   '<button class="kpi-add-fine" onclick="openFineModal('+m.id+',\''+escHtml(m.name)+'\')"><i class="fas fa-plus"></i> Jarima</button>'
            + '</td>'
            + '<td class="tr"><span class="kpi-payout" id="payout-'+m.id+'">'+fmtMoney(totalPay)+'</span></td>'
            + '</tr>';
        });

        // Jami byudjet qatori
        const grandTotal = managers.reduce(function(s, m) {
          const base = m.baseSalary || 0;
          const kpi  = m.kpiBonus || (m.wonCount * 100000);
          const fine = m.totalFines || 0;
          return s + base + kpi - fine;
        }, 0);
        const totalRow = '<tr class="kpi-total-row">'
          + '<td colspan="5" class="kpi-total-label"><i class="fas fa-wallet" style="margin-right:5px;color:var(--brand);"></i>Jami maosh byudjeti</td>'
          + '<td colspan="3"></td>'
          + '<td class="tr"><span class="kpi-payout">'+fmtMoney(grandTotal)+'</span></td>'
          + '</tr>';

        kpiBody.innerHTML = rows.join('') + totalRow;
      }
    }

    // Save base salary to DB
    window.saveBaseSalary = async function(managerId, val, inputEl) {
      try {
        const r = await fetch('/api/marketing/salary/' + managerId, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ baseSalary: Number(val) || 0 })
        });
        if (!r.ok) throw new Error();
        if (typeof showToast === 'function') showToast('Maosh saqlandi', 'success');
      } catch(e) {
        if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
      }
    };

    window.openFineModal = function(id, name) {
      document.getElementById('fineManagerId').value = id;
      document.getElementById('fineManagerName').value = name;
      document.getElementById('fineAmount').value = '';
      document.getElementById('fineReason').value = '';
      document.getElementById('fineModal').style.display = 'flex';
    };
    window.closeFineModal = function() {
