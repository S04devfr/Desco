window.submitClientDebtForm = async function() {
  const id = document.getElementById('debtClientId').value;
  const name = document.getElementById('debtClientName').value.trim();
  const phone = document.getElementById('debtClientPhone').value.trim();
  const city = document.getElementById('debtClientCity').value.trim();
  const debt = Number(document.getElementById('debtClientAmount').value) || 0;
  const debtDate = document.getElementById('debtClientDate').value;
  const debtNotes = document.getElementById('debtClientNotes').value.trim();

  if (!name) { alert("Mijoz ismini kiriting!"); return; }
  if (debt <= 0) { alert("Iltimos, to'g'ri qarz summasini kiriting!"); return; }

  const saveBtn = document.querySelector('#clientDebtModal .btn-primary');
  if (saveBtn) saveBtn.disabled = true;

  try {
    const payload = { name, phone, city, debt, debtDate, debtNotes };
    let r;
    if (id) {
      r = await fetch('/api/clients/' + id, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    } else {
      r = await fetch('/api/clients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    }

    if (!r.ok) {
      const err = await r.json();
      throw new Error(err.message || 'Saqlashda xato');
