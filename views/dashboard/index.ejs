            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════ -->
<!-- BO'LIM 2: UMUMIY STATISTIKALAR -->
<!-- ══════════════════════════════════════════════════════ -->
<div class="section-header mt">
  <div class="section-bar green"></div>
  <h2 class="section-title"><i class="fas fa-chart-pie" style="color:#34C759;"></i>Umumiy Statistikalar</h2>
  <div class="section-line"></div>
</div>

<div class="stats-grid mb-6">

  <!-- Menejerlar statistikasi -->
  <div class="stat-card clickable" onclick="document.getElementById('managerKpiSection')?.scrollIntoView({behavior:'smooth'})">
    <div class="stat-icon blue"><i class="fas fa-users-cog"></i></div>
    <div class="stat-info">
      <div class="stat-label">Menejerlar statistikasi</div>
      <div id="statMgrTotal" class="stat-value">—</div>
      <div id="statMgrSub" class="stat-sub">Menejerlar soni</div>
    </div>
  </div>

  <!-- Mijozlar qiziqishi -->
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-smile"></i></div>
    <div class="stat-info">
      <div class="stat-label">Mijozlar qiziqishi</div>
      <div id="statSatisfaction" class="stat-value" style="color:#34C759;">—%</div>
      <div id="statComplaintSub" class="stat-sub">Mamnuniyat darajasi</div>
    </div>
  </div>

  <!-- Otkaz va chiqimlar -->
