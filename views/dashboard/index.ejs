function renderClientDebtTable() {
  renderTopDebtorsList();
  const tbody = document.getElementById('clientDebtTableBody');
  const filterQuery = document.getElementById('clientDebtSearch').value.toLowerCase();
  
  const allDebts = [];
  
  // 1. Add manual client debts
  allClientsData.forEach(c => {
    if (c.debt && c.debt > 0) {
      allDebts.push({
        type: 'manual',
        id: c.id,
        name: c.name,
        phone: c.phone,
        city: c.city,
        date: c.debtDate ? c.debtDate.slice(0, 10) : '',
        amount: c.debt || 0,
        notes: c.debtNotes || '',
        managerName: c.owner?.fullName || 'Admin',
        isEditable: true
      });
    }
  });
  
  // 2. Add deal debts (Nasiya)
  allDealsData.forEach(d => {
    const debt = d.amount - d.paidAmount;
    if (debt > 0) {
      allDebts.push({
        type: 'nasiya',
        id: d.id,
        name: d.client?.name || 'Noma\'lum',
        phone: d.client?.phone || '',
        city: d.client?.city || '',
        date: d.createdAt ? d.createdAt.slice(0, 10) : '',
        amount: debt,
        notes: `${d.productName || 'Sdelka'} qarzi`,
        managerName: d.manager?.fullName || '—',
        isEditable: false
      });
    }
  });

  const filtered = allDebts.filter(item => 
    (item.name || '').toLowerCase().includes(filterQuery) ||
    (item.phone || '').toLowerCase().includes(filterQuery) ||
    (item.city || '').toLowerCase().includes(filterQuery) ||
    (item.notes || '').toLowerCase().includes(filterQuery) ||
    (item.managerName || '').toLowerCase().includes(filterQuery) ||
    String(item.id) === filterQuery
  );

  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-tertiary)"><i class="fas fa-search" style="font-size:20px; opacity:0.4; display:block; margin-bottom:8px"></i>Qarzdor mijozlar topilmadi. Mijoz qidirib qo\'shing yoki yangi yarating.</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map(item => {
    if (item.type === 'nasiya') {
      return `
        <tr style="background:rgba(255, 149, 0, 0.03);">
          <td style="text-align:center; font-weight:600; color:var(--text-secondary)">#${item.id}</td>
          <td style="font-weight:700; color:var(--text-primary)">${escHtml(item.name)}</td>
          <td style="text-align:center; font-family: monospace; font-size:12.5px;">${escHtml(item.phone || '—')}</td>
          <td style="text-align:center;">${escHtml(item.city || '—')}</td>
          <td style="text-align:center; color:var(--text-secondary)">${item.date ? new Date(item.date).toLocaleDateString('uz-UZ') : '—'}</td>
          <td style="text-align:right;">
            <div style="display:flex; align-items:center; justify-content:flex-end; gap:6px;">
              <span style="font-weight:800; color:var(--danger);">${fmtMoney(item.amount)}</span>
              <span style="font-size:10.0px; padding:2px 5px; background:#FF950020; color:#FF9500; border-radius:4px; font-weight:700; white-space:nowrap;"><i class="fas fa-calendar-alt"></i> Nasiya</span>
            </div>
          </td>
          <td style="color:var(--text-secondary); max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${escHtml(item.notes)}">${escHtml(item.notes)}</td>
          <td style="font-weight:600; color:var(--text-primary); text-align:center;">${escHtml(item.managerName)}</td>
          <td style="text-align:center;">
            <div style="display:flex; justify-content:center; gap:4px;">
              <button class="btn btn-ghost btn-sm text-accent" onclick="openNasiyaPlanForDeal(${item.id})" style="padding:4px 8px;" title="Nasiya rejasini boshqarish / Tahrirlash">
                <i class="fas fa-edit"></i>
              </button>
              <button class="btn btn-ghost btn-sm text-danger" onclick="deleteNasiyaDebt(${item.id})" style="padding:4px 8px;" title="Qarzni yopish (To'langan deb belgilash)">
                <i class="fas fa-trash-alt"></i>
              </button>
            </div>
          </td>
        </tr>
      `;
    } else {
      return `
        <tr>
          <td style="text-align:center; font-weight:600; color:var(--text-secondary)">#${item.id}</td>
          <td style="font-weight:700; color:var(--text-primary)">${escHtml(item.name)}</td>
          <td style="text-align:center; font-family: monospace; font-size:12.5px;">${escHtml(item.phone || '—')}</td>
          <td style="text-align:center;">${escHtml(item.city || '—')}</td>
          <td style="text-align:center; color:var(--text-secondary)">${item.date ? new Date(item.date).toLocaleDateString('uz-UZ') : '—'}</td>
          <td style="text-align:right; font-weight:800; color:var(--danger);">${fmtMoney(item.amount)}</td>
          <td style="color:var(--text-secondary); max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${escHtml(item.notes || '')}">${escHtml(item.notes || '—')}</td>
          <td style="font-weight:600; color:var(--text-primary); text-align:center;">${escHtml(item.managerName)}</td>
          <td style="text-align:center;">
            <div style="display:flex; justify-content:center; gap:4px;">
              <button class="btn btn-ghost btn-sm text-accent" onclick="openClientDebtModalForEdit(${item.id})" style="padding:4px 8px;" title="Tahrirlash">
                <i class="fas fa-edit"></i>
              </button>
              <button class="btn btn-ghost btn-sm text-danger" onclick="deleteClientDebt(${item.id})" style="padding:4px 8px;" title="Qarzdorlikni o'chirish">
                <i class="fas fa-trash-alt"></i>
              </button>
            </div>
          </td>
        </tr>
      `;
    }
  }).join('');
}

function openNasiyaPlanForDeal(dealId) {
  switchFinTab('installments');
  selectedDealIdForInstallments = dealId;
  renderInstallmentTab();
}

async function deleteClientDebt(clientId) {
  if (!confirm("Ushbu mijozning manual qarzdorlik summasini butunlay o'chirmoqchimisiz?")) return;
  
  try {
    const r = await fetch('/api/clients/' + clientId, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ debt: 0, debtDate: null, debtNotes: null })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('Qarzdorlik o\'chirildi', 'success');
    
    const c = allClientsData.find(x => x.id === clientId);
    if (c) {
      c.debt = 0;
      c.debtDate = null;
      c.debtNotes = null;
    }
    
    loadFinancialData();
    renderClientDebtTable();
  } catch(e) {
    if (typeof showToast === 'function') showToast('O\'chirishda xatolik yuz berdi', 'error');
  }
}

window.deleteNasiyaDebt = async function(dealId) {
  if (!confirm("Ushbu sdelkaning qolgan barcha qarzdorligini to'liq to'langan deb belgilab, qarzni yopmoqchimisiz?")) return;

  try {
    const deal = allDealsData.find(d => d.id === dealId);
    if (!deal) throw new Error("Sdelka topilmadi");

    const r = await fetch('/api/deals/' + dealId, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ paidAmount: deal.amount })
    });
    if (!r.ok) throw new Error();

    if (typeof showToast === 'function') showToast('Sdelka qarzi yopildi', 'success');

    await loadFinancialData();
    renderClientDebtTable();
    loadDashboard();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Qarzni yopishda xatolik yuz berdi', 'error');
  }
};

// Emergency override: Majburiy loading to'xtatuvchi
setTimeout(() => {
  const gl = document.getElementById('global-loader');
  if (gl) gl.style.display = 'none'; // yashirish
  document.querySelectorAll('.spinner, .fa-spinner').forEach(el => {
    // try to remove spinners or parent fallback
    if(el.parentElement && el.parentElement.tagName !== 'BUTTON') el.remove();
  });
  const refreshBtn = document.querySelector('button[onclick="loadDashboard()"]');
  if (refreshBtn && refreshBtn.disabled) {
    refreshBtn.disabled = false;
    refreshBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Yangilash';
  }
}, 2000);
// ── Marketing Modal ──
window.openMarketingModal = function() {
  const today = new Date().toISOString().slice(0, 10);
  document.getElementById('mktDate').value = today;
  document.getElementById('mktChannel').value = 'instagram';
  document.getElementById('mktCampaign').value = '';
  document.getElementById('mktSpent').value = '';
  document.getElementById('mktLeads').value = '';
  document.getElementById('mktNotes').value = '';
  document.getElementById('marketingModal').style.display = 'flex';
};
window.closeMarketingModal = function() {
  document.getElementById('marketingModal').style.display = 'none';
};
window.submitMarketingLog = async function() {
  const body = {
    date:     document.getElementById('mktDate').value,
    channel:  document.getElementById('mktChannel').value,
    campaign: document.getElementById('mktCampaign').value.trim() || null,
    spent:    Number(document.getElementById('mktSpent').value) || 0,
    leads:    Number(document.getElementById('mktLeads').value) || 0,
    notes:    document.getElementById('mktNotes').value.trim() || null
  };
  if (!body.date || !body.channel) { alert("Sana va kanal majburiy"); return; }
  try {
    const r = await fetch('/api/marketing', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!r.ok) throw new Error();
    closeMarketingModal();
    if (typeof showToast === 'function') showToast('Ma\'lumot qo\'shildi', 'success');
    loadDashboard();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Xatolik yuz berdi', 'error');
  }
};
window.deleteMktLog = async function(id) {
  if (!confirm("O'chirishni tasdiqlaysizmi?")) return;
  try {
    const r = await fetch('/api/marketing/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast('O\'chirildi', 'success');
    loadDashboard();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Xatolik', 'error');
  }
};

// Start
loadDashboard();
</script>

