function openAddProductModal() {
  // We'll create a simple prompt-based modal logic for adding
  const name = prompt("Mahsulot nomi:");
  if (!name) return;
  const price = prompt("Narxi (raqamda):");
  if (!price) return;
  const notes = prompt("Izoh (masalan qaysi shaharga qancha):");
  
  saveNewProduct(name, price, notes);
}

async function saveNewProduct(name, price, notes) {
  try {
    const r = await fetch('/api/product-catalog', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, price, notes })
    });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast('Qo\'shildi', 'success');
    loadFinancialData();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xato', 'error');
  }
}

async function deleteCatalogProduct(id) {
  if (!confirm('Rostdan ham o\'chirmoqchimisiz?')) return;
  try {
    const r = await fetch('/api/product-catalog/' + id, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    loadFinancialData();
  } catch(e) {}
}

async function attachProductToDeal() {
  const searchQ = document.getElementById('dealAttachSearch').value.toLowerCase();
  const selectEl = document.getElementById('catalogSelect');
  const catId = selectEl.value;
  
  if (!searchQ || !catId) return alert('Mijozni qidiring va mahsulotni tanlang!');
  
  const deal = allDealsData.find(d => 
    (d.client?.name || '').toLowerCase().includes(searchQ) ||
    String(d.client?.phone || '').includes(searchQ)
  );
  
  if (!deal) return alert('Sdelka (mijoz) topilmadi!');
  
  const opt = selectEl.options[selectEl.selectedIndex];
  const price = opt.getAttribute('data-price');
  const pName = opt.getAttribute('data-name');
  
  if (!confirm(`Sdelka: ${deal.client?.name}\nMahsulot: ${pName}\nNarx: ${price}\nBiriktirilsinmi?`)) return;
  
  try {
    const r = await fetch('/api/deals/' + deal.id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productName: pName, amount: Number(price) })
    });
    if (!r.ok) throw new Error();
    if (typeof showToast === 'function') showToast('Mahsulot biriktirildi', 'success');
    document.getElementById('dealAttachSearch').value = '';
    loadFinancialData();
  } catch(e) {
    if (typeof showToast === 'function') showToast('Xatolik yuz berdi', 'error');
  }
}

// Tab 2: Installments rendering & planners
function onNasiyaSearchInput() {
  const input = document.getElementById('addNasiyaSearchInput');
  const suggestionsEl = document.getElementById('nasiyaSearchSuggestions');
  const q = input.value.trim().toLowerCase();
  
  if (!q) {
    suggestionsEl.innerHTML = '';
    suggestionsEl.classList.add('hidden');
    return;
  }
  
  const cleanId = q.startsWith('#') ? q.substring(1) : q;
  
  // Filter deals with outstanding debt
  const matches = allDealsData.filter(d => {
    const hasDebt = d.amount > d.paidAmount;
    if (!hasDebt) return false;
    
    const matchesName = (d.client?.name || '').toLowerCase().includes(q);
    const matchesPhone = (d.client?.phone || '').includes(q);
    const matchesId = String(d.id) === cleanId;
    
    return matchesName || matchesPhone || matchesId;
  });
  
  if (!matches.length) {
    suggestionsEl.innerHTML = '<div style="padding:10px; font-size:11.5px; color:var(--text-tertiary); text-align:center;">Qarzdor sdelka topilmadi</div>';
    suggestionsEl.classList.remove('hidden');
    return;
  }
  
  suggestionsEl.innerHTML = matches.map(d => {
    const alreadyPlan = d.installments && d.installments.length > 0;
    return `
      <div class="suggestion-item" onclick="addDealToNasiyaList(${d.id})" style="padding:8px 10px; cursor:pointer; border-bottom:1px solid var(--border); transition:background 0.15s; text-align:left;" onmouseover="this.style.background='var(--bg-primary)'" onmouseout="this.style.background='transparent'">
        <div style="font-weight:600; font-size:12px; color:var(--text-primary); display:flex; justify-content:space-between; align-items:center;">
          <span>${escHtml(d.client?.name || 'Mijoz')} (#${d.id})</span>
          ${alreadyPlan ? '<span style="font-size:10px; color:var(--success); font-weight:700;"><i class="fas fa-check"></i> Reja bor</span>' : '<span style="font-size:10px; color:var(--accent); font-weight:700;">+ Yangi</span>'}
        </div>
        <div style="font-size:11px; color:var(--text-secondary); display:flex; justify-content:space-between; margin-top:2px;">
          <span>${escHtml(d.productName || 'Mahsulot')}</span>
          <span style="color:var(--danger); font-weight:700;">Qarz: ${fmtMoney(d.amount - d.paidAmount)}</span>
        </div>
      </div>
    `;
  }).join('');
  suggestionsEl.classList.remove('hidden');
}

function addDealToNasiyaList(dealId) {
  const input = document.getElementById('addNasiyaSearchInput');
  const suggestionsEl = document.getElementById('nasiyaSearchSuggestions');
  
  input.value = '';
  suggestionsEl.innerHTML = '';
  suggestionsEl.classList.add('hidden');
  
  if (!manuallyAddedDealIds.includes(dealId)) {
    manuallyAddedDealIds.push(dealId);
  }
  
  selectedDealIdForInstallments = dealId;
  renderInstallmentTab();
}

