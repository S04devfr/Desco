function addInstallmentRow() {
  const container = document.getElementById('instRowsContainer');
  const index = container.querySelectorAll('.installment-row').length;
  
  const lastRowDate = container.querySelector('.installment-row:last-child .inst-date');
  const lastProduct = container.querySelector('.installment-row:last-child .inst-product');
  let dateStr = new Date().toISOString().slice(0,10);
  let pName = lastProduct ? lastProduct.value : '';
  
  if (lastRowDate && lastRowDate.value) {
    const d = new Date(lastRowDate.value);
    d.setMonth(d.getMonth() + 1);
    dateStr = d.toISOString().slice(0,10);
  }

  const div = document.createElement('div');
  div.innerHTML = getInstallmentRowHtml(index, dateStr, 0, false, pName, `${index+1}-oy`, '');
  container.appendChild(div.firstElementChild);
}

function autoGenerateInstallments(dealId, months) {
  const deal = allDealsData.find(d => d.id === dealId);
  if (!deal) return;
  const remaining = deal.amount - deal.paidAmount;
  const eachVal = Math.round(remaining / months);

  const container = document.getElementById('instRowsContainer');
  container.innerHTML = '';
  
  for (let i = 0; i < months; i++) {
    const d = new Date();
    d.setMonth(d.getMonth() + i);
    const dateStr = d.toISOString().slice(0, 10);
    const amount = (i === months - 1) ? (remaining - (eachVal * (months - 1))) : eachVal;
    
    container.innerHTML += getInstallmentRowHtml(i, dateStr, amount, false, deal.productName, `${i+1}-oy`, '');
  }
}

async function saveInstallmentPlan(dealId) {
  const btn = document.getElementById('saveInstPlanBtn');
  btn.disabled = true;
  
  const container = document.getElementById('instRowsContainer');
  const rows = container.querySelectorAll('.installment-row');
  const installments = [];
  
  let totalScheduled = 0;
  for (const row of rows) {
    const dueDate = row.querySelector('.inst-date').value;
    const amount = Number(row.querySelector('.inst-amount').value) || 0;
    const paid = row.querySelector('.inst-paid').checked;
    const productName = row.querySelector('.inst-product').value;
    const month = row.querySelector('.inst-month').value;
    const notes = row.querySelector('.inst-notes').value;
    
    if (!dueDate) {
      if (typeof showToast === 'function') showToast('Sana kiritilishi majburiy', 'error');
      btn.disabled = false;
      return;
    }
    installments.push({ dueDate, amount, paid, productName, month, notes });
    totalScheduled += amount;
  }

  try {
    const deal = allDealsData.find(d => d.id === dealId);
    
    // 1. Update client name & phone if they changed
    if (deal && deal.client && deal.client.id) {
      const newName = document.getElementById('editNasiyaClientName').value.trim();
      const newPhone = document.getElementById('editNasiyaClientPhone').value.trim();
      if (newName && (newName !== deal.client.name || newPhone !== deal.client.phone)) {
        await fetch('/api/clients/' + deal.client.id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newName, phone: newPhone })
        });
      }
    }

    // 2. Save installments
    const r = await fetch('/api/deals/' + dealId + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('To\'lov plani saqlandi', 'success');
    manuallyAddedDealIds = manuallyAddedDealIds.filter(id => id !== dealId);
    loadFinancialData(); // Refresh metrics locally
  } catch(e) {
    if (typeof showToast === 'function') showToast('Saqlashda xatolik', 'error');
  } finally {
    btn.disabled = false;
  }
}

async function deleteInstallmentPlan(dealId) {
  if (!confirm("Haqiqatan ham ushbu nasiya to'lov rejasini o'chirmoqchimisiz? (Bu barcha rejalashtirilgan oylik to'lovlarni o'chiradi)")) return;
  
  try {
    const r = await fetch('/api/deals/' + dealId + '/installments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ installments: [] })
    });
    if (!r.ok) throw new Error();
    
    if (typeof showToast === 'function') showToast('Nasiya rejasi o\'chirildi', 'success');
    
    // Clear selection
    selectedDealIdForInstallments = null;
    manuallyAddedDealIds = manuallyAddedDealIds.filter(id => id !== dealId);
    loadFinancialData();
  } catch(e) {
    if (typeof showToast === 'function') showToast('O\'chirishda xatolik', 'error');
  }
}

