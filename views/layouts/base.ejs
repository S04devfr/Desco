<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'DESCO CRM' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/css/custom.css">
  <script>(function(){const t=localStorage.getItem('crm-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="app-wrapper">
  <%- include('../layouts/sidebar', { user: user, activePage: typeof activePage !== 'undefined' ? activePage : '' }) %>
  <div class="main-area">
    <%- include('../layouts/topbar', { user: user }) %>
    <div class="page-content">
      <%- body %>
    </div>
  </div>
</div>
<div id="toastContainer"></div>
<script src="/js/main.js"></script>
</body>
</html>
