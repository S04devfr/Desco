<header class="topbar">

  <!-- Left: menu toggle + page title -->
  <div class="flex items-center gap-3">
    <button class="topbar-btn mobile-menu-toggle hidden" onclick="toggleMobileMenu()" aria-label="Menu">
      <i class="fas fa-bars"></i>
    </button>
    <div class="breadcrumb" id="pageTitle"></div>
  </div>

  <!-- Right: search, theme, notifs, avatar -->
  <div class="topbar-right">

    <!-- Search -->
    <div class="topbar-search">
      <i class="fas fa-search"></i>
      <input type="text" id="globalSearch" placeholder="Mijoz, sdelka qidirish..." autocomplete="off">
    </div>

    <!-- Theme toggle -->
    <button class="topbar-btn" id="themeToggleBtn" title="Mavzuni o'zgartirish" onclick="toggleTheme()">
      <i class="fas fa-moon" id="themeIcon"></i>
    </button>

    <!-- Notifications -->
    <div style="position:relative;" id="notifWrap">
      <button class="topbar-btn" id="notifBtn" title="Bildirishnomalar" onclick="toggleNotifPanel()">
        <i class="fas fa-bell"></i>
        <span class="notif-badge hidden" id="notifCount">0</span>
      </button>

      <div class="notif-panel hidden" id="notifPanel">
        <div class="notif-panel-header">
          <span>Bildirishnomalar</span>
          <button class="notif-read-all" onclick="markAllRead()">Hammasini o'qildi</button>
        </div>
        <div class="notif-list" id="notifList">
          <div class="empty-state" style="padding:24px;">Bildirishnoma yo'q</div>
        </div>
      </div>
    </div>

    <!-- Profile -->
    <div style="position:relative;" id="profileWrap">
      <div class="topbar-avatar" id="profileBtn" onclick="toggleProfileMenu()" title="<%= user.fullName %>">
        <%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %>
      </div>

      <div class="profile-dropdown hidden" id="profileMenu">
        <div class="dropdown-profile-header">
          <div class="topbar-avatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;">
            <%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--text-900);">
              <%= user.fullName || 'Foydalanuvchi' %>
            </div>
            <div style="font-size:11.5px;color:var(--text-500);">
              <%= user.email %>
            </div>
          </div>
        </div>

        <div class="dropdown-divider"></div>

        <div class="dropdown-section">
          <a href="/settings#profile" class="dropdown-item">
            <i class="fas fa-user dropdown-item-icon"></i> Profil sozlamalari
          </a>
          <button class="dropdown-item" onclick="openPasswordModal()">
            <i class="fas fa-lock dropdown-item-icon"></i> Parol o'zgartirish
          </button>
        </div>

        <div class="dropdown-divider"></div>

        <div class="dropdown-section">
          <button class="dropdown-item danger" onclick="logout()">
            <i class="fas fa-sign-out-alt dropdown-item-icon"></i> Chiqish
          </button>
        </div>
      </div>
    </div>

  </div>
</header>

<!-- Password change modal -->
<div class="modal-overlay hidden" id="passwordModal">
  <div class="modal-box">
    <div class="modal-header">
      <h2>Parol o'zgartirish</h2>
      <button class="modal-close" onclick="closePasswordModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Joriy parol</label>
        <input type="password" id="pwCurrent" class="form-control" placeholder="••••••••">
      </div>
      <div class="form-group">
        <label class="form-label">Yangi parol</label>
        <input type="password" id="pwNew" class="form-control" placeholder="••••••••">
      </div>
      <div class="form-group">
        <label class="form-label">Yangi parolni takrorlang</label>
        <input type="password" id="pwConfirm" class="form-control" placeholder="••••••••">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closePasswordModal()">Bekor</button>
      <button class="btn btn-primary" onclick="submitPasswordChange()">Saqlash</button>
    </div>
  </div>
</div>

<script>
// ── Notifications ──
async function loadNotifications() {
  try {
    const res = await fetch('/api/notifications');
    if (!res.ok) return;
    const notifs = await res.json();
    const unread = notifs.filter(n => !n.read).length;
    const countEl = document.getElementById('notifCount');
    if (unread > 0) {
      countEl.textContent = unread > 9 ? '9+' : unread;
      countEl.classList.remove('hidden');
    } else {
      countEl.classList.add('hidden');
    }

    // Update sidebar task badge if needed
    const taskBadge = document.getElementById('sidebar-task-badge');
    if (taskBadge && unread > 0) {
      taskBadge.textContent = unread > 9 ? '9+' : unread;
      taskBadge.classList.remove('hidden');
    }

    const list = document.getElementById('notifList');
    if (!notifs.length) {
      list.innerHTML = "<div class='empty-state' style='padding:24px;'>Bildirishnoma yo'q</div>";
      return;
    }
    list.innerHTML = notifs.map(n => `
      <div class="notif-item ${n.read ? '' : 'notif-unread'}"
           ${n.read ? '' : `onclick="markAsRead('${n.id}',this)"`}
           style="cursor:${n.read ? 'default' : 'pointer'}">
        <div style="font-size:16px;color:${n.type==='overdue'?'var(--danger)':'var(--warning)'};flex-shrink:0;margin-top:1px;">
          <i class="fas fa-${n.type==='overdue'?'exclamation-circle':'clock'}"></i>
        </div>
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--text-900);margin-bottom:2px;">${n.title}</div>
          <div style="font-size:12px;color:var(--text-500);">${n.message}</div>
        </div>
      </div>`).join('');
  } catch(e) {}
}

function toggleNotifPanel() {
  document.getElementById('profileMenu').classList.add('hidden');
  document.getElementById('notifPanel').classList.toggle('hidden');
  if (!document.getElementById('notifPanel').classList.contains('hidden')) loadNotifications();
}

async function markAllRead() {
  await fetch('/api/notifications/read-all', { method: 'POST' });
  document.getElementById('notifCount').classList.add('hidden');
  loadNotifications();
}

async function markAsRead(id, el) {
  if (!el.classList.contains('notif-unread')) return;
  await fetch('/api/notifications/' + id + '/read', { method: 'POST' });
  el.classList.remove('notif-unread');
  el.style.opacity = '0';
  el.style.transition = 'opacity 0.25s';
  setTimeout(() => {
    el.remove();
    const countEl = document.getElementById('notifCount');
    let count = parseInt(countEl.textContent) || 0;
    if (--count > 0) { countEl.textContent = count > 9 ? '9+' : count; }
    else { countEl.classList.add('hidden'); }
    const list = document.getElementById('notifList');
    if (!list.querySelector('.notif-item')) {
      list.innerHTML = "<div class='empty-state' style='padding:24px;'>Bildirishnoma yo'q</div>";
    }
  }, 250);
}

// ── Profile dropdown ──
function toggleProfileMenu() {
  document.getElementById('notifPanel').classList.add('hidden');
  document.getElementById('profileMenu').classList.toggle('hidden');
}

document.addEventListener('click', (e) => {
  const pw = document.getElementById('profileWrap');
  const nw = document.getElementById('notifWrap');
  if (pw && !pw.contains(e.target)) document.getElementById('profileMenu')?.classList.add('hidden');
  if (nw && !nw.contains(e.target)) document.getElementById('notifPanel')?.classList.add('hidden');
});

// ── Password modal ──
function openPasswordModal() {
  document.getElementById('profileMenu').classList.add('hidden');
  document.getElementById('passwordModal').classList.remove('hidden');
}

function closePasswordModal() {
  document.getElementById('passwordModal').classList.add('hidden');
  ['pwCurrent','pwNew','pwConfirm'].forEach(id => { document.getElementById(id).value = ''; });
}

async function submitPasswordChange() {
  const current = document.getElementById('pwCurrent').value;
  const newPw   = document.getElementById('pwNew').value;
  const confirm = document.getElementById('pwConfirm').value;
  if (!current || !newPw) return showToast("Barcha maydonlarni to'ldiring", 'error');
  if (newPw !== confirm)  return showToast('Yangi parollar mos kelmadi', 'error');
  if (newPw.length < 6)   return showToast("Parol kamida 6 ta belgi bo'lishi kerak", 'error');
  try {
    const res = await fetch('/api/auth/change-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentPassword: current, newPassword: newPw })
    });
    const data = await res.json();
    if (!res.ok) return showToast(data.message || 'Xatolik yuz berdi', 'error');
    showToast("Parol muvaffaqiyatli o'zgartirildi", 'success');
    closePasswordModal();
  } catch(e) { showToast("Server bilan bog'lanishda xatolik", 'error'); }
}

// ── Mobile menu ──
function toggleMobileMenu() {
  document.querySelector('.sidebar').classList.toggle('mobile-open');
}

document.addEventListener('DOMContentLoaded', () => {
  loadNotifications();
  setInterval(loadNotifications, 2 * 60 * 1000);
});
</script>
