    </a>
    <a href="/tasks" class="<%= activePage === 'tasks' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-check-circle"></i></span>
      <span class="nav-label">Vazifalar</span>
      <span id="sidebar-task-badge" class="nav-badge" style="display: none;">0</span>
    </a>
    <a href="/expenses" class="<%= activePage === 'expenses' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-receipt"></i></span>
      <span class="nav-label">Xarajatlar</span>
    </a>
    <a href="/warehouse" class="<%= activePage === 'warehouse' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-warehouse"></i></span>
      <span class="nav-label">Ombor</span>
    </a>
    <a href="/instagram" class="<%= activePage === 'instagram' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fab fa-instagram" style="color:#E1306C"></i></span>
      <span class="nav-label">Instagram</span>
    </a>
    
    <!-- Qo'shimcha Submenu -->
    <div class="sidebar-submenu-container" style="margin-bottom: 4px;">
      <div class="sidebar-submenu-header <%= activePage.startsWith('extra') ? 'active' : '' %>" onclick="toggleSubmenu(this)">
        <span class="nav-icon"><i class="fas fa-plus-circle"></i></span>
        <span class="nav-label">Qo'shimcha</span>
        <i class="fas fa-chevron-right arrow-icon"></i>
      </div>
      <div class="sidebar-submenu-items">
        <a href="/extra/drivers" class="sub-item <%= activePage === 'extra-drivers' ? 'active' : '' %>">
