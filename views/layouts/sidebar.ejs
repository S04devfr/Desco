    <div>
      <h1>Desco<span style="color:var(--accent)">.crm</span></h1>
    </div>
  </div>

  <nav class="sidebar-nav">
    <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-chart-line"></i></span>
      <span class="nav-label">Tahlil</span>
    </a>
    <a href="/deals" class="<%= activePage === 'deals' ? 'active' : '' %>">
