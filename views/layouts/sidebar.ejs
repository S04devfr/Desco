          <span class="sub-dot" style="background:#3B82F6"></span> Shopirdagi pul
        </a>
        <a href="/nasiya/list?stage=desco" class="sub-item <%= activePage === 'nasiya-desco' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#10B981"></span> Nasiya Desco
        </a>
        <a href="/nasiya/list?stage=ishonch" class="sub-item <%= activePage === 'nasiya-ishonch' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#F59E0B"></span> Nasiya Ishonch
        </a>
        <a href="/nasiya/list?stage=baraka" class="sub-item <%= activePage === 'nasiya-baraka' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#EF4444"></span> Nasiya Baraka
        </a>
      </div>
    </div>

    <a href="/clients" class="<%= activePage === 'clients' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-users"></i></span>
