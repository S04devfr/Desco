</aside>

<style>
.sidebar-submenu-header {
  display: flex; align-items: center; gap: 12px; padding: 0 16px; height: 44px;
  color: var(--text-secondary); cursor: pointer; font-size: 14px; font-weight: 500;
  border-radius: var(--radius-sm); transition: var(--transition); position: relative;
}
.sidebar-submenu-header:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}
.sidebar-submenu-header.active {
  background: var(--accent);
  color: var(--text-on-accent) !important;
  border-left: 3px solid #818CF8;
}
.sidebar-submenu-header.active .nav-icon {
  color: var(--text-on-accent) !important;
}
.sidebar-submenu-header .arrow-icon {
  font-size: 10px; margin-left: auto; transition: transform 0.2s;
}
.sidebar-submenu-items {
  display: none; flex-direction: column; gap: 4px; padding-left: 16px; margin-top: 4px;
}
.sub-item {
  padding: 8px 12px; font-size: 13px; border-radius: var(--radius-sm);
  display: flex; align-items: center; gap: 10px;
  color: var(--text-secondary); text-decoration: none; transition: var(--transition);
}
.sub-item:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}
.sub-item.active {
  background: var(--accent-soft) !important;
  color: var(--accent) !important;
  font-weight: 600;
}
.sub-dot {
  width: 8px; height: 8px; border-radius: 50%;
}
.sidebar-submenu-header.open .arrow-icon {
  transform: rotate(90deg);
}
.sidebar-bottom button:hover {
  background: var(--danger-bg);
  color: var(--danger);
}
.sidebar-bottom button:hover i {
  color: var(--danger);
}
.nav-badge {
  background: var(--danger); color: white; padding: 2px 6px; border-radius: var(--radius-full); font-size: 10px; font-weight: bold; margin-left: auto;
}
</style>

<script>
function toggleSubmenu(header) {
  const container = header.parentElement;
  const items = container.querySelector('.sidebar-submenu-items');
  const arrow = header.querySelector('.arrow-icon');
  
  if (items.style.display === 'none' || !items.style.display) {
    items.style.display = 'flex';
    header.classList.add('open');
  } else {
    items.style.display = 'none';
    header.classList.remove('open');
  }
}

// Auto-open active submenus on page load
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.sidebar-submenu-container').forEach(container => {
    const hasActiveSub = container.querySelector('.sub-item.active');
    if (hasActiveSub) {
      const items = container.querySelector('.sidebar-submenu-items');
      const header = container.querySelector('.sidebar-submenu-header');
      if (items) items.style.display = 'flex';
      if (header) header.classList.add('open');
    }
  });
});
</script>
