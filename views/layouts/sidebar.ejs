<aside class="sidebar">

  <!-- Logo -->
  <a href="/" class="sidebar-logo">
    <div class="sidebar-logo-icon"><i class="fas fa-layer-group"></i></div>
    <div class="sidebar-logo-text">Desco<span>.crm</span></div>
  </a>

  <!-- Navigation -->
  <nav class="sidebar-nav">

    <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-chart-line"></i></span>
      <span class="nav-label">Tahlil</span>
    </a>

    <a href="/deals" class="<%= activePage === 'deals' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-handshake"></i></span>
      <span class="nav-label">Sdelkalar</span>
    </a>

    <!-- Nasiya submenu -->
    <div class="sidebar-submenu-container">
      <div class="sidebar-submenu-header <%= activePage.startsWith('nasiya') ? 'active' : '' %>" onclick="toggleSubmenu(this)">
        <span class="nav-icon"><i class="fas fa-wallet"></i></span>
        <span class="nav-label">Nasiya</span>
        <i class="fas fa-chevron-right arrow-icon"></i>
      </div>
      <div class="sidebar-submenu-items">
        <a href="/nasiya/list?stage=desco" class="sub-item <%= activePage === 'nasiya-desco' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#10B981"></span> Nasiya Desco
        </a>
        <a href="/nasiya/list?stage=ishonch" class="sub-item <%= activePage === 'nasiya-ishonch' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#F59E0B"></span> Nasiya Ishonch
        </a>
        <a href="/nasiya/list?stage=baraka" class="sub-item <%= activePage === 'nasiya-baraka' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#EF4444"></span> Nasiya Baraka
        </a>
      </div>
    </div>

    <a href="/clients" class="<%= activePage === 'clients' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-users"></i></span>
      <span class="nav-label">Mijozlar</span>
    </a>

    <a href="/tasks" class="<%= activePage === 'tasks' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-check-circle"></i></span>
      <span class="nav-label">Vazifalar</span>
      <span id="sidebar-task-badge" class="nav-badge hidden">0</span>
    </a>

    <a href="/expenses" class="<%= activePage === 'expenses' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-receipt"></i></span>
      <span class="nav-label">Xarajatlar</span>
    </a>

    <a href="/warehouse" class="<%= activePage === 'warehouse' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-warehouse"></i></span>
      <span class="nav-label">Ombor</span>
    </a>

    <a href="/plans" class="<%= activePage === 'plans' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-clipboard-list" style="color:#FF9500"></i></span>
      <span class="nav-label">Rejalar</span>
    </a>

    <!-- Qo'shimcha submenu -->
    <div class="sidebar-submenu-container">
      <div class="sidebar-submenu-header <%= (activePage.startsWith('extra') || activePage === 'instagram') ? 'active' : '' %>" onclick="toggleSubmenu(this)">
        <span class="nav-icon"><i class="fas fa-plus-circle"></i></span>
        <span class="nav-label">Qo'shimcha</span>
        <i class="fas fa-chevron-right arrow-icon"></i>
      </div>
      <div class="sidebar-submenu-items">
        <a href="/extra/drivers"  class="sub-item <%= activePage === 'extra-drivers'   ? 'active' : '' %>">
          <span class="sub-dot" style="background:#6366F1"></span> Shopirlar
        </a>
        <a href="/extra/branches" class="sub-item <%= activePage === 'extra-branches'  ? 'active' : '' %>">
          <span class="sub-dot" style="background:#A855F7"></span> Ishonch filiallari
        </a>
        <a href="/instagram" class="sub-item <%= activePage === 'instagram' ? 'active' : '' %>">
          <span class="sub-dot" style="background:#E1306C"></span> Instagram
        </a>
      </div>
    </div>

    <div class="nav-divider"></div>

    <a href="/ai" class="<%= activePage === 'ai' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-robot" style="color:var(--brand)"></i></span>
      <span class="nav-label">Desco AI</span>
    </a>

    <a href="/settings" class="<%= activePage === 'settings' ? 'active' : '' %>">
      <span class="nav-icon"><i class="fas fa-cog"></i></span>
      <span class="nav-label">Sozlamalar</span>
    </a>

  </nav>

  <!-- Bottom user section -->
  <div class="sidebar-bottom">
    <div class="sidebar-user" onclick="window.location.href='/settings'">
      <div class="sidebar-user-avatar">
        <%= user && user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div class="sidebar-user-info">
        <div class="name"><%= user ? user.fullName : '' %></div>
        <div class="role"><%= user && user.role === 'admin' ? 'Administrator' : 'Manager' %></div>
      </div>
    </div>
    <button class="sidebar-logout-btn" onclick="logout()">
      <span class="nav-icon"><i class="fas fa-sign-out-alt"></i></span>
      <span>Chiqish</span>
    </button>
  </div>

</aside>

<script>
function toggleSubmenu(header) {
  const items = header.nextElementSibling;
  const isOpen = items.classList.contains('open');
  items.classList.toggle('open', !isOpen);
  header.classList.toggle('open', !isOpen);
}

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.sidebar-submenu-container').forEach(container => {
    if (container.querySelector('.sub-item.active')) {
      container.querySelector('.sidebar-submenu-items')?.classList.add('open');
      container.querySelector('.sidebar-submenu-header')?.classList.add('open');
    }
  });
});
</script>
