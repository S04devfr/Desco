<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — Desco Lead CRM</title>
  <meta name="description" content="<%= pageDescription || 'Desco Lead CRM — Professional Meta Lead Ads Management Platform' %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #2563eb;
      --primary-dark: #1d4ed8;
      --primary-light: #3b82f6;
      --primary-soft: rgba(37, 99, 235, 0.08);
      --bg-body: #0a0f1a;
      --bg-card: #111827;
      --bg-card-hover: #1a2332;
      --border-color: rgba(255, 255, 255, 0.06);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent-gradient: linear-gradient(135deg, #2563eb, #7c3aed);
      --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.3);
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-body);
      color: var(--text-primary);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── HEADER ── */
    .legal-header {
      background: rgba(17, 24, 39, 0.95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .legal-header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .legal-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: var(--text-primary);
    }
    .legal-logo-icon {
      width: 40px;
      height: 40px;
      background: var(--accent-gradient);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 18px;
      font-weight: 800;
      box-shadow: 0 4px 16px rgba(37, 99, 235, 0.3);
    }
    .legal-logo-text {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    .legal-logo-text span { color: var(--primary-light); }

    .legal-nav {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .legal-nav a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 8px;
      transition: all 0.2s;
    }
    .legal-nav a:hover, .legal-nav a.active {
      color: var(--primary-light);
      background: var(--primary-soft);
    }

    /* ── HERO ── */
    .legal-hero {
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(124, 58, 237, 0.08));
      border-bottom: 1px solid var(--border-color);
      padding: 64px 32px 48px;
      text-align: center;
    }
    .legal-hero h1 {
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -1px;
      margin-bottom: 12px;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .legal-hero p {
      color: var(--text-secondary);
      font-size: 16px;
      max-width: 600px;
      margin: 0 auto;
    }
    .legal-hero .last-updated {
      display: inline-block;
      margin-top: 16px;
      font-size: 13px;
      color: var(--text-muted);
      background: rgba(255,255,255,0.04);
      padding: 6px 16px;
      border-radius: 20px;
      border: 1px solid var(--border-color);
    }

    /* ── CONTENT ── */
    .legal-content {
      max-width: 860px;
      margin: 0 auto;
      padding: 48px 32px 80px;
      flex: 1;
    }
    .legal-content h2 {
      font-size: 22px;
      font-weight: 700;
      color: var(--text-primary);
      margin: 40px 0 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-color);
      letter-spacing: -0.3px;
    }
    .legal-content h2:first-child { margin-top: 0; }
    .legal-content h3 {
      font-size: 17px;
      font-weight: 600;
      color: var(--primary-light);
      margin: 28px 0 10px;
    }
    .legal-content p {
      color: var(--text-secondary);
      font-size: 15px;
      margin-bottom: 16px;
    }
    .legal-content ul, .legal-content ol {
      color: var(--text-secondary);
      font-size: 15px;
      margin: 0 0 20px 24px;
    }
    .legal-content li { margin-bottom: 8px; }
    .legal-content a {
      color: var(--primary-light);
      text-decoration: none;
      border-bottom: 1px solid rgba(59, 130, 246, 0.3);
      transition: border-color 0.2s;
    }
    .legal-content a:hover { border-bottom-color: var(--primary-light); }
    .legal-content strong { color: var(--text-primary); font-weight: 600; }

    .info-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 24px 28px;
      margin: 24px 0;
    }
    .info-card.highlight {
      border-color: rgba(37, 99, 235, 0.3);
      background: rgba(37, 99, 235, 0.06);
    }
    .info-card h4 {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .info-card h4 i { color: var(--primary-light); }
    .info-card p, .info-card li { font-size: 14px; }

    .data-flow {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      margin: 28px 0;
    }
    .data-flow-step {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 14px 28px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-primary);
      min-width: 260px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .data-flow-step i { color: var(--primary-light); font-size: 16px; }
    .data-flow-arrow {
      color: var(--text-muted);
      font-size: 18px;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin: 24px 0;
    }
    .contact-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 28px;
      text-align: center;
      transition: border-color 0.3s;
    }
    .contact-card:hover { border-color: rgba(37, 99, 235, 0.4); }
    .contact-card i {
      font-size: 28px;
      color: var(--primary-light);
      margin-bottom: 16px;
    }
    .contact-card h4 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
    .contact-card p { font-size: 13px; color: var(--text-secondary); margin: 0; }

    /* ── FOOTER ── */
    .legal-footer {
      background: var(--bg-card);
      border-top: 1px solid var(--border-color);
      padding: 40px 32px;
    }
    .legal-footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
    }
    .legal-footer-links {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .legal-footer-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: color 0.2s;
    }
    .legal-footer-links a:hover { color: var(--primary-light); }
    .legal-footer-copy {
      color: var(--text-muted);
      font-size: 13px;
    }

    @media (max-width: 768px) {
      .legal-header-inner { flex-direction: column; gap: 12px; }
      .legal-nav { justify-content: center; }
      .legal-hero { padding: 40px 20px 32px; }
      .legal-hero h1 { font-size: 28px; }
      .legal-content { padding: 32px 20px 60px; }
      .legal-footer-inner { flex-direction: column; text-align: center; }
      .legal-footer-links { justify-content: center; }
    }
  </style>
</head>
<body>

  <header class="legal-header">
    <div class="legal-header-inner">
      <a href="/" class="legal-logo">
        <div class="legal-logo-icon">D</div>
        <div class="legal-logo-text">Desco <span>Lead CRM</span></div>
      </a>
      <nav class="legal-nav">
        <a href="/about" class="<%= activePage === 'about' ? 'active' : '' %>">About</a>
        <a href="/privacy" class="<%= activePage === 'privacy' ? 'active' : '' %>">Privacy</a>
        <a href="/terms" class="<%= activePage === 'terms' ? 'active' : '' %>">Terms</a>
        <a href="/cookies" class="<%= activePage === 'cookies' ? 'active' : '' %>">Cookies</a>
        <a href="/data-deletion" class="<%= activePage === 'data-deletion' ? 'active' : '' %>">Data Deletion</a>
        <a href="/contact" class="<%= activePage === 'contact' ? 'active' : '' %>">Contact</a>
      </nav>
    </div>
  </header>

  <section class="legal-hero">
    <h1><%= pageTitle %></h1>
    <p><%= pageSubtitle || '' %></p>
    <% if (lastUpdated) { %>
      <div class="last-updated"><i class="fas fa-calendar-alt"></i>&nbsp; Last Updated: <%= lastUpdated %></div>
    <% } %>
  </section>

  <main class="legal-content">
    <%- body %>
  </main>

  <footer class="legal-footer">
    <div class="legal-footer-inner">
      <div class="legal-footer-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/cookies">Cookie Policy</a>
        <a href="/data-deletion">Data Deletion</a>
        <a href="/contact">Support & Contact</a>
        <a href="/about">About Us</a>
      </div>
      <div class="legal-footer-copy">
        &copy; <%= new Date().getFullYear() %> Desco Lead CRM — Dilafruz Komilova / Desco premium 2. All rights reserved.
      </div>
    </div>
  </footer>

</body>
</html>
