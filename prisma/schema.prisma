generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String?
  role      String   @default("manager")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals          Deal[]
  tasks          Task[]
  expenses       Expense[]
  clients        Client[]
  activities     ActivityLog[]
  managerSalary  ManagerSalary?
  managerFines   ManagerFine[]
  plans          Plan[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  company   String?
  companyAddress String?
  notes     String?
  city      String?
  debt      Float    @default(0)
  debtDate  DateTime?
  debtNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId Int?
  owner   User?  @relation(fields: [ownerId], references: [id])

  deals Deal[]
  tasks Task[]

  instagramId       String? @unique
  instagramUsername String?
  messages          InstagramMessage[]

  @@index([ownerId])
  @@index([createdAt])
}

// ── VORONKA (PIPELINE) ──
model Pipeline {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  color       String   @default("#007AFF")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages PipelineStage[]
  deals  Deal[]
}

model PipelineStage {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#5D4037")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipelineId Int?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])

  deals Deal[]
}

model Deal {
  id          Int       @id @default(autoincrement())
  productName String
  amount      Float     @default(0)
  paidAmount  Float     @default(0)
  costPrice   Float     @default(0)
  status      String    @default("new")
  notes       String?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  managerId Int?
  manager   User? @relation(fields: [managerId], references: [id])

  stageId Int?
  stage   PipelineStage? @relation(fields: [stageId], references: [id])

  pipelineId Int?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])

  tasks        Task[]
  activities   ActivityLog[]
  installments Installment[]
  deliveryLog  DeliveryLog?
  warehouse        String?
  stockDecremented Boolean   @default(false)

  @@index([stageId])
  @@index([managerId])
  @@index([clientId])
  @@index([pipelineId])
  @@index([createdAt])
}

// ── YETKAZIB BERISH KUZATUVI ──
model DeliveryLog {
  id            Int       @id @default(autoincrement())
  dealId        Int       @unique
  deal          Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  shopirName    String?
  dispatchDate  DateTime  @default(now())
  deliveredDate DateTime?
  destination   String?

  status        String    @default("dispatched")    // dispatched | delivered | returned | cancelled
  paymentStatus String    @default("unpaid")        // unpaid | partial | paid
  collectedAmount Float   @default(0)
  paymentNotes  String?

  updatedBy     String?
  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([paymentStatus])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  createdAt DateTime @default(now())

  dealId Int?
  deal   Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float    @default(0)
  category    String   @default("other")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id])
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  completed   Boolean   @default(false)
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignedToId Int?
  assignedTo   User? @relation(fields: [assignedToId], references: [id])

  dealId Int?
  deal   Deal? @relation(fields: [dealId], references: [id])

  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id])

  @@index([assignedToId])
  @@index([completed])
  @@index([createdAt])
}

model CompanySettings {
  id                    Int      @id @default(autoincrement())
  companyName           String   @default("DESCO CRM")
  currency              String   @default("UZS")
  logoUrl               String?
  telegramSessionString String?
  telegramPhone         String?
  telegramApiId         String?
  telegramApiHash       String?
  instagramAccessToken  String?
  instagramPageId       String?
  instagramVerifyToken  String?
  updatedAt             DateTime @updatedAt
}

model InstagramAccount {
  id          Int      @id @default(autoincrement())
  accountId   String   @unique
  accessToken String?
  username    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstagramMessage {
  id        Int      @id @default(autoincrement())
  messageId String   @unique
  text      String?
  senderId  String
  recipientId String
  timestamp DateTime
  isOutgoing Boolean @default(false)
  createdAt DateTime @default(now())

  clientId  Int?
  client    Client?  @relation(fields: [clientId], references: [id])
}

model Installment {
  id          Int      @id @default(autoincrement())
  dealId      Int
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dueDate     DateTime
  amount      Float    @default(0)
  paid        Boolean  @default(false)
  productName String?
  month       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealId])
  @@index([dueDate])
}

model ProductCatalog {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shopir {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String?
  region     String?
  price      Float    @default(0)
  travelCost Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model IshonchFilial {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String?
  region     String?
  price      Float    @default(0)
  travelCost Float    @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WarehouseStock {
  id          Int      @id @default(autoincrement())
  warehouse   String
  productName String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([warehouse, productName])
}

model WarehouseLog {
  id          Int      @id @default(autoincrement())
  warehouse   String
  productName String
  changeQty   Int
  action      String
  notes       String?
  dealId      Int?
  userName    String?
  createdAt   DateTime @default(now())
}

// ── MARKETING & TARGET ──
model MarketingLog {
  id        Int      @id @default(autoincrement())
  date      DateTime
  channel   String   // instagram, facebook, google, tiktok, other
  campaign  String?  // kampaniya nomi / reklamasi
  spent     Float    @default(0)
  leads     Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── HODIMLAR OYLIK ──
model ManagerSalary {
  id         Int   @id @default(autoincrement())
  managerId  Int   @unique
  baseSalary Float @default(0)
  manager    User  @relation(fields: [managerId], references: [id])
}

model ManagerFine {
  id        Int      @id @default(autoincrement())
  managerId Int
  amount    Float    @default(0)
  reason    String?
  month     String   // "2025-01"
  createdAt DateTime @default(now())
  manager   User     @relation(fields: [managerId], references: [id])
}

model Plan {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("todo") // "todo", "progress", "done"
  priority    String   @default("medium") // "high", "medium", "low"
  color       String?  @default("#3b82f6")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
}

